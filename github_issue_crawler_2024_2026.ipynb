        "#@title Tải TensorFlow wheelhouse cho môi trường ChatGPT: Linux x86_64 + Python 3.13\n",
        "import os, sys, subprocess, shutil, textwrap, json, platform\n",
        "from pathlib import Path\n",
        "from google.colab import files\n",
        "\n",
        "TF_VERSION = \"2.21.0\"\n",
        "\n",
        "ROOT = Path(\"/content/tf_wheelhouse_cp313_linux_x86_64\")\n",
        "WHEELHOUSE = ROOT / \"wheelhouse\"\n",
        "ROOT.mkdir(parents=True, exist_ok=True)\n",
        "WHEELHOUSE.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "print(\"== THÔNG TIN COLAB ==\")\n",
        "print(\"Python Colab:\", sys.version)\n",
        "print(\"Platform Colab:\", platform.platform())\n",
        "print()\n",
        "print(\"== MỤC TIÊU TẢI ==\")\n",
        "print(\"TensorFlow:\", TF_VERSION)\n",
        "print(\"Target Python:\", \"CPython 3.13 / cp313\")\n",
        "print(\"Target OS:\", \"Linux x86_64\")\n",
        "print(\"Target manylinux:\", \"manylinux_2_27_x86_64\")\n",
        "print()\n",
        "\n",
        "subprocess.check_call([sys.executable, \"-m\", \"pip\", \"install\", \"-U\", \"pip\", \"wheel\", \"setuptools\"])\n",
        "\n",
        "# Tải wheel đúng ABI Python 3.13 cho Linux x86_64.\n",
        "# Không tải bản CUDA extra để giảm dung lượng và giảm rủi ro xung đột.\n",
        "cmd = [\n",
        "    sys.executable, \"-m\", \"pip\", \"download\",\n",
        "    f\"tensorflow=={TF_VERSION}\",\n",
        "    \"--dest\", str(WHEELHOUSE),\n",
        "    \"--only-binary=:all:\",\n",
        "    \"--implementation\", \"cp\",\n",
        "    \"--python-version\", \"313\",\n",
        "    \"--abi\", \"cp313\",\n",
        "    \"--platform\", \"manylinux_2_27_x86_64\",\n",
        "]\n",
        "\n",
        "print(\"== LỆNH TẢI ==\")\n",
        "print(\" \".join(cmd))\n",
        "print()\n",
        "\n",
        "subprocess.check_call(cmd)\n",
        "\n",
        "# Ghi script cài offline kèm theo\n",
        "install_script = ROOT / \"install_offline_tensorflow.sh\"\n",
        "install_script.write_text(f\"\"\"#!/usr/bin/env bash\n",
        "set -euo pipefail\n",
        "cd \"$(dirname \"$0\")\"\n",
        "\n",
        "python3 -m pip install --upgrade pip setuptools wheel\n",
        "\n",
        "python3 -m pip install \\\\\n",
        "  --no-index \\\\\n",
        "  --find-links ./wheelhouse \\\\\n",
        "  --only-binary=:all: \\\\\n",
        "  tensorflow=={TF_VERSION}\n",
        "\n",
        "python3 - <<'PY'\n",
        "import sys\n",
        "print(\"Python:\", sys.version)\n",
        "import tensorflow as tf\n",
        "print(\"TensorFlow:\", tf.__version__)\n",
        "print(\"Built with CUDA:\", tf.test.is_built_with_cuda())\n",
        "print(\"Physical devices:\", tf.config.list_physical_devices())\n",
        "PY\n",
        "\"\"\", encoding=\"utf-8\")\n",
        "os.chmod(install_script, 0o755)\n",
        "\n",
        "# Ghi manifest\n",
        "manifest = {\n",
        "    \"target\": {\n",
        "        \"python\": \"cp313-cp313\",\n",
        "        \"platform\": \"manylinux_2_27_x86_64\",\n",
        "        \"machine\": \"x86_64\",\n",
        "        \"os\": \"linux\",\n",
        "    },\n",
        "    \"tensorflow\": TF_VERSION,\n",
        "    \"note\": \"CPU/default TensorFlow wheelhouse, no [and-cuda] extra.\",\n",
        "    \"install\": \"bash install_offline_tensorflow.sh\",\n",
        "}\n",
        "(ROOT / \"manifest.json\").write_text(json.dumps(manifest, indent=2, ensure_ascii=False), encoding=\"utf-8\")\n",
        "\n",
        "print()\n",
        "print(\"== DANH SÁCH WHEEL ==\")\n",
        "total = 0\n",
        "for p in sorted(WHEELHOUSE.glob(\"*.whl\")):\n",
        "    size = p.stat().st_size\n",
        "    total += size\n",
        "    print(f\"{p.name}  {size/1024/1024:.1f} MB\")\n",
        "print(f\"Tổng dung lượng wheel: {total/1024/1024:.1f} MB\")\n",
        "\n",
        "# Nén\n",
        "archive_base = \"/content/tensorflow_2_21_0_cp313_linux_x86_64_wheelhouse\"\n",
        "archive_path = shutil.make_archive(\n",
        "    archive_base,\n",
        "    \"gztar\",\n",
        "    root_dir=str(ROOT.parent),\n",
        "    base_dir=ROOT.name,\n",
        ")\n",
        "\n",
        "print()\n",
        "print(\"== XONG ==\")\n",
        "print(\"Tệp:\", archive_path)\n",
        "print(\"Dung lượng nén:\", os.path.getsize(archive_path)/1024/1024, \"MB\")\n",
        "\n",
        "files.download(archive_path)"
      ]
