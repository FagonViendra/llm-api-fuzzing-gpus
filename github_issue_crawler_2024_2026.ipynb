        "        return \"drop\" if st.split(\":\", 1)[1] in DROP_ETYPES else \"keep\"\n",
        "    return \"keep\"\n",
        "\n",
        "all_real = [s for k in splits for s in splits[k]]\n",
        "run_status = smoke_validate(all_real) if CFG2[\"smoke_run\"] else {s[\"id\"]: \"unvalidated\" for s in all_real}\n",
        "st_count = Counter(run_status.values())\n",
        "for k in splits:\n",
        "    kept = []\n",
        "    for s in splits[k]:\n",
        "        s[\"run_status\"] = run_status.get(s[\"id\"], \"unvalidated\")\n",
        "        s[\"source\"] = \"github_issue\"\n",
        "        if verdict(s[\"run_status\"]) == \"keep\":\n",
        "            kept.append(s)\n",
        "    print(f\"  {k}: {len(splits[k])} → {len(kept)} sau bằng-chứng-thực-thi\")\n",
        "    splits[k] = kept\n",
        "\n",
        "# ═════ 2) Tiêm axiom exemplar — 9 idiom oracle từ docs, sinh tất định ════════\n",
        "SHAPES = [(8, 96, 24), (16, 128, 32), (24, 160, 48), (32, 192, 40), (48, 224, 56),\n",
        "          (64, 256, 64), (12, 320, 36), (20, 384, 28), (40, 144, 52), (28, 288, 44)]\n",
        "\n",
        "def T_metamorphic(i, n, k, m):\n",
        "    body = f\"f = lambda t: torch.cumsum(t, dim=1)\" if i % 2 else \\\n",
        "           f\"w = torch.randn({k}, {m})\\nf = lambda t: t @ w\"\n",
        "    return (\"metamorphic_axiom\", \"Probe IEEE sign symmetry: f(-x) must equal -f(x) bit-for-bit\",\n",
        "            [\"torch.randn\", \"torch.cumsum\", \"torch.equal\", \"torch.manual_seed\"], f\"\"\"import torch\n",
        "\n",
        "torch.manual_seed({1000 + i})\n",
        "x = torch.randn({n}, {k})\n",
        "{body}\n",
        "a = f(x)\n",
        "b = f(-x)\n",
        "same_bits = torch.equal(a.view(torch.int32), (-b).view(torch.int32))\n",
        "print(\"bitwise sign symmetry holds:\", same_bits)\n",
        "assert same_bits, \"round-to-nearest is an odd function; any bit mismatch is a proven violation\"\n",
        "\"\"\")\n",
        "\n",
        "def T_opcore(i, n, k, m):\n",
        "    return (\"op_core\", \"Chain identity diff(cumsum(x)) == x within float32 budget\",\n",
        "            [\"torch.cumsum\", \"torch.diff\", \"torch.zeros\"], f\"\"\"import torch\n",
        "\n",
        "torch.manual_seed({1100 + i})\n",
        "x = torch.randn({n}, {k})\n",
        "y = torch.diff(torch.cumsum(x, dim=1), dim=1, prepend=torch.zeros({n}, 1))\n",
        "err = (y - x).abs().max().item()\n",
        "print(\"diff(cumsum)=id max abs error:\", err)\n",
        "assert err < 1e-4, \"inverse-pair identity drifted beyond accumulation budget\"\n",
        "\"\"\")\n",
        "\n",
        "def T_device(i, n, k, m):\n",
        "    return (\"device_divergence\", \"Differential check of matmul across available backends\",\n",
        "            [\"torch.cuda.is_available\", \"torch.randn\"], f\"\"\"import torch\n",
        "\n",
        "torch.manual_seed({1200 + i})\n",
        "x = torch.randn({n}, {k})\n",
        "w = torch.randn({k}, {m})\n",
        "ref = x @ w\n",
        "if torch.cuda.is_available():\n",
        "    out = (x.cuda() @ w.cuda()).cpu()\n",
        "    tag = \"cpu-vs-cuda\"\n",
        "else:\n",
        "    out = x.t().contiguous().t() @ w\n",
        "    tag = \"contig-vs-roundtrip\"\n",
        "d = (ref - out).abs().max().item()\n",
        "print(tag, \"max abs divergence:\", d)\n",
        "assert d <= 1e-5 * max(ref.abs().max().item(), 1.0) * {k} ** 0.5, \"backend divergence beyond fp32 budget\"\n",
        "\"\"\")\n",
        "\n",
        "def T_compile(i, n, k, m):\n",
        "    return (\"compile_drift\", \"Eager vs compiled execution must agree within tolerance\",\n",
        "            [\"torch.compile\", \"torch.softmax\", \"torch.testing.assert_close\"], f\"\"\"import torch\n",
        "\n",
        "torch.manual_seed({1300 + i})\n",
        "x = torch.randn({n}, {k})\n",
        "w = torch.randn({k}, {m})\n",
        "def fn(t):\n",
        "    return torch.softmax(t @ w, dim=-1)\n",
        "eager = fn(x)\n",
        "try:\n",
        "    compiled_out = torch.compile(fn)(x)\n",
        "except Exception as exc:\n",
        "    print(\"compile path unavailable:\", type(exc).__name__)\n",
        "    compiled_out = fn(x)\n",
        "torch.testing.assert_close(eager, compiled_out, rtol=2e-5, atol=2e-6)\n",
        "print(\"eager and compiled outputs consistent\")\n",
        "\"\"\")\n",
        "\n",
        "def T_precision(i, n, k, m):\n",
        "    return (\"precision_dtype\", \"Certified Wilkinson-Higham envelope for fp32 matmul vs fp64 reference\",\n",
        "            [\"torch.double\", \"torch.abs\"], f\"\"\"import torch\n",
        "\n",
        "torch.manual_seed({1400 + i})\n",
        "A = torch.randn({n}, {k})\n",
        "B = torch.randn({k}, {m})\n",
        "C32 = A @ B\n",
        "C64 = A.double() @ B.double()\n",
        "u = 2.0 ** -24\n",
        "gamma = {k} * u / (1 - {k} * u)\n",
        "envelope = gamma * (A.abs().double() @ B.abs().double())\n",
        "violations = ((C32.double() - C64).abs() > envelope + 1e-30).sum().item()\n",
        "print(\"entries beyond certified error envelope:\", violations)\n",
        "assert violations == 0, \"dot-product rounding theorem violated -> silent precision substitution suspected\"\n",
        "\"\"\")\n",
        "\n",
        "def T_layout(i, n, k, m):\n",
        "    c = 4 + (i % 3) * 4\n",
        "    return (\"layout_phase\", \"Same conv, two memory layouts: results must agree\",\n",
        "            [\"torch.nn.Conv2d\", \"torch.channels_last\"], f\"\"\"import torch\n",
        "\n",
        "torch.manual_seed({1500 + i})\n",
        "x = torch.randn({max(n // 8, 2)}, {c}, 16, 16)\n",
        "conv = torch.nn.Conv2d({c}, {c}, 3, padding=1, bias=False)\n",
        "with torch.no_grad():\n",
        "    a = conv(x)\n",
        "    b = conv(x.to(memory_format=torch.channels_last)).contiguous()\n",
        "d = (a - b).abs().max().item()\n",
        "print(\"contiguous vs channels_last max diff:\", d)\n",
        "assert d < 1e-4, \"layout-dependent kernel divergence beyond budget\"\n",
        "\"\"\")\n",
        "\n",
        "def T_gradient(i, n, k, m):\n",
        "    return (\"gradient_adjoint\", \"gradcheck: backward must match finite-difference forward\",\n",
        "            [\"torch.autograd.gradcheck\", \"torch.cumsum\"], f\"\"\"import torch\n",
        "\n",
        "torch.manual_seed({1600 + i})\n",
        "x = torch.randn(4, {5 + i % 5}, dtype=torch.float64, requires_grad=True)\n",
        "def f(t):\n",
        "    return torch.cumsum(t, dim=1).tanh().sum()\n",
        "ok = torch.autograd.gradcheck(f, (x,), eps=1e-6, atol=1e-8)\n",
        "print(\"forward/backward consistency (gradcheck):\", ok)\n",
        "assert ok\n",
        "\"\"\")\n",
        "\n",
        "def T_boundary(i, n, k, m):\n",
        "    return (\"boundary_contract\", \"Empty and zero-dim tensors: shape/value contracts must hold exactly\",\n",
        "            [\"torch.zeros\", \"torch.cumsum\", \"torch.equal\"], f\"\"\"import torch\n",
        "\n",
        "x = torch.zeros(0, {m})\n",
        "y = torch.cumsum(x, dim=0)\n",
        "assert y.shape == (0, {m})\n",
        "z = torch.randn({n}, 0) @ torch.randn(0, {m})\n",
        "assert z.shape == ({n}, {m}) and torch.equal(z, torch.zeros({n}, {m})), \"empty-K matmul must be exact zeros\"\n",
        "s = torch.randn(()).reshape(1)\n",
        "print(\"empty/0-dim contracts hold:\", tuple(y.shape), tuple(z.shape), tuple(s.shape))\n",
        "\"\"\")\n",
        "\n",
        "def T_canary(i, n, k, m):\n",
        "    return (\"silent_correctness\", \"Canary lanes woven into a real matmul: basis row must copy B exactly\",\n",
        "            [\"torch.randn\", \"torch.equal\"], f\"\"\"import torch\n",
        "\n",
        "torch.manual_seed({1700 + i})\n",
        "A = torch.randn({max(n, 4)}, {k})\n",
        "B = torch.randn({k}, {m})\n",
        "u = {3 + i % 7}\n",
        "A[0].zero_()\n",
        "A[1].zero_()\n",
        "A[1, u] = 1.0\n",
        "C = A @ B\n",
        "zero_lane = torch.equal(C[0], torch.zeros({m}))\n",
        "copy_lane = torch.equal(C[1], B[u])\n",
        "print(\"canary lanes exact:\", zero_lane, copy_lane)\n",
        "assert zero_lane and copy_lane, \"canary corrupted -> silent precision substitution (e.g. TF32) or kernel defect\"\n",
        "\"\"\")\n",
        "\n",
        "TEMPLATES = [T_metamorphic, T_opcore, T_device, T_compile, T_precision,\n",
        "             T_layout, T_gradient, T_boundary, T_canary]\n",
