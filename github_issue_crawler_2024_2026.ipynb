      "source": [
        "# =========================\n",
        "# Colab cell: crawl bổ sung PyTorch/TensorFlow issues 2021-2023 theo created-range\n",
        "# Dedupe với dataset cũ nếu có, xuất zip riêng + combined jsonl\n",
        "# =========================\n",
        "\n",
        "!pip -q install requests tqdm pandas\n",
        "\n",
        "import os, re, json, time, random, hashlib, zipfile, getpass, ast, math\n",
        "from pathlib import Path\n",
        "from datetime import datetime, timezone, date, timedelta\n",
        "from concurrent.futures import ThreadPoolExecutor, as_completed\n",
        "\n",
        "import requests\n",
        "import pandas as pd\n",
        "from tqdm.auto import tqdm\n",
        "\n",
        "REPOS = [\"pytorch/pytorch\", \"tensorflow/tensorflow\"]\n",
        "OUT_DIR = Path(\"/content/dl_issue_fuzz_dataset_2021_2023\")\n",
        "OUT_DIR.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "EXISTING_ALL = Path(\"/content/dl_issue_fuzz_dataset_fast/all.jsonl\")\n",
        "\n",
        "# Search API chỉ 30 request/phút/token, nên đừng spam như đập chuột.\n",
        "SEARCH_SLEEP = 2.25\n",
        "MAX_WORKERS = 3\n",
        "MAX_COMMENT_PAGES = 2\n",
        "FETCH_COMMENTS_TOP_PER_REPO = 2500\n",
        "\n",
        "# Từ khóa high-yield. Ít nhưng chất, để tránh phí search quota.\n",
        "TERMS_BY_REPO = {\n",
        "    \"pytorch/pytorch\": [\n",
        "        \"label:bug\",\n",
        "        '\"module: correctness\"',\n",
        "        '\"module: autograd\"',\n",
        "        '\"module: cuda\"',\n",
        "        '\"module: dynamo\"',\n",
        "        '\"module: inductor\"',\n",
        "        '\"torch.compile\"',\n",
        "        \"segfault\",\n",
        "        \"crash\",\n",
        "        '\"wrong result\"',\n",
        "        \"incorrect\",\n",
        "        \"mismatch\",\n",
        "        \"autograd\",\n",
        "        \"gradient\",\n",
        "        \"cuda\",\n",
        "        \"dtype\",\n",
        "        \"shape\",\n",
        "        \"nan\",\n",
        "        \"inf\",\n",
        "        '\"minimal repro\"',\n",
        "        \"torch.\",\n",
        "    ],\n",
        "    \"tensorflow/tensorflow\": [\n",
        "        \"label:type:bug\",\n",
        "        \"label:comp:gpu\",\n",
        "        \"label:comp:xla\",\n",
        "        \"label:comp:keras\",\n",
        "        \"segfault\",\n",
        "        \"crash\",\n",
        "        '\"wrong result\"',\n",
        "        \"incorrect\",\n",
        "        \"mismatch\",\n",
        "        \"xla\",\n",
        "        \"jit_compile\",\n",
        "        \"tf.function\",\n",
        "        \"gradient\",\n",
        "        \"keras\",\n",
        "        \"dtype\",\n",
        "        \"shape\",\n",
        "        \"nan\",\n",
        "        \"inf\",\n",
        "        '\"minimal repro\"',\n",
        "        \"tf.\",\n",
        "    ],\n",
        "}\n",
        "\n",
        "FRAMEWORK_HINT = {\n",
        "    \"pytorch/pytorch\": \"pytorch\",\n",
        "    \"tensorflow/tensorflow\": \"tensorflow\",\n",
        "}\n",
        "\n",
        "API_REGEX = {\n",
        "    \"pytorch\": [\n",
        "        r\"\\btorch(?:\\.[A-Za-z_]\\w*){1,8}\\b\",\n",
        "        r\"\\btorchvision(?:\\.[A-Za-z_]\\w*){1,8}\\b\",\n",
        "        r\"\\bfunctorch(?:\\.[A-Za-z_]\\w*){0,8}\\b\",\n",
        "    ],\n",
        "    \"tensorflow\": [\n",
        "        r\"\\btf(?:\\.[A-Za-z_]\\w*){1,8}\\b\",\n",
        "        r\"\\btensorflow(?:\\.[A-Za-z_]\\w*){1,8}\\b\",\n",
        "        r\"\\bkeras(?:\\.[A-Za-z_]\\w*){1,8}\\b\",\n",
        "    ],\n",
        "}\n",
        "\n",
        "BUG_TERMS = [\n",
        "    \"bug\", \"regression\", \"crash\", \"segfault\", \"segmentation fault\",\n",
        "    \"runtimeerror\", \"assertionerror\", \"valueerror\", \"internalerror\",\n",
        "    \"wrong result\", \"incorrect\", \"mismatch\", \"inconsistency\",\n",
        "    \"cuda\", \"cudnn\", \"gpu\", \"xla\", \"autograd\", \"gradient\", \"backward\",\n",
        "    \"dtype\", \"shape\", \"nan\", \"inf\", \"minimal repro\", \"minimal reproduction\",\n",
        "    \"reproduce\", \"reproduction\", \"torch.compile\", \"dynamo\", \"inductor\",\n",
        "    \"tf.function\", \"keras\", \"jit_compile\",\n",
        "]\n",
        "\n",
        "TOKEN = os.environ.get(\"GITHUB_TOKEN\", \"\").strip()\n",
        "try:\n",
        "    from google.colab import userdata\n",
        "    TOKEN = TOKEN or (userdata.get(\"GITHUB_TOKEN\") or \"\").strip()\n",
        "except Exception:\n",
        "    pass\n",
        "\n",
        "if not TOKEN:\n",
        "    TOKEN = getpass.getpass(\"GITHUB_TOKEN: \").strip()\n",
        "\n",
        "HEADERS = {\n",
        "    \"Accept\": \"application/vnd.github+json\",\n",
        "    \"X-GitHub-Api-Version\": \"2022-11-28\",\n",
        "    \"User-Agent\": \"dl-fuzz-issue-created-range-crawler\",\n",
        "}\n",
        "if TOKEN:\n",
        "    HEADERS[\"Authorization\"] = f\"Bearer {TOKEN}\"\n",
        "\n",
        "S = requests.Session()\n",
        "API = \"https://api.github.com\"\n",
        "\n",
        "def now():\n",
        "    return datetime.now().strftime(\"%H:%M:%S\")\n",
        "\n",
        "def sha1(x):\n",
        "    return hashlib.sha1(x.encode(\"utf-8\", errors=\"ignore\")).hexdigest()\n",
        "\n",
        "def load_jsonl(p):\n",
        "    if not p.exists():\n",
        "        return []\n",
        "    rows = []\n",
        "    with open(p, \"r\", encoding=\"utf-8\") as f:\n",
        "        for line in f:\n",
        "            line = line.strip()\n",
        "            if line:\n",
        "                rows.append(json.loads(line))\n",
        "    return rows\n",
        "\n",
        "existing_rows = load_jsonl(EXISTING_ALL)\n",
        "existing_code_sha = set(r.get(\"code_sha1\") for r in existing_rows if r.get(\"code_sha1\"))\n",
        "existing_issue_key = set((r.get(\"repo\"), r.get(\"issue_number\")) for r in existing_rows)\n",
        "\n",
        "print(f\"[{now()}] Existing records loaded: {len(existing_rows)} | code_sha dedupe={len(existing_code_sha)}\")\n",
        "\n",
        "def gh_get(path, params=None, retries=8):\n",
        "    url = path if path.startswith(\"http\") else API + path\n",
        "    params = params or {}\n",
        "    for k in range(retries):\n",
        "        r = S.get(url, headers=HEADERS, params=params, timeout=45)\n",
        "        if r.status_code == 200:\n",
        "            return r.json(), r.headers\n",
        "\n",
        "        print(f\"[{now()}] HTTP {r.status_code} | remain={r.headers.get('x-ratelimit-remaining')} | resource={r.headers.get('x-ratelimit-resource')} | {r.text[:180]}\")\n",
        "\n",
        "        if r.status_code in (403, 429):\n",
        "            retry_after = r.headers.get(\"retry-after\")\n",
        "            if retry_after:\n",
        "                wait = int(retry_after) + 5\n",
        "            else:\n",
        "                reset = r.headers.get(\"x-ratelimit-reset\")\n",
        "                remain = r.headers.get(\"x-ratelimit-remaining\")\n",
        "                if remain == \"0\" and reset:\n",
        "                    wait = max(20, int(reset) - int(time.time()) + 5)\n",
        "                else:\n",
        "                    wait = 60 + 20 * k + random.randint(0, 20)\n",
        "            print(f\"[{now()}] throttle thật, ngủ {wait}s\")\n",
        "            time.sleep(wait)\n",
        "            continue\n",
        "\n",
        "        if r.status_code in (500, 502, 503, 504):\n",
        "            time.sleep(10 + 5 * k)\n",
        "            continue\n",
        "\n",
        "        raise RuntimeError(f\"GitHub lỗi {r.status_code}: {r.text[:600]}\")\n",
        "    raise RuntimeError(\"Hết retry\")\n",
        "\n",
        "def month_ranges(start=\"2021-01-01\", end=\"2023-12-31\"):\n",
        "    s = datetime.strptime(start, \"%Y-%m-%d\").date()\n",
        "    e = datetime.strptime(end, \"%Y-%m-%d\").date()\n",
        "    out = []\n",
        "    cur = date(s.year, s.month, 1)\n",
        "    while cur <= e:\n",
        "        if cur.month == 12:\n",
        "            nxt = date(cur.year + 1, 1, 1)\n",
        "        else:\n",
        "            nxt = date(cur.year, cur.month + 1, 1)\n",
        "        last = min(e, nxt - timedelta(days=1))\n",
        "        out.append((cur.isoformat(), last.isoformat()))\n",
        "        cur = nxt\n",
        "    return out\n",
        "\n",
        "def split_range(start_s, end_s):\n",
        "    s = datetime.strptime(start_s, \"%Y-%m-%d\").date()\n",
        "    e = datetime.strptime(end_s, \"%Y-%m-%d\").date()\n",
        "    if s >= e:\n",
        "        return None\n",
        "    mid = s + (e - s) // 2\n",
        "    return (s.isoformat(), mid.isoformat()), ((mid + timedelta(days=1)).isoformat(), e.isoformat())\n",
        "\n",
        "def search_issues(repo, term, start_s, end_s, depth=0):\n",
        "    q = f\"repo:{repo} is:issue created:{start_s}..{end_s} {term}\"\n",
        "    data, _ = gh_get(\n",
        "        \"/search/issues\",\n",
        "        {\n",
        "            \"q\": q,\n",
        "            \"sort\": \"updated\",\n",
        "            \"order\": \"desc\",\n",
        "            \"per_page\": 100,\n",
        "            \"page\": 1,\n",
        "        }\n",
        "    )\n",
        "    total = int(data.get(\"total_count\", 0) or 0)\n",
        "\n",
        "    # Nếu quá nhiều, tách đôi tiếp để né trần 1000 kết quả/search.\n",
        "    if total > 900 and depth < 8:\n",
        "        sp = split_range(start_s, end_s)\n",
        "        if sp:\n",
        "            left, right = sp\n",
        "            time.sleep(SEARCH_SLEEP)\n",
        "            return search_issues(repo, term, left[0], left[1], depth + 1) + search_issues(repo, term, right[0], right[1], depth + 1)\n",
        "\n",
        "    items = data.get(\"items\", []) or []\n",
        "    max_pages = min(10, math.ceil(min(total, 1000) / 100))\n",
        "    for page in range(2, max_pages + 1):\n",
        "        time.sleep(SEARCH_SLEEP)\n",
        "        d, _ = gh_get(\n",
        "            \"/search/issues\",\n",
        "            {\n",
        "                \"q\": q,\n",
        "                \"sort\": \"updated\",\n",
        "                \"order\": \"desc\",\n",
        "                \"per_page\": 100,\n",
        "                \"page\": page,\n",
        "            }\n",
        "        )\n",
        "        items.extend(d.get(\"items\", []) or [])\n",
        "\n",
        "    return [x for x in items if \"pull_request\" not in x]\n",
        "\n",
        "def labels(issue):\n",
        "    return [x.get(\"name\", \"\") for x in issue.get(\"labels\", []) if isinstance(x, dict)]\n",
        "\n",
        "def code_blocks(md):\n",
        "    md = md or \"\"\n",
        "    out = []\n",
        "    for m in re.finditer(r\"```[ \\t]*([A-Za-z0-9_+\\-\\.]*)?[ \\t]*\\n(.*?)```\", md, re.S):\n",
        "        out.append(((m.group(1) or \"\").lower(), m.group(2) or \"\"))\n",
        "    return out\n",
        "\n",
        "def apis(text, fw):\n",
        "    found = set()\n",
        "    for pat in API_REGEX[fw]:\n",
        "        for m in re.finditer(pat, text or \"\"):\n",
        "            x = m.group(0)\n",
        "            if len(x) < 160:\n",
        "                found.add(x.replace(\"tensorflow.\", \"tf.\"))\n",
        "    return sorted(found)\n",
        "\n",
        "def clean_code(c):\n",
        "    c = (c or \"\").replace(\"\\r\\n\", \"\\n\").replace(\"\\r\", \"\\n\")\n",
        "    lines = []\n",
        "    for line in c.splitlines():\n",
        "        line = re.sub(r\"^\\s*(>>>|\\.\\.\\.)\\s?\", \"\", line)\n",
        "        lines.append(line.rstrip())\n",
        "    return \"\\n\".join(lines).strip()[:12000]\n",
        "\n",
        "def ast_ok(c):\n",
        "    try:\n",
        "        ast.parse(c)\n",
        "        return True\n",
        "    except Exception:\n",
        "        return False\n",
        "\n",
        "def issue_score(issue, fw):\n",
        "    title = issue.get(\"title\") or \"\"\n",
        "    body = issue.get(\"body\") or \"\"\n",
        "    labs = \" \".join(labels(issue)).lower()\n",
        "    txt = (title + \"\\n\" + body + \"\\n\" + labs).lower()\n",
        "    score = 0\n",
        "    score += min(9, sum(1 for t in BUG_TERMS if t in txt))\n",
        "    if any(x in labs for x in [\"bug\", \"type:bug\", \"type: bug\", \"regression\", \"module:\", \"comp:\", \"triaged\"]):\n",
        "        score += 6\n",
        "    if code_blocks(body):\n",
        "        score += 6\n",
        "    if fw == \"pytorch\" and (\"torch.\" in body or \"import torch\" in body):\n",
        "        score += 5\n",
        "    if fw == \"tensorflow\" and (\"tf.\" in body or \"tensorflow\" in body or \"keras\" in body):\n",
        "        score += 5\n",
        "    score += min(4, int(issue.get(\"comments\") or 0) // 5)\n",
        "    return score\n",
        "\n",
        "def record_from_block(repo, issue, source, idx, lang, raw):\n",
        "    fw = FRAMEWORK_HINT[repo]\n",
        "    c = clean_code(raw)\n",
        "    if len(c) < 40:\n",
        "        return None\n",
        "\n",
        "    aa = apis(c, fw)\n",
        "    if not aa:\n",
        "        return None\n",
        "\n",
        "    if fw == \"pytorch\" and not re.search(r\"\\b(torch\\.|import torch|from torch|torchvision\\.|functorch\\.)\", c):\n",
        "        return None\n",
        "    if fw == \"tensorflow\" and not re.search(r\"\\b(tf\\.|tensorflow\\.|keras\\.|import tensorflow|from tensorflow|import keras)\", c):\n",
        "        return None\n",
        "\n",
        "    ctx = ((issue.get(\"title\") or \"\") + \"\\n\" + (issue.get(\"body\") or \"\")).lower()\n",
        "    sc = 6 + min(10, len(aa))\n",
        "    sc += min(9, sum(1 for t in BUG_TERMS if t in (ctx + \"\\n\" + c.lower())))\n",
        "    sc += 4 if ast_ok(c) else -1\n",
        "    sc += 4 if code_blocks(issue.get(\"body\") or \"\") else 0\n",
        "\n",
        "    # bỏ log môi trường thuần\n",
        "    if \"Collecting environment information\" in c and \"PyTorch version:\" in c:\n",
        "        sc -= 10\n",
        "\n",
        "    if sc < 8:\n",
        "        return None\n",
        "\n",
        "    h = sha1(c)\n",
        "    if h in existing_code_sha:\n",
        "        return None\n",
        "\n",
        "    return {\n",
        "        \"id\": f\"{repo}#{issue.get('number')}:{source}:{idx}:{h[:12]}\",\n",
        "        \"framework\": fw,\n",
        "        \"repo\": repo,\n",
        "        \"issue_number\": issue.get(\"number\"),\n",
        "        \"issue_title\": issue.get(\"title\"),\n",
        "        \"url\": issue.get(\"html_url\"),\n",
        "        \"created_at\": issue.get(\"created_at\"),\n",
        "        \"updated_at\": issue.get(\"updated_at\"),\n",
        "        \"labels\": labels(issue),\n",
        "        \"apis\": aa,\n",
        "        \"quality_score\": sc,\n",
        "        \"source\": source,\n",
        "        \"markdown_lang\": lang,\n",
        "        \"code_sha1\": h,\n",
        "        \"instruction\": \"Generate or mutate a minimal Python fuzzing/reproducer seed for PyTorch/TensorFlow bug discovery.\",\n",
        "        \"input\": f\"Framework: {fw}\\nIssue: {issue.get('title')}\\nAPIs: {', '.join(aa[:20])}\\nURL: {issue.get('html_url')}\",\n",
        "        \"output\": c,\n",
        "    }\n",
        "\n",
        "def fetch_comments(repo, issue):\n",
        "    comments = []\n",
        "    for page in range(1, MAX_COMMENT_PAGES + 1):\n",
        "        d, _ = gh_get(\n",
        "            f\"/repos/{repo}/issues/{issue['number']}/comments\",\n",
        "            {\"per_page\": 100, \"page\": page}\n",
        "        )\n",
        "        if not d:\n",
        "            break\n",
        "        comments.extend(d)\n",
        "        if len(d) < 100:\n",
        "            break\n",
        "        time.sleep(0.25)\n",
        "    return repo, issue, comments\n",
        "\n",
        "def write_jsonl(path, rows):\n",
        "    with open(path, \"w\", encoding=\"utf-8\") as f:\n",
        "        for r in rows:\n",
        "            f.write(json.dumps(r, ensure_ascii=False) + \"\\n\")\n",
        "\n",
        "# Check quota\n",
        "rate, _ = gh_get(\"/rate_limit\")\n",
        "print(\"[rate_limit]\", json.dumps(rate.get(\"resources\", {}).get(\"search\", {}), indent=2))\n",
        "\n",
        "# Stage 1: search candidates 2021-2023\n",
        "candidates = {}\n",
        "ranges = month_ranges(\"2021-01-01\", \"2023-12-31\")\n",
        "\n",
        "for repo in REPOS:\n",
        "    fw = FRAMEWORK_HINT[repo]\n",
        "    print(f\"\\n[{now()}] Search candidates repo={repo} created=2021..2023\")\n",
        "    terms = TERMS_BY_REPO[repo]\n",
        "\n",
        "    for start_s, end_s in tqdm(ranges, desc=f\"months {repo}\"):\n",
        "        for term in terms:\n",
        "            try:\n",
        "                items = search_issues(repo, term, start_s, end_s)\n",
        "                for it in items:\n",
        "                    if \"pull_request\" in it:\n",
        "                        continue\n",
        "                    key = (repo, it.get(\"number\"))\n",
        "                    old = candidates.get(key)\n",
        "                    if old is None or issue_score(it, fw) > issue_score(old, fw):\n",
        "                        candidates[key] = it\n",
        "            except Exception as e:\n",
        "                print(f\"[WARN] search lỗi {repo} {start_s}..{end_s} {term}: {e}\")\n",
        "            time.sleep(SEARCH_SLEEP)\n",
        "\n",
        "    xs = [it for (r, _), it in candidates.items() if r == repo]\n",
        "    print(f\"[{now()}] {repo}: candidates so far={len(xs)}\")\n",
        "\n",
        "# Stage 2: select top + fetch comments\n",
        "selected = []\n",
        "for repo in REPOS:\n",
        "    fw = FRAMEWORK_HINT[repo]\n",
        "    xs = [it for (r, _), it in candidates.items() if r == repo]\n",
        "    xs = sorted(xs, key=lambda x: issue_score(x, fw), reverse=True)\n",
        "    selected.extend([(repo, x) for x in xs[:FETCH_COMMENTS_TOP_PER_REPO]])\n",
        "    print(f\"[{now()}] {repo}: selected={min(len(xs), FETCH_COMMENTS_TOP_PER_REPO)} / candidates={len(xs)}\")\n",
        "\n",
        "print(f\"\\n[{now()}] Fetch comments + extract for {len(selected)} issues\")\n",
        "\n",
        "records = []\n",
        "seen_new = set()\n",
        "\n",
        "with ThreadPoolExecutor(max_workers=MAX_WORKERS) as ex:\n",
        "    futs = [ex.submit(fetch_comments, repo, issue) for repo, issue in selected]\n",
        "    for fut in tqdm(as_completed(futs), total=len(futs), desc=\"comments+extract\"):\n",
        "        repo, issue, comments = fut.result()\n",
        "        bodies = [(\"issue_body\", 0, \"\", issue.get(\"body\") or \"\")]\n",
        "        for i, c in enumerate(comments):\n",
        "            bodies.append((\"comment\", i, \"\", c.get(\"body\") or \"\"))\n",
        "\n",
        "        for source, idx, _, md in bodies:\n",
        "            for lang, raw in code_blocks(md):\n",
        "                rec = record_from_block(repo, issue, source, idx, lang, raw)\n",
        "                if not rec:\n",
        "                    continue\n",
        "                key = (rec[\"framework\"], rec[\"code_sha1\"])\n",
        "                if key in seen_new:\n",
        "                    continue\n",
        "                seen_new.add(key)\n",
        "                records.append(rec)\n",
        "\n",
        "records = sorted(records, key=lambda x: x[\"quality_score\"], reverse=True)\n",
        "\n",
        "# Combine với existing\n",
        "combined = existing_rows + records\n",
        "seen = set()\n",
        "combined_dedup = []\n",
        "for r in combined:\n",
        "    h = r.get(\"code_sha1\") or sha1(r.get(\"output\", \"\"))\n",
        "    key = (r.get(\"framework\"), h)\n",
        "    if key in seen:\n",
        "        continue\n",
        "    seen.add(key)\n",
        "    r[\"code_sha1\"] = h\n",
        "    combined_dedup.append(r)\n",
        "\n",
        "write_jsonl(OUT_DIR / \"new_2021_2023.jsonl\", records)\n",
        "write_jsonl(OUT_DIR / \"combined_2021_2026_raw.jsonl\", combined_dedup)\n",
        "\n",
        "pd.DataFrame([{\n",
        "    \"repo\": r,\n",
        "    \"number\": i.get(\"number\"),\n",
        "    \"title\": i.get(\"title\"),\n",
        "    \"url\": i.get(\"html_url\"),\n",
        "    \"created_at\": i.get(\"created_at\"),\n",
        "    \"updated_at\": i.get(\"updated_at\"),\n",
        "    \"labels\": \"|\".join(labels(i)),\n",
        "    \"score\": issue_score(i, FRAMEWORK_HINT[r])\n",
        "} for (r, _), i in candidates.items()]).to_csv(OUT_DIR / \"candidate_issues_2021_2023.csv\", index=False)\n",
        "\n",
        "manifest = {\n",
        "    \"created_at\": datetime.now(timezone.utc).isoformat(),\n",
        "    \"range\": \"2021-01-01..2023-12-31\",\n",
        "    \"repos\": REPOS,\n",
        "    \"existing_records_loaded\": len(existing_rows),\n",
        "    \"candidate_issues\": len(candidates),\n",
        "    \"new_records_2021_2023\": len(records),\n",
        "    \"combined_records_raw\": len(combined_dedup),\n",
        "    \"by_framework_new\": pd.Series([r[\"framework\"] for r in records]).value_counts().to_dict() if records else {},\n",
        "    \"by_framework_combined\": pd.Series([r[\"framework\"] for r in combined_dedup]).value_counts().to_dict() if combined_dedup else {},\n",
        "}\n",
        "(OUT_DIR / \"manifest_2021_2023.json\").write_text(json.dumps(manifest, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n",
        "\n",
        "zip_path = Path(\"/content/dl_issue_fuzz_dataset_2021_2023.zip\")\n",
        "with zipfile.ZipFile(zip_path, \"w\", zipfile.ZIP_DEFLATED) as z:\n",
        "    for p in OUT_DIR.glob(\"*\"):\n",
        "        z.write(p, arcname=p.name)\n",
        "\n",
        "print(\"\\nDONE 2021-2023\")\n",
        "print(json.dumps(manifest, ensure_ascii=False, indent=2))\n",
        "print(\"ZIP:\", zip_path)\n",
        "\n",
        "print(\"\\nTop 12 new records:\")\n",
        "for r in records[:12]:\n",
        "    print(\"-\" * 90)\n",
        "    print(r[\"repo\"], \"#\", r[\"issue_number\"], \"score=\", r[\"quality_score\"], r[\"issue_title\"][:120])\n",
        "    print(\"APIs:\", \", \".join(r[\"apis\"][:12]))\n",
        "    print(r[\"url\"])\n",
        "    print(r[\"output\"][:800].replace(\"\\n\", \"\\n  \"))\n",
        "\n",
        "try:\n",
        "    from google.colab import files\n",
        "    files.download(str(zip_path))\n",
        "except Exception:\n",
        "    pass"
      ],
