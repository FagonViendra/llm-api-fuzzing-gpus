      "cell_type": "code",
      "source": [
        "!pip -q install requests tqdm pandas\n",
        "\n",
        "import os, re, json, time, random, hashlib, zipfile, getpass, ast\n",
        "from pathlib import Path\n",
        "from datetime import datetime, timezone\n",
        "from concurrent.futures import ThreadPoolExecutor, as_completed\n",
        "\n",
        "import requests\n",
        "import pandas as pd\n",
        "from tqdm.auto import tqdm\n",
        "\n",
        "REPOS = [\"pytorch/pytorch\", \"tensorflow/tensorflow\"]\n",
        "SINCE = \"2024-01-01T00:00:00Z\"       # đổi 2021 nếu muốn sâu\n",
        "MAX_PAGES_PER_REPO = 80              # 80*100 = tối đa 8000 issue/repo\n",
        "FETCH_COMMENTS_TOP_PER_REPO = 900\n",
        "MAX_COMMENT_PAGES = 2\n",
        "MAX_WORKERS = 3\n",
        "OUT_DIR = Path(\"/content/dl_issue_fuzz_dataset_fast\")\n",
        "OUT_DIR.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "TOKEN = os.environ.get(\"GITHUB_TOKEN\", \"\").strip()\n",
        "try:\n",
        "    from google.colab import userdata\n",
        "    TOKEN = TOKEN or (userdata.get(\"GITHUB_TOKEN\") or \"\").strip()\n",
        "except Exception:\n",
        "    pass\n",
        "\n",
        "if not TOKEN:\n",
        "    TOKEN = getpass.getpass(\"GITHUB_TOKEN: \").strip()\n",
        "\n",
        "HEADERS = {\n",
        "    \"Accept\": \"application/vnd.github+json\",\n",
        "    \"X-GitHub-Api-Version\": \"2022-11-28\",\n",
        "    \"User-Agent\": \"dl-issue-fast-crawler\",\n",
        "}\n",
        "if TOKEN:\n",
        "    HEADERS[\"Authorization\"] = f\"Bearer {TOKEN}\"\n",
        "\n",
        "S = requests.Session()\n",
        "API = \"https://api.github.com\"\n",
        "\n",
        "BUG_TERMS = [\n",
        "    \"bug\", \"regression\", \"crash\", \"segfault\", \"segmentation fault\",\n",
        "    \"runtimeerror\", \"assertionerror\", \"valueerror\", \"internalerror\",\n",
        "    \"wrong result\", \"incorrect\", \"mismatch\", \"inconsistency\",\n",
        "    \"cuda\", \"cudnn\", \"gpu\", \"xla\", \"autograd\", \"gradient\", \"backward\",\n",
        "    \"dtype\", \"shape\", \"nan\", \"inf\", \"minimal repro\", \"minimal reproduction\",\n",
        "    \"reproduce\", \"reproduction\", \"torch.compile\", \"dynamo\", \"inductor\",\n",
        "    \"tf.function\", \"keras\",\n",
        "]\n",
        "\n",
        "API_REGEX = {\n",
        "    \"pytorch\": [\n",
        "        r\"\\btorch(?:\\.[A-Za-z_]\\w*){1,7}\\b\",\n",
        "        r\"\\btorchvision(?:\\.[A-Za-z_]\\w*){1,7}\\b\",\n",
        "        r\"\\bfunctorch(?:\\.[A-Za-z_]\\w*){0,7}\\b\",\n",
        "    ],\n",
        "    \"tensorflow\": [\n",
        "        r\"\\btf(?:\\.[A-Za-z_]\\w*){1,7}\\b\",\n",
        "        r\"\\btensorflow(?:\\.[A-Za-z_]\\w*){1,7}\\b\",\n",
        "        r\"\\bkeras(?:\\.[A-Za-z_]\\w*){1,7}\\b\",\n",
        "    ],\n",
        "}\n",
        "\n",
        "FW = {\"pytorch/pytorch\": \"pytorch\", \"tensorflow/tensorflow\": \"tensorflow\"}\n",
        "\n",
        "def now():\n",
        "    return datetime.now().strftime(\"%H:%M:%S\")\n",
        "\n",
        "def sha1(x):\n",
        "    return hashlib.sha1(x.encode(\"utf-8\", errors=\"ignore\")).hexdigest()\n",
        "\n",
        "def gh_get(path, params=None, retries=7):\n",
        "    url = path if path.startswith(\"http\") else API + path\n",
        "    for k in range(retries):\n",
        "        r = S.get(url, headers=HEADERS, params=params or {}, timeout=45)\n",
        "        if r.status_code == 200:\n",
        "            return r.json(), r.headers\n",
        "\n",
        "        print(f\"[{now()}] HTTP {r.status_code} | resource={r.headers.get('x-ratelimit-resource')} | remain={r.headers.get('x-ratelimit-remaining')} | body={r.text[:180]}\")\n",
        "\n",
        "        if r.status_code in (403, 429):\n",
        "            retry_after = r.headers.get(\"retry-after\")\n",
        "            if retry_after:\n",
        "                wait = int(retry_after) + 5\n",
        "            else:\n",
        "                reset = r.headers.get(\"x-ratelimit-reset\")\n",
        "                remain = r.headers.get(\"x-ratelimit-remaining\")\n",
        "                if remain == \"0\" and reset:\n",
        "                    wait = max(20, int(reset) - int(time.time()) + 5)\n",
        "                else:\n",
        "                    wait = 45 + 15 * k + random.randint(0, 15)\n",
        "            print(f\"[{now()}] bị throttle thật, ngủ {wait}s\")\n",
        "            time.sleep(wait)\n",
        "            continue\n",
        "\n",
        "        if r.status_code in (500, 502, 503, 504):\n",
        "            time.sleep(10 + 5 * k)\n",
        "            continue\n",
        "\n",
        "        raise RuntimeError(f\"GitHub lỗi {r.status_code}: {r.text[:500]}\")\n",
        "    raise RuntimeError(\"Hết retry\")\n",
        "\n",
        "def labels(issue):\n",
        "    return [x.get(\"name\", \"\") for x in issue.get(\"labels\", []) if isinstance(x, dict)]\n",
        "\n",
        "def code_blocks(md):\n",
        "    md = md or \"\"\n",
        "    out = []\n",
        "    for m in re.finditer(r\"```[ \\t]*([A-Za-z0-9_+\\-\\.]*)?[ \\t]*\\n(.*?)```\", md, re.S):\n",
        "        out.append(((m.group(1) or \"\").lower(), m.group(2) or \"\"))\n",
        "    return out\n",
        "\n",
        "def apis(text, fw):\n",
        "    found = set()\n",
        "    for pat in API_REGEX[fw]:\n",
        "        for m in re.finditer(pat, text or \"\"):\n",
        "            x = m.group(0)\n",
        "            if len(x) < 150:\n",
        "                found.add(x.replace(\"tensorflow.\", \"tf.\"))\n",
        "    return sorted(found)\n",
        "\n",
        "def clean_code(c):\n",
        "    c = (c or \"\").replace(\"\\r\\n\", \"\\n\").replace(\"\\r\", \"\\n\")\n",
        "    lines = []\n",
        "    for line in c.splitlines():\n",
        "        line = re.sub(r\"^\\s*(>>>|\\.\\.\\.)\\s?\", \"\", line)\n",
        "        lines.append(line.rstrip())\n",
        "    c = \"\\n\".join(lines).strip()\n",
        "    return c[:10000]\n",
        "\n",
        "def ast_ok(c):\n",
        "    try:\n",
        "        ast.parse(c)\n",
        "        return True\n",
        "    except Exception:\n",
        "        return False\n",
        "\n",
        "def issue_score(issue, fw):\n",
        "    title = issue.get(\"title\") or \"\"\n",
        "    body = issue.get(\"body\") or \"\"\n",
        "    labs = \" \".join(labels(issue)).lower()\n",
        "    txt = (title + \"\\n\" + body + \"\\n\" + labs).lower()\n",
        "    score = 0\n",
        "    score += min(8, sum(1 for t in BUG_TERMS if t in txt))\n",
        "    if any(x in labs for x in [\"bug\", \"triaged\", \"regression\", \"module:\", \"comp:\", \"type: bug\", \"type:bug\"]):\n",
        "        score += 6\n",
        "    if code_blocks(body):\n",
        "        score += 6\n",
        "    if fw == \"pytorch\" and (\"torch.\" in body or \"import torch\" in body):\n",
        "        score += 5\n",
        "    if fw == \"tensorflow\" and (\"tf.\" in body or \"tensorflow\" in body or \"keras\" in body):\n",
        "        score += 5\n",
        "    score += min(4, int(issue.get(\"comments\") or 0) // 5)\n",
        "    return score\n",
        "\n",
        "def record_from_block(repo, issue, source, idx, lang, raw):\n",
        "    fw = FW[repo]\n",
        "    c = clean_code(raw)\n",
        "    if len(c) < 40:\n",
        "        return None\n",
        "    aa = apis(c, fw)\n",
        "    if not aa:\n",
        "        return None\n",
        "    if fw == \"pytorch\" and not re.search(r\"\\b(torch\\.|import torch|from torch|torchvision\\.|functorch\\.)\", c):\n",
        "        return None\n",
        "    if fw == \"tensorflow\" and not re.search(r\"\\b(tf\\.|tensorflow\\.|keras\\.|import tensorflow|from tensorflow|import keras)\", c):\n",
        "        return None\n",
        "\n",
        "    ctx = ((issue.get(\"title\") or \"\") + \"\\n\" + (issue.get(\"body\") or \"\")).lower()\n",
        "    sc = 6 + len(aa[:8])\n",
        "    sc += min(8, sum(1 for t in BUG_TERMS if t in (ctx + \"\\n\" + c.lower())))\n",
        "    sc += 4 if ast_ok(c) else -1\n",
        "    sc += 4 if code_blocks(issue.get(\"body\") or \"\") else 0\n",
        "\n",
        "    if sc < 8:\n",
        "        return None\n",
        "\n",
        "    return {\n",
        "        \"id\": f\"{repo}#{issue.get('number')}:{source}:{idx}:{sha1(c)[:12]}\",\n",
        "        \"framework\": fw,\n",
        "        \"repo\": repo,\n",
        "        \"issue_number\": issue.get(\"number\"),\n",
        "        \"issue_title\": issue.get(\"title\"),\n",
        "        \"url\": issue.get(\"html_url\"),\n",
        "        \"created_at\": issue.get(\"created_at\"),\n",
        "        \"updated_at\": issue.get(\"updated_at\"),\n",
        "        \"labels\": labels(issue),\n",
        "        \"apis\": aa,\n",
        "        \"quality_score\": sc,\n",
        "        \"source\": source,\n",
        "        \"markdown_lang\": lang,\n",
        "        \"code_sha1\": sha1(c),\n",
        "        \"instruction\": \"Generate or mutate a minimal Python fuzzing/reproducer seed for PyTorch/TensorFlow bug discovery.\",\n",
        "        \"input\": f\"Framework: {fw}\\nIssue: {issue.get('title')}\\nAPIs: {', '.join(aa[:20])}\\nURL: {issue.get('html_url')}\",\n",
        "        \"output\": c,\n",
        "    }\n",
        "\n",
        "print(f\"[{now()}] Check rate_limit\")\n",
        "rate, _ = gh_get(\"/rate_limit\")\n",
        "print(json.dumps(rate.get(\"resources\", {}), indent=2)[:1500])\n",
        "\n",
        "all_issues = []\n",
        "for repo in REPOS:\n",
        "    fw = FW[repo]\n",
        "    print(f\"\\n[{now()}] List issues repo={repo} since={SINCE}\")\n",
        "    repo_items = []\n",
        "    for page in tqdm(range(1, MAX_PAGES_PER_REPO + 1), desc=f\"list {repo}\"):\n",
        "        data, hdr = gh_get(\n",
        "            f\"/repos/{repo}/issues\",\n",
        "            {\n",
        "                \"state\": \"all\",\n",
        "                \"since\": SINCE,\n",
        "                \"sort\": \"updated\",\n",
        "                \"direction\": \"desc\",\n",
        "                \"per_page\": 100,\n",
        "                \"page\": page,\n",
        "            }\n",
        "        )\n",
        "        if not data:\n",
        "            break\n",
        "        # endpoint này trả cả PR dạng issue, bỏ PR\n",
        "        data = [x for x in data if \"pull_request\" not in x]\n",
        "        repo_items.extend(data)\n",
        "        if len(data) < 100:\n",
        "            break\n",
        "        time.sleep(0.25)\n",
        "\n",
        "    repo_items = sorted(repo_items, key=lambda x: issue_score(x, fw), reverse=True)\n",
        "    print(f\"[{now()}] {repo}: got {len(repo_items)} issues, top_score={issue_score(repo_items[0], fw) if repo_items else 0}\")\n",
        "    all_issues += [(repo, x) for x in repo_items]\n",
        "\n",
        "selected = []\n",
        "for repo in REPOS:\n",
        "    xs = [(r, x) for r, x in all_issues if r == repo]\n",
        "    xs = sorted(xs, key=lambda rx: issue_score(rx[1], FW[rx[0]]), reverse=True)\n",
        "    selected += xs[:FETCH_COMMENTS_TOP_PER_REPO]\n",
        "\n",
        "print(f\"\\n[{now()}] Fetch comments for top {len(selected)} issues\")\n",
        "\n",
        "def fetch_comments(repo, issue):\n",
        "    num = issue[\"number\"]\n",
        "    comments = []\n",
        "    for page in range(1, MAX_COMMENT_PAGES + 1):\n",
        "        data, _ = gh_get(f\"/repos/{repo}/issues/{num}/comments\", {\"per_page\": 100, \"page\": page})\n",
        "        if not data:\n",
        "            break\n",
        "        comments.extend(data)\n",
        "        if len(data) < 100:\n",
        "            break\n",
        "        time.sleep(0.2)\n",
        "    return repo, issue, comments\n",
        "\n",
        "records = []\n",
        "seen = set()\n",
        "\n",
        "with ThreadPoolExecutor(max_workers=MAX_WORKERS) as ex:\n",
        "    futs = [ex.submit(fetch_comments, repo, issue) for repo, issue in selected]\n",
        "    for fut in tqdm(as_completed(futs), total=len(futs), desc=\"comments+extract\"):\n",
        "        repo, issue, comments = fut.result()\n",
        "\n",
        "        bodies = [(\"issue_body\", 0, \"\", issue.get(\"body\") or \"\")]\n",
        "        for i, c in enumerate(comments):\n",
        "            bodies.append((\"comment\", i, \"\", c.get(\"body\") or \"\"))\n",
        "\n",
        "        for source, idx, _, md in bodies:\n",
        "            for lang, raw in code_blocks(md):\n",
        "                rec = record_from_block(repo, issue, source, idx, lang, raw)\n",
        "                if not rec:\n",
        "                    continue\n",
        "                key = (rec[\"framework\"], rec[\"code_sha1\"])\n",
        "                if key in seen:\n",
        "                    continue\n",
        "                seen.add(key)\n",
        "                records.append(rec)\n",
        "\n",
        "records = sorted(records, key=lambda x: x[\"quality_score\"], reverse=True)\n",
        "\n",
        "def write_jsonl(path, rows):\n",
        "    with open(path, \"w\", encoding=\"utf-8\") as f:\n",
        "        for r in rows:\n",
        "            f.write(json.dumps(r, ensure_ascii=False) + \"\\n\")\n",
        "\n",
        "random.seed(1337)\n",
        "shuf = records[:]\n",
        "random.shuffle(shuf)\n",
        "n = len(shuf)\n",
        "n_val = max(1, int(n * 0.05)) if n else 0\n",
        "n_test = max(1, int(n * 0.05)) if n else 0\n",
        "val = shuf[:n_val]\n",
        "test = shuf[n_val:n_val+n_test]\n",
        "train = shuf[n_val+n_test:]\n",
        "\n",
        "write_jsonl(OUT_DIR / \"all.jsonl\", records)\n",
        "write_jsonl(OUT_DIR / \"train.jsonl\", train)\n",
        "write_jsonl(OUT_DIR / \"val.jsonl\", val)\n",
        "write_jsonl(OUT_DIR / \"test.jsonl\", test)\n",
        "\n",
        "pd.DataFrame([{\n",
        "    \"repo\": r, \"number\": i[\"number\"], \"title\": i.get(\"title\"), \"url\": i.get(\"html_url\"),\n",
        "    \"created_at\": i.get(\"created_at\"), \"updated_at\": i.get(\"updated_at\"),\n",
        "    \"labels\": \"|\".join(labels(i)), \"score\": issue_score(i, FW[r])\n",
        "} for r, i in all_issues]).to_csv(OUT_DIR / \"issues_scored.csv\", index=False)\n",
        "\n",
        "manifest = {\n",
        "    \"created_at\": datetime.now(timezone.utc).isoformat(),\n",
        "    \"since\": SINCE,\n",
        "    \"repos\": REPOS,\n",
        "    \"issues_seen\": len(all_issues),\n",
        "    \"issues_comment_fetched\": len(selected),\n",
        "    \"records_total\": len(records),\n",
        "    \"train\": len(train),\n",
        "    \"val\": len(val),\n",
        "    \"test\": len(test),\n",
        "}\n",
        "(OUT_DIR / \"manifest.json\").write_text(json.dumps(manifest, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n",
        "\n",
        "zip_path = Path(\"/content/dl_issue_fuzz_dataset_fast.zip\")\n",
        "with zipfile.ZipFile(zip_path, \"w\", zipfile.ZIP_DEFLATED) as z:\n",
        "    for p in OUT_DIR.glob(\"*\"):\n",
        "        z.write(p, arcname=p.name)\n",
        "\n",
        "print(\"\\nDONE\")\n",
        "print(json.dumps(manifest, ensure_ascii=False, indent=2))\n",
        "print(\"ZIP:\", zip_path)\n",
        "\n",
        "for r in records[:10]:\n",
        "    print(\"-\" * 90)\n",
        "    print(r[\"repo\"], \"#\", r[\"issue_number\"], \"score=\", r[\"quality_score\"], r[\"issue_title\"][:120])\n",
        "    print(\"APIs:\", \", \".join(r[\"apis\"][:12]))\n",
        "    print(r[\"url\"])\n",
        "    print(r[\"output\"][:700].replace(\"\\n\", \"\\n  \"))\n",
        "\n",
        "try:\n",
        "    from google.colab import files\n",
        "    files.download(str(zip_path))\n",
        "except Exception:\n",
        "    pass"
      ],
