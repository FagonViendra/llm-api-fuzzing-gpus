  "cells": [
    {
      "cell_type": "code",
      "source": [
        "\"\"\"\n",
        "One-cell Colab crawler for the missing 2024-2026 dataset.\n",
        "\n",
        "Goal:\n",
        "  Crawl PyTorch/TensorFlow GitHub issues from 2024-01-01 to today, extract\n",
        "  Python fuzzing/reproducer seeds, and export a standalone train/val/test zip.\n",
        "\n",
        "How to use in Colab:\n",
        "  1. Set GITHUB_TOKEN in Colab Secrets/env, or paste it when prompted.\n",
        "  2. Paste this whole file into one Colab cell and run.\n",
        "  3. Download the final zip when the cell finishes.\n",
        "\n",
        "Main output:\n",
        "  /content/dl_issue_fuzz_dataset_2024_2026_rescued.zip\n",
        "\"\"\"\n",
        "\n",
        "import ast\n",
        "import getpass\n",
        "import hashlib\n",
        "import json\n",
        "import math\n",
        "import os\n",
        "import random\n",
        "import re\n",
        "import subprocess\n",
        "import sys\n",
        "import threading\n",
        "import time\n",
        "import zipfile\n",
        "from collections import Counter\n",
        "from concurrent.futures import ThreadPoolExecutor, as_completed\n",
        "from datetime import date, datetime, timedelta, timezone\n",
        "from pathlib import Path\n",
        "\n",
        "\n",
        "def ensure_package(import_name, pip_name=None):\n",
        "    try:\n",
        "        __import__(import_name)\n",
        "    except ImportError:\n",
        "        subprocess.check_call([sys.executable, \"-m\", \"pip\", \"install\", \"-q\", pip_name or import_name])\n",
        "\n",
        "\n",
        "ensure_package(\"requests\")\n",
        "ensure_package(\"tqdm\")\n",
        "\n",
        "import requests\n",
        "from tqdm.auto import tqdm\n",
        "\n",
        "\n",
        "# =========================\n",
        "# Config\n",
        "# =========================\n",
        "\n",
        "REPOS = [\"pytorch/pytorch\", \"tensorflow/tensorflow\"]\n",
        "START_DATE = \"2024-01-01\"\n",
        "END_DATE = datetime.now(timezone.utc).date().isoformat()\n",
        "SINCE = START_DATE + \"T00:00:00Z\"\n",
        "\n",
        "OUT_DIR = Path(\"/content/dl_issue_fuzz_dataset_2024_2026_rescued\")\n",
        "CHECKPOINT_DIR = OUT_DIR / \"checkpoints\"\n",
        "OUT_DIR.mkdir(parents=True, exist_ok=True)\n",
        "CHECKPOINT_DIR.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "# Stage A catches high-signal issues updated during 2024-2026, including old\n",
        "# issues revived with fresh repro/comments. Stage B catches issues created in\n",
        "# the target period via keyword search.\n",
        "CRAWL_UPDATED_SINCE = True\n",
        "CRAWL_CREATED_SEARCH = True\n",
        "\n",
        "# The updated endpoint is PR-heavy. Break by raw API page size, not by issues-only.\n",
        "MAX_UPDATED_PAGES_PER_REPO = 180\n",
        "\n",
        "# Good quality/speed balance. Increase to 2500 only if you have time and quota.\n",
        "FETCH_COMMENTS_TOP_PER_REPO = 1750\n",
        "MAX_COMMENT_PAGES = 2\n",
        "MAX_WORKERS = 5\n",
        "\n",
        "# GitHub search limit is 30 requests/minute authenticated, 10 unauthenticated.\n",
        "SEARCH_INTERVAL_AUTH = 2.15\n",
        "SEARCH_INTERVAL_NO_TOKEN = 6.5\n",
        "\n",
        "# Core is 5000/hour authenticated. Pace globally to avoid secondary limits.\n",
        "CORE_INTERVAL_AUTH = 0.22\n",
        "CORE_INTERVAL_NO_TOKEN = 1.25\n",
        "\n",
        "STRICT_PYTHON_AST = True\n",
        "MIN_CODE_CHARS = 45\n",
        "MAX_CODE_CHARS = 12000\n",
        "\n",
        "\n",
        "TERMS_BY_REPO = {\n",
        "    \"pytorch/pytorch\": [\n",
        "        'label:\"module: correctness\"',\n",
        "        'label:\"module: autograd\"',\n",
        "        'label:\"module: cuda\"',\n",
        "        'label:\"module: dynamo\"',\n",
        "        'label:\"module: inductor\"',\n",
        "        'label:\"module: pt2\"',\n",
        "        '\"torch.compile\"',\n",
        "        \"segfault\",\n",
        "        \"crash\",\n",
        "        '\"wrong result\"',\n",
        "        \"incorrect\",\n",
        "        \"mismatch\",\n",
        "        \"autograd\",\n",
        "        \"gradient\",\n",
        "        \"cuda\",\n",
        "        \"dtype\",\n",
        "        \"shape\",\n",
        "        \"nan\",\n",
        "        \"inf\",\n",
        "        '\"minimal repro\"',\n",
        "        \"torch.\",\n",
        "    ],\n",
        "    \"tensorflow/tensorflow\": [\n",
        "        'label:\"type:bug\"',\n",
        "        'label:\"comp:gpu\"',\n",
        "        'label:\"comp:xla\"',\n",
        "        'label:\"comp:keras\"',\n",
        "        'label:\"comp:graph\"',\n",
        "        'label:\"comp:tflite\"',\n",
        "        \"segfault\",\n",
        "        \"crash\",\n",
        "        '\"wrong result\"',\n",
        "        \"incorrect\",\n",
        "        \"mismatch\",\n",
        "        \"xla\",\n",
        "        \"jit_compile\",\n",
        "        \"tf.function\",\n",
        "        \"gradient\",\n",
        "        \"keras\",\n",
        "        \"dtype\",\n",
        "        \"shape\",\n",
        "        \"nan\",\n",
        "        \"inf\",\n",
        "        '\"minimal repro\"',\n",
        "        \"tf.\",\n",
        "    ],\n",
        "}\n",
        "\n",
        "FRAMEWORK_HINT = {\n",
        "    \"pytorch/pytorch\": \"pytorch\",\n",
        "    \"tensorflow/tensorflow\": \"tensorflow\",\n",
        "}\n",
        "\n",
        "API_REGEX = {\n",
        "    \"pytorch\": [\n",
        "        r\"\\btorch(?:\\.[A-Za-z_]\\w*){1,8}\\b\",\n",
        "        r\"\\btorchvision(?:\\.[A-Za-z_]\\w*){1,8}\\b\",\n",
        "        r\"\\bfunctorch(?:\\.[A-Za-z_]\\w*){0,8}\\b\",\n",
        "    ],\n",
        "    \"tensorflow\": [\n",
        "        r\"\\btf(?:\\.[A-Za-z_]\\w*){1,8}\\b\",\n",
        "        r\"\\btensorflow(?:\\.[A-Za-z_]\\w*){1,8}\\b\",\n",
        "        r\"\\bkeras(?:\\.[A-Za-z_]\\w*){1,8}\\b\",\n",
        "    ],\n",
        "}\n",
        "\n",
        "BUG_TERMS = [\n",
        "    \"bug\",\n",
        "    \"regression\",\n",
        "    \"crash\",\n",
        "    \"segfault\",\n",
        "    \"segmentation fault\",\n",
        "    \"runtimeerror\",\n",
        "    \"assertionerror\",\n",
        "    \"valueerror\",\n",
        "    \"internalerror\",\n",
        "    \"wrong result\",\n",
        "    \"incorrect\",\n",
        "    \"mismatch\",\n",
        "    \"inconsistency\",\n",
        "    \"cuda\",\n",
        "    \"cudnn\",\n",
        "    \"gpu\",\n",
        "    \"xla\",\n",
        "    \"autograd\",\n",
        "    \"gradient\",\n",
        "    \"backward\",\n",
        "    \"dtype\",\n",
        "    \"shape\",\n",
        "    \"nan\",\n",
        "    \"inf\",\n",
        "    \"minimal repro\",\n",
        "    \"minimal reproduction\",\n",
        "    \"reproduce\",\n",
        "    \"reproduction\",\n",
        "    \"torch.compile\",\n",
        "    \"dynamo\",\n",
        "    \"inductor\",\n",
        "    \"tf.function\",\n",
        "    \"keras\",\n",
        "    \"jit_compile\",\n",
        "]\n",
        "\n",
        "LOG_OR_ENV_PATTERNS = [\n",
        "    \"Collecting environment information\",\n",
        "    \"PyTorch version:\",\n",
        "    \"CUDA used to build PyTorch\",\n",
        "    \"Versions of relevant libraries\",\n",
        "    \"Traceback (most recent call last)\",\n",
        "    \"Eager output:\",\n",
        "    \"XLA output:\",\n",
        "    \"AutoCluster output:\",\n",
        "]\n",
        "\n",
        "\n",
        "# =========================\n",
        "# Helpers\n",
        "# =========================\n",
        "\n",
        "def now():\n",
        "    return datetime.now().strftime(\"%H:%M:%S\")\n",
        "\n",
        "\n",
        "def sha1_text(text):\n",
        "    return hashlib.sha1((text or \"\").encode(\"utf-8\", errors=\"ignore\")).hexdigest()\n",
        "\n",
        "\n",
        "def read_jsonl(path):\n",
        "    rows = []\n",
        "    path = Path(path)\n",
        "    if not path.exists():\n",
        "        return rows\n",
        "    with path.open(\"r\", encoding=\"utf-8\", errors=\"ignore\") as f:\n",
        "        for line in f:\n",
        "            line = line.strip()\n",
        "            if line:\n",
        "                rows.append(json.loads(line))\n",
        "    return rows\n",
        "\n",
        "\n",
        "def write_jsonl(path, rows):\n",
        "    path = Path(path)\n",
        "    path.parent.mkdir(parents=True, exist_ok=True)\n",
        "    with path.open(\"w\", encoding=\"utf-8\") as f:\n",
        "        for row in rows:\n",
        "            f.write(json.dumps(row, ensure_ascii=False) + \"\\n\")\n",
        "\n",
        "\n",
        "def append_jsonl(path, row):\n",
        "    path = Path(path)\n",
        "    path.parent.mkdir(parents=True, exist_ok=True)\n",
        "    with path.open(\"a\", encoding=\"utf-8\") as f:\n",
        "        f.write(json.dumps(row, ensure_ascii=False) + \"\\n\")\n",
        "\n",
        "\n",
        "def labels(issue):\n",
        "    out = []\n",
        "    for x in issue.get(\"labels\") or []:\n",
        "        if isinstance(x, dict):\n",
        "            out.append(x.get(\"name\", \"\"))\n",
        "        elif isinstance(x, str):\n",
        "            out.append(x)\n",
        "    return [x for x in out if x]\n",
        "\n",
        "\n",
        "def issue_url(issue):\n",
        "    return issue.get(\"html_url\") or issue.get(\"url\") or \"\"\n",
        "\n",
        "\n",
        "def normalize_issue(repo, issue, source=None):\n",
        "    sources = issue.get(\"candidate_sources\") or []\n",
        "    if source and source not in sources:\n",
        "        sources.append(source)\n",
        "    return {\n",
        "        \"repo\": repo,\n",
        "        \"number\": issue.get(\"number\"),\n",
        "        \"title\": issue.get(\"title\") or \"\",\n",
        "        \"url\": issue_url(issue),\n",
        "        \"state\": issue.get(\"state\"),\n",
        "        \"created_at\": issue.get(\"created_at\"),\n",
        "        \"updated_at\": issue.get(\"updated_at\"),\n",
        "        \"comments\": int(issue.get(\"comments\") or 0),\n",
        "        \"labels\": labels(issue),\n",
        "        \"body\": issue.get(\"body\") or \"\",\n",
        "        \"candidate_sources\": sources,\n",
        "    }\n",
        "\n",
        "\n",
        "def merge_issue(old, new, fw):\n",
        "    sources = sorted(set((old.get(\"candidate_sources\") or []) + (new.get(\"candidate_sources\") or [])))\n",
        "    if issue_score(new, fw) > issue_score(old, fw) or (not old.get(\"body\") and new.get(\"body\")):\n",
        "        out = dict(new)\n",
        "    else:\n",
        "        out = dict(old)\n",
        "        if not out.get(\"body\") and new.get(\"body\"):\n",
        "            out[\"body\"] = new.get(\"body\")\n",
        "    out[\"candidate_sources\"] = sources\n",
        "    return out\n",
        "\n",
        "\n",
        "def code_blocks(markdown):\n",
        "    out = []\n",
        "    for m in re.finditer(r\"```[ \\t]*([A-Za-z0-9_+\\-\\.]*)?[ \\t]*\\n(.*?)```\", markdown or \"\", re.S):\n",
        "        out.append(((m.group(1) or \"\").strip().lower(), m.group(2) or \"\"))\n",
        "    return out\n",
        "\n",
        "\n",
        "def apis_in_text(text, fw):\n",
        "    found = set()\n",
        "    for pat in API_REGEX[fw]:\n",
        "        for m in re.finditer(pat, text or \"\"):\n",
        "            x = m.group(0)\n",
        "            if len(x) < 180:\n",
        "                found.add(x.replace(\"tensorflow.\", \"tf.\"))\n",
        "    return sorted(found)\n",
        "\n",
        "\n",
        "def clean_code(raw):\n",
        "    code = (raw or \"\").replace(\"\\r\\n\", \"\\n\").replace(\"\\r\", \"\\n\")\n",
        "    lines = []\n",
        "    for line in code.splitlines():\n",
        "        line = re.sub(r\"^\\s*(>>>|\\.\\.\\.)\\s?\", \"\", line)\n",
        "        lines.append(line.rstrip())\n",
        "    return \"\\n\".join(lines).strip()[:MAX_CODE_CHARS]\n",
        "\n",
        "\n",
        "def ast_parse_ok(code):\n",
        "    try:\n",
        "        ast.parse(code)\n",
        "        return True\n",
        "    except Exception:\n",
        "        return False\n",
        "\n",
        "\n",
        "def looks_like_log_or_env(code):\n",
        "    text = code or \"\"\n",
        "    if any(p in text for p in LOG_OR_ENV_PATTERNS):\n",
        "        return True\n",
        "    return bool(re.match(r\"^(RuntimeError|ValueError|TypeError|AssertionError|InternalError):\", text.strip()))\n",
        "\n",
        "\n",
        "def issue_score(issue, fw):\n",
        "    title = issue.get(\"title\") or \"\"\n",
        "    body = issue.get(\"body\") or \"\"\n",
        "    labs = \" \".join(labels(issue)).lower()\n",
        "    text = (title + \"\\n\" + body + \"\\n\" + labs).lower()\n",
        "    score = 0\n",
        "    score += min(9, sum(1 for t in BUG_TERMS if t in text))\n",
        "    if any(x in labs for x in [\"bug\", \"type:bug\", \"type: bug\", \"regression\", \"module:\", \"comp:\", \"triaged\"]):\n",
        "        score += 6\n",
        "    if code_blocks(body):\n",
        "        score += 6\n",
        "    if fw == \"pytorch\" and (\"torch.\" in body or \"import torch\" in body or \"from torch\" in body):\n",
        "        score += 5\n",
        "    if fw == \"tensorflow\" and (\"tf.\" in body or \"tensorflow\" in body or \"keras\" in body):\n",
        "        score += 5\n",
        "    score += min(4, int(issue.get(\"comments\") or 0) // 5)\n",
        "    return score\n",
        "\n",
        "\n",
        "def record_from_block(repo, issue, source, idx, lang, raw):\n",
        "    fw = FRAMEWORK_HINT[repo]\n",
        "    code = clean_code(raw)\n",
        "    if len(code) < MIN_CODE_CHARS:\n",
        "        return None\n",
        "\n",
        "    api_list = apis_in_text(code, fw)\n",
        "    if not api_list:\n",
        "        return None\n",
        "\n",
        "    if fw == \"pytorch\" and not re.search(r\"\\b(torch\\.|import torch|from torch|torchvision\\.|functorch\\.)\", code):\n",
        "        return None\n",
        "    if fw == \"tensorflow\" and not re.search(\n",
        "        r\"\\b(tf\\.|tensorflow\\.|keras\\.|import tensorflow|from tensorflow|import keras)\",\n",
        "        code,\n",
        "    ):\n",
        "        return None\n",
        "\n",
        "    parsed = ast_parse_ok(code)\n",
        "    if STRICT_PYTHON_AST and not parsed:\n",
        "        return None\n",
        "    if looks_like_log_or_env(code):\n",
        "        return None\n",
        "\n",
        "    ctx = ((issue.get(\"title\") or \"\") + \"\\n\" + (issue.get(\"body\") or \"\")).lower()\n",
        "    score = 6 + min(10, len(api_list))\n",
        "    score += min(9, sum(1 for t in BUG_TERMS if t in (ctx + \"\\n\" + code.lower())))\n",
        "    score += 4 if parsed else -1\n",
        "    score += 4 if code_blocks(issue.get(\"body\") or \"\") else 0\n",
        "    score += min(3, int(issue.get(\"comments\") or 0) // 10)\n",
        "    if score < 10:\n",
        "        return None\n",
        "\n",
        "    h = sha1_text(code)\n",
        "    return {\n",
        "        \"id\": f\"{repo}#{issue.get('number')}:{source}:{idx}:{h[:12]}\",\n",
        "        \"framework\": fw,\n",
        "        \"repo\": repo,\n",
        "        \"issue_number\": issue.get(\"number\"),\n",
        "        \"issue_title\": issue.get(\"title\"),\n",
        "        \"url\": issue_url(issue),\n",
        "        \"created_at\": issue.get(\"created_at\"),\n",
        "        \"updated_at\": issue.get(\"updated_at\"),\n",
        "        \"labels\": labels(issue),\n",
        "        \"apis\": api_list,\n",
        "        \"quality_score\": score,\n",
        "        \"source\": source,\n",
        "        \"markdown_lang\": lang,\n",
        "        \"code_sha1\": h,\n",
        "        \"ast_parse_ok\": parsed,\n",
        "        \"instruction\": \"Generate or mutate a minimal Python fuzzing/reproducer seed for PyTorch/TensorFlow bug discovery.\",\n",
        "        \"input\": (\n",
        "            f\"Framework: {fw}\\n\"\n",
        "            f\"Issue: {issue.get('title')}\\n\"\n",
        "            f\"APIs: {', '.join(api_list[:20])}\\n\"\n",
        "            f\"URL: {issue_url(issue)}\"\n",
        "        ),\n",
        "        \"output\": code,\n",
        "    }\n",
        "\n",
        "\n",
        "def month_ranges(start_s, end_s):\n",
        "    s = datetime.strptime(start_s, \"%Y-%m-%d\").date()\n",
        "    e = datetime.strptime(end_s, \"%Y-%m-%d\").date()\n",
        "    out = []\n",
        "    cur = date(s.year, s.month, 1)\n",
        "    while cur <= e:\n",
        "        nxt = date(cur.year + 1, 1, 1) if cur.month == 12 else date(cur.year, cur.month + 1, 1)\n",
        "        out.append((cur.isoformat(), min(e, nxt - timedelta(days=1)).isoformat()))\n",
        "        cur = nxt\n",
        "    return out\n",
        "\n",
        "\n",
        "def split_date_range(start_s, end_s):\n",
        "    s = datetime.strptime(start_s, \"%Y-%m-%d\").date()\n",
        "    e = datetime.strptime(end_s, \"%Y-%m-%d\").date()\n",
        "    if s >= e:\n",
        "        return None\n",
        "    mid = s + (e - s) // 2\n",
        "    return (s.isoformat(), mid.isoformat()), ((mid + timedelta(days=1)).isoformat(), e.isoformat())\n",
        "\n",
        "\n",
        "def save_candidate_checkpoint(candidates, path):\n",
        "    rows = sorted(candidates.values(), key=lambda x: (x.get(\"repo\") or \"\", int(x.get(\"number\") or 0)))\n",
        "    write_jsonl(path, rows)\n",
        "\n",
        "\n",
        "def write_candidate_csv(path, rows):\n",
        "    import csv\n",
        "\n",
        "    fields = [\"repo\", \"number\", \"title\", \"url\", \"state\", \"created_at\", \"updated_at\", \"comments\", \"labels\", \"score\", \"candidate_sources\"]\n",
        "    with Path(path).open(\"w\", encoding=\"utf-8\", newline=\"\") as f:\n",
        "        writer = csv.DictWriter(f, fieldnames=fields)\n",
        "        writer.writeheader()\n",
        "        for r in rows:\n",
        "            fw = FRAMEWORK_HINT[r[\"repo\"]]\n",
        "            writer.writerow(\n",
        "                {\n",
        "                    \"repo\": r[\"repo\"],\n",
        "                    \"number\": r[\"number\"],\n",
        "                    \"title\": r.get(\"title\"),\n",
        "                    \"url\": r.get(\"url\"),\n",
        "                    \"state\": r.get(\"state\"),\n",
        "                    \"created_at\": r.get(\"created_at\"),\n",
        "                    \"updated_at\": r.get(\"updated_at\"),\n",
        "                    \"comments\": r.get(\"comments\"),\n",
        "                    \"labels\": \"|\".join(labels(r)),\n",
        "                    \"score\": issue_score(r, fw),\n",
        "                    \"candidate_sources\": \"|\".join(r.get(\"candidate_sources\") or []),\n",
        "                }\n",
        "            )\n",
        "\n",
        "\n",
        "# =========================\n",
        "# GitHub API client\n",
        "# =========================\n",
        "\n",
        "TOKEN = os.environ.get(\"GITHUB_TOKEN\", \"\").strip()\n",
        "try:\n",
        "    from google.colab import userdata\n",
        "\n",
        "    TOKEN = TOKEN or (userdata.get(\"GITHUB_TOKEN\") or \"\").strip()\n",
        "except Exception:\n",
        "    pass\n",
        "\n",
        "if not TOKEN:\n",
        "    print(\"GITHUB_TOKEN not found. Public unauthenticated crawling is very slow.\")\n",
        "    TOKEN = getpass.getpass(\"Paste a GitHub token, or press Enter to continue unauthenticated: \").strip()\n",
        "\n",
        "HEADERS = {\n",
        "    \"Accept\": \"application/vnd.github+json\",\n",
        "    \"X-GitHub-Api-Version\": \"2022-11-28\",\n",
        "    \"User-Agent\": \"gemma-fuzz-dataset-2024-2026-crawler\",\n",
        "}\n",
        "if TOKEN:\n",
        "    HEADERS[\"Authorization\"] = f\"Bearer {TOKEN}\"\n",
        "\n",
        "S = requests.Session()\n",
        "API = \"https://api.github.com\"\n",
        "PACE_LOCK = threading.Lock()\n",
        "LAST_CALL = {\"search\": 0.0, \"core\": 0.0}\n",
        "SEARCH_INTERVAL = SEARCH_INTERVAL_AUTH if TOKEN else SEARCH_INTERVAL_NO_TOKEN\n",
        "CORE_INTERVAL = CORE_INTERVAL_AUTH if TOKEN else CORE_INTERVAL_NO_TOKEN\n",
        "\n",
        "\n",
        "def pace(bucket):\n",
        "    interval = SEARCH_INTERVAL if bucket == \"search\" else CORE_INTERVAL\n",
        "    with PACE_LOCK:\n",
        "        elapsed = time.time() - LAST_CALL[bucket]\n",
        "        if elapsed < interval:\n",
        "            time.sleep(interval - elapsed)\n",
        "        LAST_CALL[bucket] = time.time()\n",
        "\n",
        "\n",
        "def wait_from_headers(headers, fallback=60):\n",
        "    retry_after = headers.get(\"retry-after\")\n",
        "    if retry_after:\n",
        "        try:\n",
        "            return int(retry_after) + 5\n",
        "        except ValueError:\n",
        "            pass\n",
        "    reset = headers.get(\"x-ratelimit-reset\")\n",
        "    remaining = headers.get(\"x-ratelimit-remaining\")\n",
        "    if remaining == \"0\" and reset:\n",
        "        try:\n",
        "            return max(20, int(reset) - int(time.time()) + 5)\n",
        "        except ValueError:\n",
        "            return fallback\n",
        "    return fallback\n",
        "\n",
        "\n",
        "def gh_get(path, params=None, bucket=\"core\", retries=8):\n",
        "    url = path if str(path).startswith(\"http\") else API + path\n",
        "    params = params or {}\n",
        "    for attempt in range(retries):\n",
        "        try:\n",
        "            pace(bucket)\n",
        "            resp = S.get(url, headers=HEADERS, params=params, timeout=45)\n",
        "        except requests.RequestException as exc:\n",
        "            wait = min(90, 8 + 6 * attempt + random.randint(0, 6))\n",
        "            print(f\"[{now()}] network error: {exc}; sleep {wait}s\")\n",
        "            time.sleep(wait)\n",
        "            continue\n",
        "\n",
        "        if resp.status_code == 200:\n",
        "            return resp.json(), resp.headers\n",
        "\n",
        "        body = resp.text[:240].replace(\"\\n\", \" \")\n",
        "        print(\n",
        "            f\"[{now()}] HTTP {resp.status_code} bucket={bucket} \"\n",
        "            f\"remain={resp.headers.get('x-ratelimit-remaining')} \"\n",
        "            f\"resource={resp.headers.get('x-ratelimit-resource')} body={body}\"\n",
        "        )\n",
        "\n",
        "        if resp.status_code in (403, 429):\n",
        "            wait = wait_from_headers(resp.headers, fallback=60 + 15 * attempt + random.randint(0, 15))\n",
        "            print(f\"[{now()}] rate/secondary limit; sleep {wait}s\")\n",
        "            time.sleep(wait)\n",
        "            continue\n",
        "\n",
        "        if resp.status_code in (500, 502, 503, 504):\n",
        "            time.sleep(10 + 8 * attempt + random.randint(0, 8))\n",
        "            continue\n",
        "\n",
        "        if resp.status_code == 422:\n",
        "            raise RuntimeError(f\"GitHub validation/search error 422: {body}\")\n",
        "\n",
        "        raise RuntimeError(f\"GitHub error {resp.status_code}: {body}\")\n",
        "\n",
        "    raise RuntimeError(f\"GitHub request failed after retries: {url}\")\n",
        "\n",
        "\n",
        "def search_issues(repo, term, start_s, end_s, depth=0):\n",
        "    q = f\"repo:{repo} is:issue created:{start_s}..{end_s} {term}\"\n",
        "    data, _ = gh_get(\n",
        "        \"/search/issues\",\n",
        "        {\n",
        "            \"q\": q,\n",
        "            \"sort\": \"updated\",\n",
        "            \"order\": \"desc\",\n",
        "            \"per_page\": 100,\n",
        "            \"page\": 1,\n",
        "        },\n",
        "        bucket=\"search\",\n",
        "    )\n",
        "    total = int(data.get(\"total_count\", 0) or 0)\n",
        "\n",
        "    if (total > 900 or data.get(\"incomplete_results\")) and depth < 9:\n",
        "        split = split_date_range(start_s, end_s)\n",
        "        if split:\n",
        "            left, right = split\n",
        "            return search_issues(repo, term, left[0], left[1], depth + 1) + search_issues(\n",
        "                repo, term, right[0], right[1], depth + 1\n",
        "            )\n",
        "\n",
        "    items = data.get(\"items\", []) or []\n",
        "    max_pages = min(10, math.ceil(min(total, 1000) / 100))\n",
        "    for page in range(2, max_pages + 1):\n",
        "        d, _ = gh_get(\n",
        "            \"/search/issues\",\n",
        "            {\n",
        "                \"q\": q,\n",
        "                \"sort\": \"updated\",\n",
        "                \"order\": \"desc\",\n",
        "                \"per_page\": 100,\n",
        "                \"page\": page,\n",
        "            },\n",
        "            bucket=\"search\",\n",
        "        )\n",
        "        items.extend(d.get(\"items\", []) or [])\n",
        "\n",
        "    return [x for x in items if \"pull_request\" not in x]\n",
        "\n",
        "\n",
        "def fetch_comments(repo, issue_number):\n",
        "    comments = []\n",
        "    for page in range(1, MAX_COMMENT_PAGES + 1):\n",
        "        data, _ = gh_get(\n",
        "            f\"/repos/{repo}/issues/{issue_number}/comments\",\n",
        "            {\"per_page\": 100, \"page\": page},\n",
        "            bucket=\"core\",\n",
        "        )\n",
        "        if not data:\n",
        "            break\n",
        "        comments.extend(data)\n",
        "        if len(data) < 100:\n",
        "            break\n",
        "    return comments\n",
        "\n",
        "\n",
        "# =========================\n",
        "# Main\n",
        "# =========================\n",
        "\n",
        "print(f\"[{now()}] Start 2024-2026 crawler | {START_DATE}..{END_DATE}\")\n",
        "print(f\"[{now()}] Token mode: {'authenticated' if TOKEN else 'unauthenticated'}\")\n",
        "rate, _ = gh_get(\"/rate_limit\", bucket=\"core\")\n",
        "print(\"[rate_limit search]\", json.dumps(rate.get(\"resources\", {}).get(\"search\", {}), indent=2))\n",
        "print(\"[rate_limit core]\", json.dumps(rate.get(\"resources\", {}).get(\"core\", {}), indent=2))\n",
        "\n",
        "candidates_path = CHECKPOINT_DIR / \"candidate_issues_2024_2026.jsonl\"\n",
        "if candidates_path.exists():\n",
        "    loaded = read_jsonl(candidates_path)\n",
        "    candidates = {\n",
        "        (r[\"repo\"], int(r[\"number\"])): normalize_issue(r[\"repo\"], r, source=None)\n",
        "        for r in loaded\n",
        "        if r.get(\"repo\") in FRAMEWORK_HINT and r.get(\"number\") is not None\n",
        "    }\n",
        "    print(f\"[{now()}] Loaded candidate checkpoint: {len(candidates)}\")\n",
        "else:\n",
        "    candidates = {}\n",
        "\n",
        "\n",
        "def add_candidate(repo, issue, source):\n",
        "    if \"pull_request\" in issue:\n",
        "        return False\n",
        "    row = normalize_issue(repo, issue, source=source)\n",
        "    if row.get(\"number\") is None:\n",
        "        return False\n",
        "    key = (repo, int(row[\"number\"]))\n",
        "    old = candidates.get(key)\n",
        "    if old is None:\n",
        "        candidates[key] = row\n",
        "        return True\n",
        "    candidates[key] = merge_issue(old, row, FRAMEWORK_HINT[repo])\n",
        "    return False\n",
        "\n",
        "\n",
        "if CRAWL_UPDATED_SINCE:\n",
        "    print(f\"\\n[{now()}] Stage A: list repo issues updated since {SINCE}\")\n",
        "    for repo in REPOS:\n",
        "        repo_new = 0\n",
        "        print(f\"[{now()}] Updated listing repo={repo}\")\n",
        "        for page in tqdm(range(1, MAX_UPDATED_PAGES_PER_REPO + 1), desc=f\"updated {repo}\"):\n",
        "            data, _ = gh_get(\n",
        "                f\"/repos/{repo}/issues\",\n",
        "                {\n",
        "                    \"state\": \"all\",\n",
        "                    \"since\": SINCE,\n",
        "                    \"sort\": \"updated\",\n",
        "                    \"direction\": \"desc\",\n",
        "                    \"per_page\": 100,\n",
        "                    \"page\": page,\n",
        "                },\n",
        "                bucket=\"core\",\n",
        "            )\n",
        "            raw_len = len(data)\n",
        "            if raw_len == 0:\n",
        "                break\n",
        "            issues_only = [x for x in data if \"pull_request\" not in x]\n",
        "            for item in issues_only:\n",
        "                if add_candidate(repo, item, \"updated_since\"):\n",
        "                    repo_new += 1\n",
        "            if page % 10 == 0:\n",
        "                save_candidate_checkpoint(candidates, candidates_path)\n",
        "                print(f\"[{now()}] {repo} page={page} raw={raw_len} issues={len(issues_only)} total_repo={sum(1 for r, _ in candidates if r == repo)}\")\n",
        "            if raw_len < 100:\n",
        "                break\n",
        "        save_candidate_checkpoint(candidates, candidates_path)\n",
        "        print(f\"[{now()}] {repo} updated_since new={repo_new} total_repo={sum(1 for r, _ in candidates if r == repo)}\")\n",
        "\n",
        "if CRAWL_CREATED_SEARCH:\n",
        "    ranges = month_ranges(START_DATE, END_DATE)\n",
        "    print(f\"\\n[{now()}] Stage B: search created candidates months={len(ranges)}\")\n",
        "    for repo in REPOS:\n",
        "        print(f\"[{now()}] Search repo={repo}\")\n",
        "        for start_s, end_s in tqdm(ranges, desc=f\"search {repo}\"):\n",
        "            month_new = 0\n",
        "            for term in TERMS_BY_REPO[repo]:\n",
        "                try:\n",
        "                    for item in search_issues(repo, term, start_s, end_s):\n",
        "                        if add_candidate(repo, item, \"created_search\"):\n",
        "                            month_new += 1\n",
        "                except Exception as exc:\n",
        "                    print(f\"[WARN] search failed repo={repo} range={start_s}..{end_s} term={term}: {exc}\")\n",
        "            save_candidate_checkpoint(candidates, candidates_path)\n",
        "            print(f\"[{now()}] {repo} {start_s[:7]} new={month_new} total_repo={sum(1 for r, _ in candidates if r == repo)}\")\n",
        "\n",
        "candidate_rows = list(candidates.values())\n",
        "candidate_rows.sort(key=lambda x: issue_score(x, FRAMEWORK_HINT[x[\"repo\"]]), reverse=True)\n",
        "save_candidate_checkpoint(candidates, candidates_path)\n",
        "write_candidate_csv(OUT_DIR / \"candidate_issues_2024_2026.csv\", candidate_rows)\n",
        "\n",
        "print(\"[candidate counts]\", dict(Counter(r[\"repo\"] for r in candidate_rows)))\n",
        "\n",
        "records_partial_path = CHECKPOINT_DIR / \"new_2024_2026.partial.jsonl\"\n",
        "processed_comments_path = CHECKPOINT_DIR / \"processed_comment_issues.jsonl\"\n",
        "records = read_jsonl(records_partial_path)\n",
        "\n",
        "seen_code = set()\n",
        "for r in records:\n",
        "    h = r.get(\"code_sha1\") or sha1_text(r.get(\"output\", \"\"))\n",
        "    if h:\n",
        "        seen_code.add((r.get(\"framework\"), h))\n",
        "\n",
        "processed_comments = set()\n",
        "for row in read_jsonl(processed_comments_path):\n",
        "    if row.get(\"repo\") and row.get(\"number\") is not None:\n",
        "        processed_comments.add((row[\"repo\"], int(row[\"number\"])))\n",
        "\n",
        "print(f\"[{now()}] Loaded partial records={len(records)} processed_comment_issues={len(processed_comments)}\")\n",
        "\n",
        "\n",
        "def add_record_if_new(rec):\n",
        "    if not rec:\n",
        "        return False\n",
        "    key = (rec.get(\"framework\"), rec.get(\"code_sha1\"))\n",
        "    if key in seen_code:\n",
        "        return False\n",
        "    seen_code.add(key)\n",
        "    records.append(rec)\n",
        "    append_jsonl(records_partial_path, rec)\n",
        "    return True\n",
        "\n",
        "\n",
        "print(f\"\\n[{now()}] Body-only extraction\")\n",
        "body_added = 0\n",
        "for issue in tqdm(candidate_rows, desc=\"body extract\"):\n",
        "    repo = issue[\"repo\"]\n",
        "    for idx, (lang, raw) in enumerate(code_blocks(issue.get(\"body\") or \"\")):\n",
        "        rec = record_from_block(repo, issue, \"issue_body\", idx, lang, raw)\n",
        "        if add_record_if_new(rec):\n",
        "            body_added += 1\n",
        "print(f\"[{now()}] Body records added this run: {body_added}\")\n",
        "\n",
        "selected = []\n",
        "for repo in REPOS:\n",
        "    xs = [r for r in candidate_rows if r[\"repo\"] == repo]\n",
        "    xs.sort(key=lambda x: issue_score(x, FRAMEWORK_HINT[repo]), reverse=True)\n",
        "    # Body blocks were already extracted. If GitHub says comments=0, fetching\n",
        "    # comments only burns one core request and cannot add more records.\n",
        "    take = [x for x in xs if int(x.get(\"comments\") or 0) > 0][:FETCH_COMMENTS_TOP_PER_REPO]\n",
        "    selected.extend(take)\n",
        "    print(f\"[{now()}] selected for comments {repo}: {len(take)} / candidates={len(xs)}\")\n",
        "\n",
        "selected = [r for r in selected if (r[\"repo\"], int(r[\"number\"])) not in processed_comments]\n",
        "print(f\"[{now()}] Remaining comment issues to fetch: {len(selected)}\")\n",
        "\n",
        "\n",
        "def process_issue_comments(issue):\n",
        "    repo = issue[\"repo\"]\n",
        "    number = int(issue[\"number\"])\n",
        "    comments = fetch_comments(repo, number)\n",
        "    new_records = []\n",
        "    for c_idx, comment in enumerate(comments):\n",
        "        for b_idx, (lang, raw) in enumerate(code_blocks(comment.get(\"body\") or \"\")):\n",
        "            rec = record_from_block(repo, issue, \"comment\", c_idx * 1000 + b_idx, lang, raw)\n",
        "            if rec:\n",
        "                new_records.append(rec)\n",
        "    return repo, number, new_records\n",
        "\n",
        "\n",
        "print(f\"\\n[{now()}] Fetch comments and extract\")\n",
        "comment_added = 0\n",
        "if selected:\n",
        "    with ThreadPoolExecutor(max_workers=MAX_WORKERS) as ex:\n",
        "        futures = [ex.submit(process_issue_comments, issue) for issue in selected]\n",
        "        for fut in tqdm(as_completed(futures), total=len(futures), desc=\"comments extract\"):\n",
        "            try:\n",
        "                repo, number, new_records = fut.result()\n",
        "                added = 0\n",
        "                for rec in new_records:\n",
        "                    if add_record_if_new(rec):\n",
        "                        added += 1\n",
        "                        comment_added += 1\n",
        "                append_jsonl(\n",
        "                    processed_comments_path,\n",
        "                    {\n",
        "                        \"repo\": repo,\n",
        "                        \"number\": number,\n",
        "                        \"records_added\": added,\n",
        "                        \"processed_at\": datetime.now(timezone.utc).isoformat(),\n",
        "                    },\n",
        "                )\n",
        "            except Exception as exc:\n",
        "                print(f\"[WARN] comment processing failed: {exc}\")\n",
        "else:\n",
        "    print(\"No remaining selected issues; using existing checkpoint.\")\n",
        "\n",
        "print(f\"[{now()}] Comment records added this run: {comment_added}\")\n",
        "\n",
        "dedup = []\n",
        "seen = set()\n",
        "for r in records:\n",
        "    h = r.get(\"code_sha1\") or sha1_text(r.get(\"output\", \"\"))\n",
        "    key = (r.get(\"framework\"), h)\n",
        "    if key in seen:\n",
        "        continue\n",
        "    seen.add(key)\n",
        "    r[\"code_sha1\"] = h\n",
        "    dedup.append(r)\n",
        "\n",
        "dedup.sort(key=lambda x: (x.get(\"quality_score\") or 0, len(x.get(\"output\") or \"\")), reverse=True)\n",
        "\n",
        "\n",
        "def split_by_issue(rows):\n",
        "    train, val, test = [], [], []\n",
        "    for r in rows:\n",
        "        group = f\"{r.get('repo')}#{r.get('issue_number')}\"\n",
        "        bucket = int(sha1_text(group)[:8], 16) % 100\n",
        "        if bucket < 5:\n",
        "            val.append(r)\n",
        "        elif bucket < 10:\n",
        "            test.append(r)\n",
        "        else:\n",
        "            train.append(r)\n",
        "    return train, val, test\n",
        "\n",
        "\n",
        "train, val, test = split_by_issue(dedup)\n",
        "\n",
        "write_jsonl(OUT_DIR / \"all_2024_2026.jsonl\", dedup)\n",
        "write_jsonl(OUT_DIR / \"new_2024_2026.jsonl\", dedup)\n",
        "write_jsonl(OUT_DIR / \"train.jsonl\", train)\n",
        "write_jsonl(OUT_DIR / \"val.jsonl\", val)\n",
        "write_jsonl(OUT_DIR / \"test.jsonl\", test)\n",
        "\n",
        "manifest = {\n",
        "    \"created_at\": datetime.now(timezone.utc).isoformat(),\n",
        "    \"range\": f\"{START_DATE}..{END_DATE}\",\n",
        "    \"since\": SINCE,\n",
        "    \"repos\": REPOS,\n",
        "    \"candidate_issues_2024_2026\": len(candidate_rows),\n",
        "    \"candidate_by_repo\": dict(Counter(r[\"repo\"] for r in candidate_rows)),\n",
        "    \"candidate_source_counts\": dict(Counter(src for r in candidate_rows for src in (r.get(\"candidate_sources\") or []))),\n",
        "    \"records_total\": len(dedup),\n",
        "    \"train\": len(train),\n",
        "    \"val\": len(val),\n",
        "    \"test\": len(test),\n",
        "    \"by_framework\": dict(Counter(r.get(\"framework\") for r in dedup)),\n",
        "    \"strict_python_ast\": STRICT_PYTHON_AST,\n",
        "    \"crawl_updated_since\": CRAWL_UPDATED_SINCE,\n",
        "    \"crawl_created_search\": CRAWL_CREATED_SEARCH,\n",
        "    \"max_updated_pages_per_repo\": MAX_UPDATED_PAGES_PER_REPO,\n",
        "    \"fetch_comments_top_per_repo\": FETCH_COMMENTS_TOP_PER_REPO,\n",
        "    \"max_comment_pages\": MAX_COMMENT_PAGES,\n",
        "    \"max_workers\": MAX_WORKERS,\n",
        "}\n",
        "(OUT_DIR / \"manifest.json\").write_text(json.dumps(manifest, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n",
        "\n",
        "zip_path = Path(\"/content/dl_issue_fuzz_dataset_2024_2026_rescued.zip\")\n",
        "with zipfile.ZipFile(zip_path, \"w\", zipfile.ZIP_DEFLATED) as z:\n",
        "    for p in sorted(OUT_DIR.glob(\"*\")):\n",
        "        if p.is_file():\n",
        "            z.write(p, arcname=p.name)\n",
        "    for p in sorted(CHECKPOINT_DIR.glob(\"*\")):\n",
        "        if p.is_file():\n",
        "            z.write(p, arcname=f\"checkpoints/{p.name}\")\n",
        "\n",
        "print(\"\\nDONE\")\n",
        "print(json.dumps(manifest, ensure_ascii=False, indent=2))\n",
        "print(\"ZIP:\", zip_path)\n",
        "\n",
        "print(\"\\nTop 10 records:\")\n",
        "for r in dedup[:10]:\n",
        "    print(\"-\" * 90)\n",
        "    print(r[\"repo\"], \"#\", r[\"issue_number\"], \"score=\", r[\"quality_score\"], r[\"issue_title\"][:120])\n",
        "    print(\"APIs:\", \", \".join(r[\"apis\"][:12]))\n",
        "    print(r[\"url\"])\n",
        "    print((r[\"output\"][:600]).replace(\"\\n\", \"\\n  \"))\n",
        "\n",
        "try:\n",
        "    from google.colab import files\n",
        "\n",
        "    files.download(str(zip_path))\n",
        "except Exception:\n",
        "    pass\n"
