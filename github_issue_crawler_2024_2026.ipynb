      "source": [
        "# =========================\n",
        "# Colab 1-cell v2: Crawl PyTorch/TensorFlow GitHub issues -> FuzzGPT-style dataset\n",
        "# Robust version: no advanced_search, no OR parentheses, uses created+updated, safe empty handling\n",
        "# Output: /content/dl_issue_fuzz_dataset_v2.zip\n",
        "# =========================\n",
        "\n",
        "!pip -q install requests tqdm pandas\n",
        "\n",
        "import os, re, json, time, math, random, hashlib, zipfile, getpass, ast\n",
        "from pathlib import Path\n",
        "from datetime import datetime, timezone, timedelta\n",
        "from concurrent.futures import ThreadPoolExecutor, as_completed\n",
        "\n",
        "import requests\n",
        "import pandas as pd\n",
        "from tqdm.auto import tqdm\n",
        "\n",
        "# ========== CONFIG ==========\n",
        "REPOS = [\"pytorch/pytorch\", \"tensorflow/tensorflow\"]\n",
        "\n",
        "# Gấp deadline: 2024 -> nay sẽ ra nhanh và mới.\n",
        "# Muốn sâu hơn thì đổi thành \"2021-01-01\".\n",
        "START_DATE = \"2024-01-01\"\n",
        "END_DATE = datetime.now(timezone.utc).date().isoformat()\n",
        "\n",
        "# created: issue mới tạo; updated: issue cũ nhưng vừa có comment/repro mới.\n",
        "DATE_FIELDS = [\"updated\", \"created\"]\n",
        "\n",
        "# Query đơn giản, không OR/ngoặc để tránh GitHub search lởm khởm.\n",
        "TERMS = [\n",
        "    \"bug\",\n",
        "    \"regression\",\n",
        "    \"crash\",\n",
        "    \"segfault\",\n",
        "    \"segmentation fault\",\n",
        "    \"minimal repro\",\n",
        "    \"minimal reproduction\",\n",
        "    \"reproduce\",\n",
        "    \"wrong result\",\n",
        "    \"incorrect\",\n",
        "    \"mismatch\",\n",
        "    \"inconsistency\",\n",
        "    \"RuntimeError\",\n",
        "    \"AssertionError\",\n",
        "    \"ValueError\",\n",
        "    \"InternalError\",\n",
        "    \"CUDA error\",\n",
        "    \"cuda\",\n",
        "    \"cudnn\",\n",
        "    \"gpu\",\n",
        "    \"autograd\",\n",
        "    \"gradient\",\n",
        "    \"backward\",\n",
        "    \"dtype\",\n",
        "    \"shape\",\n",
        "    \"nan\",\n",
        "    \"inf\",\n",
        "    \"torch.compile\",\n",
        "    \"dynamo\",\n",
        "    \"inductor\",\n",
        "    \"tf.function\",\n",
        "    \"keras\",\n",
        "    \"xla\",\n",
        "]\n",
        "\n",
        "MAX_ISSUES_PER_REPO = 2500\n",
        "FETCH_COMMENTS_TOP_PER_REPO = 1200\n",
        "MAX_COMMENT_PAGES_PER_ISSUE = 2\n",
        "MAX_WORKERS = 4\n",
        "MIN_RECORD_SCORE = 6\n",
        "MAX_SNIPPET_CHARS = 9000\n",
        "OUT_DIR = Path(\"/content/dl_issue_fuzz_dataset_v2\")\n",
        "OUT_DIR.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "FRAMEWORK_HINT = {\n",
        "    \"pytorch/pytorch\": \"pytorch\",\n",
        "    \"tensorflow/tensorflow\": \"tensorflow\",\n",
        "}\n",
        "\n",
        "BUG_TERMS = [\n",
        "    \"bug\", \"regression\", \"crash\", \"segfault\", \"segmentation fault\",\n",
        "    \"runtimeerror\", \"assertionerror\", \"valueerror\", \"internalerror\",\n",
        "    \"wrong result\", \"incorrect\", \"mismatch\", \"inconsistency\",\n",
        "    \"nan\", \"inf\", \"cuda\", \"cudnn\", \"gpu\", \"xla\",\n",
        "    \"autograd\", \"gradient\", \"backward\", \"memory leak\",\n",
        "    \"deadlock\", \"hang\", \"minimal repro\", \"minimal reproduction\",\n",
        "    \"reproduce\", \"reproduction\", \"torch.compile\", \"tf.function\",\n",
        "]\n",
        "\n",
        "ORACLE_TERMS = {\n",
        "    \"crash\": [\"crash\", \"segfault\", \"segmentation fault\", \"floating point exception\", \"sigfpe\", \"abort\", \"core dumped\"],\n",
        "    \"exception\": [\"runtimeerror\", \"assertionerror\", \"valueerror\", \"internalerror\", \"typeerror\"],\n",
        "    \"silent_wrong_result\": [\"wrong result\", \"incorrect\", \"mismatch\", \"inconsistency\", \"different result\"],\n",
        "    \"autograd\": [\"autograd\", \"gradient\", \"backward\", \"jacobian\", \"gradcheck\"],\n",
        "    \"resource\": [\"memory leak\", \"oom\", \"out of memory\", \"deadlock\", \"hang\"],\n",
        "    \"numerical\": [\"nan\", \"inf\", \"overflow\", \"underflow\", \"precision\"],\n",
        "    \"compile\": [\"torch.compile\", \"dynamo\", \"inductor\", \"tf.function\", \"xla\", \"jit_compile\"],\n",
        "}\n",
        "\n",
        "API_REGEX = {\n",
        "    \"pytorch\": [\n",
        "        r\"\\btorch(?:\\.[A-Za-z_]\\w*){1,7}\\b\",\n",
        "        r\"\\btorchvision(?:\\.[A-Za-z_]\\w*){1,7}\\b\",\n",
        "        r\"\\bfunctorch(?:\\.[A-Za-z_]\\w*){0,7}\\b\",\n",
        "    ],\n",
        "    \"tensorflow\": [\n",
        "        r\"\\btf(?:\\.[A-Za-z_]\\w*){1,7}\\b\",\n",
        "        r\"\\btensorflow(?:\\.[A-Za-z_]\\w*){1,7}\\b\",\n",
        "        r\"\\bkeras(?:\\.[A-Za-z_]\\w*){1,7}\\b\",\n",
        "    ],\n",
        "}\n",
        "\n",
        "# ========== TOKEN ==========\n",
        "TOKEN = os.environ.get(\"GITHUB_TOKEN\", \"\").strip()\n",
        "try:\n",
        "    from google.colab import userdata\n",
        "    TOKEN = TOKEN or (userdata.get(\"GITHUB_TOKEN\") or \"\").strip()\n",
        "except Exception:\n",
        "    pass\n",
        "\n",
        "if not TOKEN:\n",
        "    print(\"⚠️ Chưa thấy GITHUB_TOKEN trong Colab Secrets/env.\")\n",
        "    print(\"Dán token public/read-only vào đây. Không token vẫn chạy nhưng dễ dính rate limit.\")\n",
        "    try:\n",
        "        TOKEN = getpass.getpass(\"GITHUB_TOKEN: \").strip()\n",
        "    except Exception:\n",
        "        TOKEN = \"\"\n",
        "\n",
        "HEADERS = {\n",
        "    \"Accept\": \"application/vnd.github+json\",\n",
        "    \"X-GitHub-Api-Version\": \"2022-11-28\",\n",
        "    \"User-Agent\": \"dl-issue-fuzz-crawler-v2\",\n",
        "}\n",
        "if TOKEN:\n",
        "    HEADERS[\"Authorization\"] = f\"Bearer {TOKEN}\"\n",
        "\n",
        "SESSION = requests.Session()\n",
        "API = \"https://api.github.com\"\n",
        "\n",
        "def now():\n",
        "    return datetime.now().strftime(\"%H:%M:%S\")\n",
        "\n",
        "def sha1(x):\n",
        "    return hashlib.sha1(x.encode(\"utf-8\", errors=\"ignore\")).hexdigest()\n",
        "\n",
        "def safe_text(x):\n",
        "    return x if isinstance(x, str) else \"\"\n",
        "\n",
        "def parse_d(s):\n",
        "    return datetime.strptime(s, \"%Y-%m-%d\").date()\n",
        "\n",
        "def split_date_range(start_s, end_s):\n",
        "    s, e = parse_d(start_s), parse_d(end_s)\n",
        "    if s >= e:\n",
        "        return None\n",
        "    mid = s + (e - s) // 2\n",
        "    if mid < s or mid >= e:\n",
        "        return None\n",
        "    return (s.isoformat(), mid.isoformat()), ((mid + timedelta(days=1)).isoformat(), e.isoformat())\n",
        "\n",
        "def quote_term(term):\n",
        "    term = term.strip()\n",
        "    if \" \" in term or \".\" in term:\n",
        "        return f'\"{term}\"'\n",
        "    return term\n",
        "\n",
        "def gh_get(path_or_url, params=None, retries=8):\n",
        "    url = path_or_url if path_or_url.startswith(\"http\") else API + path_or_url\n",
        "    params = dict(params or {})\n",
        "\n",
        "    for attempt in range(retries):\n",
        "        try:\n",
        "            r = SESSION.get(url, headers=HEADERS, params=params, timeout=45)\n",
        "        except Exception as e:\n",
        "            wait = min(90, 2 ** attempt + random.random())\n",
        "            print(f\"[{now()}] network lỗi: {e}; ngủ {wait:.1f}s\")\n",
        "            time.sleep(wait)\n",
        "            continue\n",
        "\n",
        "        if r.status_code == 401:\n",
        "            raise RuntimeError(\"Token GitHub sai/hết hạn hoặc không có quyền đọc public metadata.\")\n",
        "\n",
        "        if r.status_code in (403, 429):\n",
        "            text = r.text.lower()\n",
        "            remaining = int(r.headers.get(\"X-RateLimit-Remaining\", \"0\") or 0)\n",
        "            reset = int(r.headers.get(\"X-RateLimit-Reset\", \"0\") or 0)\n",
        "\n",
        "            if \"secondary rate\" in text or \"abuse\" in text:\n",
        "                wait = 75 + random.randint(0, 45)\n",
        "            elif remaining == 0 and reset:\n",
        "                wait = max(15, reset - int(time.time()) + 5)\n",
        "            else:\n",
        "                wait = 45 + random.randint(0, 30)\n",
        "\n",
        "            print(f\"[{now()}] GitHub rate/secondary limit; ngủ {wait}s\")\n",
        "            time.sleep(wait)\n",
        "            continue\n",
        "\n",
        "        if r.status_code in (500, 502, 503, 504):\n",
        "            wait = min(90, 2 ** attempt + random.random() * 3)\n",
        "            print(f\"[{now()}] GitHub {r.status_code}; ngủ {wait:.1f}s\")\n",
        "            time.sleep(wait)\n",
        "            continue\n",
        "\n",
        "        if r.status_code >= 400:\n",
        "            print(\"URL:\", r.url)\n",
        "            raise RuntimeError(f\"GitHub API lỗi {r.status_code}: {r.text[:800]}\")\n",
        "\n",
        "        return r.json(), r.headers\n",
        "\n",
        "    raise RuntimeError(f\"Hết retry cho {url}\")\n",
        "\n",
        "def search_issues_window(repo, date_field, term, start_s, end_s, depth=0):\n",
        "    q = f\"repo:{repo} is:issue state:all {date_field}:{start_s}..{end_s} {quote_term(term)}\"\n",
        "    params = {\n",
        "        \"q\": q,\n",
        "        \"sort\": \"updated\",\n",
        "        \"order\": \"desc\",\n",
        "        \"per_page\": 100,\n",
        "        \"page\": 1,\n",
        "    }\n",
        "\n",
        "    data, _ = gh_get(\"/search/issues\", params=params)\n",
        "    total = int(data.get(\"total_count\", 0) or 0)\n",
        "\n",
        "    # GitHub search hay có trần lấy sâu; nếu quá nhiều thì tách đôi khoảng ngày.\n",
        "    if total > 900 and depth < 10:\n",
        "        sp = split_date_range(start_s, end_s)\n",
        "        if sp:\n",
        "            left, right = sp\n",
        "            return (\n",
        "                search_issues_window(repo, date_field, term, left[0], left[1], depth + 1)\n",
        "                + search_issues_window(repo, date_field, term, right[0], right[1], depth + 1)\n",
        "            )\n",
        "\n",
        "    items = data.get(\"items\", []) or []\n",
        "    max_pages = min(10, math.ceil(min(total, 1000) / 100))\n",
        "    for page in range(2, max_pages + 1):\n",
        "        params[\"page\"] = page\n",
        "        d, _ = gh_get(\"/search/issues\", params=params)\n",
        "        items.extend(d.get(\"items\", []) or [])\n",
        "        time.sleep(0.15)\n",
        "\n",
        "    return items\n",
        "\n",
        "def label_names(issue):\n",
        "    return [x.get(\"name\", \"\") for x in issue.get(\"labels\", []) if isinstance(x, dict)]\n",
        "\n",
        "def framework_of(repo):\n",
        "    return FRAMEWORK_HINT.get(repo, \"unknown\")\n",
        "\n",
        "def extract_code_blocks(md):\n",
        "    md = safe_text(md)\n",
        "    blocks = []\n",
        "\n",
        "    # Fenced blocks: ```python ... ```\n",
        "    fenced = re.compile(r\"```[ \\t]*([A-Za-z0-9_+\\-\\.]*)?[ \\t]*\\n(.*?)```\", re.S)\n",
        "    for m in fenced.finditer(md):\n",
        "        blocks.append(((m.group(1) or \"\").strip().lower(), m.group(2) or \"\"))\n",
        "\n",
        "    # Indented markdown code blocks: 4 spaces / tab\n",
        "    lines = md.splitlines()\n",
        "    cur = []\n",
        "    for line in lines + [\"\"]:\n",
        "        if line.startswith(\"    \") or line.startswith(\"\\t\"):\n",
        "            cur.append(re.sub(r\"^(    |\\t)\", \"\", line))\n",
        "        else:\n",
        "            if len(cur) >= 2:\n",
        "                code = \"\\n\".join(cur).strip()\n",
        "                if len(code) > 30:\n",
        "                    blocks.append((\"\", code))\n",
        "            cur = []\n",
        "\n",
        "    return blocks\n",
        "\n",
        "def clean_code(code):\n",
        "    code = safe_text(code).replace(\"\\r\\n\", \"\\n\").replace(\"\\r\", \"\\n\")\n",
        "    out = []\n",
        "    for line in code.split(\"\\n\"):\n",
        "        line = re.sub(r\"^\\s*(>>>|\\.\\.\\.)\\s?\", \"\", line)\n",
        "        out.append(line.rstrip())\n",
        "    code = \"\\n\".join(out).strip()\n",
        "    if len(code) > MAX_SNIPPET_CHARS:\n",
        "        code = code[:MAX_SNIPPET_CHARS] + \"\\n# ... [TRUNCATED]\"\n",
        "    return code\n",
        "\n",
        "def extract_apis(text, fw):\n",
        "    found = set()\n",
        "    for pat in API_REGEX.get(fw, []):\n",
        "        for m in re.finditer(pat, text):\n",
        "            x = m.group(0)\n",
        "            if len(x) <= 140:\n",
        "                found.add(x.replace(\"tensorflow.\", \"tf.\"))\n",
        "    return sorted(found)\n",
        "\n",
        "def infer_oracle_type(text):\n",
        "    t = safe_text(text).lower()\n",
        "    out = []\n",
        "    for k, terms in ORACLE_TERMS.items():\n",
        "        if any(term in t for term in terms):\n",
        "            out.append(k)\n",
        "    return out or [\"unknown\"]\n",
        "\n",
        "def ast_ok(code):\n",
        "    try:\n",
        "        ast.parse(code)\n",
        "        return True\n",
        "    except Exception:\n",
        "        return False\n",
        "\n",
        "def issue_score(issue):\n",
        "    title = safe_text(issue.get(\"title\"))\n",
        "    body = safe_text(issue.get(\"body\"))\n",
        "    labels = \" \".join(label_names(issue)).lower()\n",
        "    txt = (title + \"\\n\" + body + \"\\n\" + labels).lower()\n",
        "\n",
        "    score = 0\n",
        "    if any(x in labels for x in [\"bug\", \"triaged\", \"regression\", \"module:\", \"comp:\", \"type: bug\", \"type:bug\"]):\n",
        "        score += 5\n",
        "    score += min(7, sum(1 for k in BUG_TERMS if k in txt))\n",
        "    if extract_code_blocks(body):\n",
        "        score += 5\n",
        "    score += min(3, int(math.log2(int(issue.get(\"comments\", 0) or 0) + 1)))\n",
        "    if any(x in txt for x in [\"minimal repro\", \"minimal reproduction\", \"expected behavior\", \"actual behavior\", \"versions\", \"collect_env\"]):\n",
        "        score += 4\n",
        "    return score\n",
        "\n",
        "def snippet_score(code, ctx, labels, fw):\n",
        "    t = (code + \"\\n\" + ctx + \"\\n\" + \" \".join(labels)).lower()\n",
        "    apis = extract_apis(code, fw)\n",
        "\n",
        "    score = 0\n",
        "    if apis:\n",
        "        score += 6\n",
        "\n",
        "    if fw == \"pytorch\" and re.search(r\"\\b(import torch|from torch|torch\\.)\", code):\n",
        "        score += 6\n",
        "    if fw == \"tensorflow\" and re.search(r\"\\b(import tensorflow|from tensorflow|import keras|tf\\.|tensorflow\\.|keras\\.)\", code):\n",
        "        score += 6\n",
        "\n",
        "    score += min(7, sum(1 for k in BUG_TERMS if k in t))\n",
        "\n",
        "    labels_l = \" \".join(labels).lower()\n",
        "    if any(x in labels_l for x in [\"bug\", \"triaged\", \"regression\", \"module:\", \"comp:\", \"type: bug\", \"type:bug\"]):\n",
        "        score += 3\n",
        "\n",
        "    if 50 <= len(code) <= MAX_SNIPPET_CHARS:\n",
        "        score += 2\n",
        "\n",
        "    if ast_ok(code):\n",
        "        score += 4\n",
        "    else:\n",
        "        score -= 1\n",
        "\n",
        "    # Loại log thuần không có code gọi API\n",
        "    if (\"traceback\" in code.lower() or \"error log\" in code.lower()) and not apis:\n",
        "        score -= 6\n",
        "\n",
        "    return score\n",
        "\n",
        "def make_record(repo, issue, source_kind, source_index, source_body, lang, raw_code):\n",
        "    fw = framework_of(repo)\n",
        "    labels = label_names(issue)\n",
        "    title = safe_text(issue.get(\"title\"))\n",
        "    body = safe_text(issue.get(\"body\"))\n",
        "    code = clean_code(raw_code)\n",
        "\n",
        "    ctx = f\"{title}\\n{body[:5000]}\\n{source_body[:3000]}\"\n",
        "    score = snippet_score(code, ctx, labels, fw)\n",
        "    if score < MIN_RECORD_SCORE:\n",
        "        return None\n",
        "\n",
        "    if fw == \"pytorch\" and not re.search(r\"\\b(torch\\.|import torch|from torch|torchvision\\.|functorch\\.)\", code):\n",
        "        return None\n",
        "    if fw == \"tensorflow\" and not re.search(r\"\\b(tf\\.|tensorflow\\.|keras\\.|import tensorflow|from tensorflow|import keras)\", code):\n",
        "        return None\n",
        "\n",
        "    apis = extract_apis(code, fw)\n",
        "    if not apis:\n",
        "        return None\n",
        "\n",
        "    num = issue.get(\"number\")\n",
        "    url = issue.get(\"html_url\") or f\"https://github.com/{repo}/issues/{num}\"\n",
        "    oracle_type = infer_oracle_type(ctx + \"\\n\" + code)\n",
        "\n",
        "    return {\n",
        "        \"id\": f\"{repo}#{num}:{source_kind}:{source_index}:{sha1(code)[:12]}\",\n",
        "        \"framework\": fw,\n",
        "        \"repo\": repo,\n",
        "        \"issue_number\": num,\n",
        "        \"issue_title\": title,\n",
        "        \"url\": url,\n",
        "        \"state\": issue.get(\"state\"),\n",
        "        \"created_at\": issue.get(\"created_at\"),\n",
        "        \"updated_at\": issue.get(\"updated_at\"),\n",
        "        \"closed_at\": issue.get(\"closed_at\"),\n",
        "        \"labels\": labels,\n",
        "        \"source_kind\": source_kind,\n",
        "        \"source_index\": source_index,\n",
        "        \"markdown_lang\": lang,\n",
        "        \"apis\": apis,\n",
        "        \"oracle_type\": oracle_type,\n",
        "        \"quality_score\": score,\n",
        "        \"code_sha1\": sha1(code),\n",
        "        \"instruction\": (\n",
        "            \"Generate or mutate a minimal Python reproducer / fuzz seed for a deep-learning \"\n",
        "            \"library bug. Prefer runnable code, edge-case tensors, dtype/shape/device variants, \"\n",
        "            \"and an oracle such as crash, exception, numerical mismatch, autograd mismatch, or hang.\"\n",
        "        ),\n",
        "        \"input\": (\n",
        "            f\"Framework: {fw}\\n\"\n",
        "            f\"Repository: {repo}\\n\"\n",
        "            f\"Issue: #{num} - {title}\\n\"\n",
        "            f\"Labels: {', '.join(labels)}\\n\"\n",
        "            f\"Detected APIs: {', '.join(apis[:20])}\\n\"\n",
        "            f\"Oracle type: {', '.join(oracle_type)}\\n\"\n",
        "            f\"URL: {url}\\n\"\n",
        "        ),\n",
        "        \"output\": code,\n",
        "        \"raw_context_excerpt\": ctx[:3000],\n",
        "    }\n",
        "\n",
        "def fetch_issue_and_comments(repo, num):\n",
        "    issue, _ = gh_get(f\"/repos/{repo}/issues/{num}\")\n",
        "    comments = []\n",
        "    for page in range(1, MAX_COMMENT_PAGES_PER_ISSUE + 1):\n",
        "        d, _ = gh_get(\n",
        "            f\"/repos/{repo}/issues/{num}/comments\",\n",
        "            params={\"per_page\": 100, \"page\": page}\n",
        "        )\n",
        "        if not d:\n",
        "            break\n",
        "        comments.extend(d)\n",
        "        if len(d) < 100:\n",
        "            break\n",
        "    return issue, comments\n",
        "\n",
        "def write_jsonl(path, rows):\n",
        "    with open(path, \"w\", encoding=\"utf-8\") as f:\n",
        "        for r in rows:\n",
        "            f.write(json.dumps(r, ensure_ascii=False) + \"\\n\")\n",
        "\n",
        "# ========== PROBE ==========\n",
        "print(f\"[{now()}] Probe GitHub Search...\")\n",
        "for repo in REPOS:\n",
        "    q = f\"repo:{repo} is:issue state:all updated:2026-01-01..{END_DATE} bug\"\n",
        "    try:\n",
        "        d, _ = gh_get(\"/search/issues\", params={\"q\": q, \"per_page\": 1, \"sort\": \"updated\", \"order\": \"desc\"})\n",
        "        print(f\"  {repo}: probe total_count={d.get('total_count')} | query={q}\")\n",
        "    except Exception as e:\n",
        "        print(f\"  {repo}: probe lỗi: {e}\")\n",
        "\n",
        "# ========== STAGE 1: SEARCH CANDIDATES ==========\n",
        "all_candidates = {}\n",
        "\n",
        "print(f\"\\n[{now()}] START search candidates | {START_DATE}..{END_DATE}\")\n",
        "for repo in REPOS:\n",
        "    repo_items = {}\n",
        "    print(f\"\\n[{now()}] Repo: {repo}\")\n",
        "\n",
        "    tasks = [(df, term) for df in DATE_FIELDS for term in TERMS]\n",
        "    for date_field, term in tqdm(tasks, desc=f\"search {repo}\"):\n",
        "        try:\n",
        "            items = search_issues_window(repo, date_field, term, START_DATE, END_DATE)\n",
        "        except Exception as e:\n",
        "            print(f\"[WARN] search lỗi repo={repo}, field={date_field}, term={term}: {e}\")\n",
        "            continue\n",
        "\n",
        "        for it in items:\n",
        "            if it.get(\"pull_request\"):\n",
        "                continue\n",
        "            num = it.get(\"number\")\n",
        "            if not num:\n",
        "                continue\n",
        "            old = repo_items.get(num)\n",
        "            if old is None or issue_score(it) > issue_score(old):\n",
        "                repo_items[num] = it\n",
        "\n",
        "        if len(repo_items) >= MAX_ISSUES_PER_REPO:\n",
        "            break\n",
        "\n",
        "        time.sleep(0.10)\n",
        "\n",
        "    scored = sorted(repo_items.values(), key=issue_score, reverse=True)[:MAX_ISSUES_PER_REPO]\n",
        "    for it in scored:\n",
        "        all_candidates[(repo, it[\"number\"])] = it\n",
        "\n",
        "    print(f\"[{now()}] {repo}: unique candidates={len(repo_items)}, kept={len(scored)}\")\n",
        "\n",
        "# Nếu search vẫn rỗng, ghi manifest rồi dừng sạch, không KeyError.\n",
        "if not all_candidates:\n",
        "    print(\"\\n❌ Không có candidate nào. Khả năng cao token/network/query bị chặn.\")\n",
        "    empty_manifest = {\n",
        "        \"created_at\": datetime.now(timezone.utc).isoformat(),\n",
        "        \"repos\": REPOS,\n",
        "        \"start_date\": START_DATE,\n",
        "        \"end_date\": END_DATE,\n",
        "        \"records_total\": 0,\n",
        "        \"hint\": \"Probe total_count cũng nên được kiểm tra ở log trên. Nếu probe=0 cho cả hai repo, thử đổi START_DATE=2021-01-01 hoặc kiểm tra token/network.\"\n",
        "    }\n",
        "    (OUT_DIR / \"manifest.json\").write_text(json.dumps(empty_manifest, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n",
        "    print(json.dumps(empty_manifest, ensure_ascii=False, indent=2))\n",
        "else:\n",
        "    # ========== STAGE 2: FETCH FULL ISSUE + COMMENTS ==========\n",
        "    selected = []\n",
        "    for repo in REPOS:\n",
        "        xs = [it for (r, n), it in all_candidates.items() if r == repo]\n",
        "        xs = sorted(xs, key=issue_score, reverse=True)[:FETCH_COMMENTS_TOP_PER_REPO]\n",
        "        selected.extend([(repo, it[\"number\"], it) for it in xs])\n",
        "\n",
        "    print(f\"\\n[{now()}] Fetch full issue/comments for {len(selected)} issues...\")\n",
        "\n",
        "    full_issues = {}\n",
        "    comments_map = {}\n",
        "\n",
        "    def fetch_one(task):\n",
        "        repo, num, fallback = task\n",
        "        try:\n",
        "            issue, comments = fetch_issue_and_comments(repo, num)\n",
        "            return repo, num, issue, comments, None\n",
        "        except Exception as e:\n",
        "            return repo, num, fallback, [], str(e)\n",
        "\n",
        "    workers = MAX_WORKERS if TOKEN else 1\n",
        "    with ThreadPoolExecutor(max_workers=workers) as ex:\n",
        "        futs = [ex.submit(fetch_one, t) for t in selected]\n",
        "        for fut in tqdm(as_completed(futs), total=len(futs), desc=\"full+comments\"):\n",
        "            repo, num, issue, comments, err = fut.result()\n",
        "            if err:\n",
        "                print(f\"[WARN] fetch lỗi {repo}#{num}: {err}\")\n",
        "            full_issues[(repo, num)] = issue\n",
        "            comments_map[(repo, num)] = comments\n",
        "\n",
        "    # ========== STAGE 3: EXTRACT RECORDS ==========\n",
        "    records = []\n",
        "    seen = set()\n",
        "    issue_rows = []\n",
        "\n",
        "    print(f\"\\n[{now()}] Extract code blocks...\")\n",
        "    for (repo, num), issue in tqdm(full_issues.items(), desc=\"extract\"):\n",
        "        fw = framework_of(repo)\n",
        "        labels = label_names(issue)\n",
        "        iscore = issue_score(issue)\n",
        "\n",
        "        issue_rows.append({\n",
        "            \"repo\": repo,\n",
        "            \"framework\": fw,\n",
        "            \"number\": num,\n",
        "            \"title\": issue.get(\"title\"),\n",
        "            \"url\": issue.get(\"html_url\"),\n",
        "            \"state\": issue.get(\"state\"),\n",
        "            \"created_at\": issue.get(\"created_at\"),\n",
        "            \"updated_at\": issue.get(\"updated_at\"),\n",
        "            \"comments\": issue.get(\"comments\"),\n",
        "            \"labels\": \"|\".join(labels),\n",
        "            \"issue_score\": iscore,\n",
        "        })\n",
        "\n",
        "        bodies = [(\"issue_body\", 0, safe_text(issue.get(\"body\")))]\n",
        "        for i, c in enumerate(comments_map.get((repo, num), [])):\n",
        "            bodies.append((\"comment\", i, safe_text(c.get(\"body\"))))\n",
        "\n",
        "        for source_kind, source_index, md in bodies:\n",
        "            for lang, code in extract_code_blocks(md):\n",
        "                rec = make_record(repo, issue, source_kind, source_index, md, lang, code)\n",
        "                if not rec:\n",
        "                    continue\n",
        "                key = (rec[\"framework\"], rec[\"code_sha1\"])\n",
        "                if key in seen:\n",
        "                    continue\n",
        "                seen.add(key)\n",
        "                records.append(rec)\n",
        "\n",
        "    records = sorted(records, key=lambda r: r[\"quality_score\"], reverse=True)\n",
        "\n",
        "    # ========== SPLIT ==========\n",
        "    random.seed(1337)\n",
        "    shuffled = records[:]\n",
        "    random.shuffle(shuffled)\n",
        "    n = len(shuffled)\n",
        "    n_val = max(1, int(n * 0.05)) if n else 0\n",
        "    n_test = max(1, int(n * 0.05)) if n else 0\n",
        "\n",
        "    val = shuffled[:n_val]\n",
        "    test = shuffled[n_val:n_val+n_test]\n",
        "    train = shuffled[n_val+n_test:]\n",
        "\n",
        "    # ========== WRITE ==========\n",
        "    dataset_path = OUT_DIR / \"fuzzgpt_style_pytorch_tensorflow_issues_v2.jsonl\"\n",
        "    train_path = OUT_DIR / \"train.jsonl\"\n",
        "    val_path = OUT_DIR / \"val.jsonl\"\n",
        "    test_path = OUT_DIR / \"test.jsonl\"\n",
        "    issues_csv = OUT_DIR / \"candidate_issues.csv\"\n",
        "    manifest_path = OUT_DIR / \"manifest.json\"\n",
        "\n",
        "    write_jsonl(dataset_path, records)\n",
        "    write_jsonl(train_path, train)\n",
        "    write_jsonl(val_path, val)\n",
        "    write_jsonl(test_path, test)\n",
        "\n",
        "    if issue_rows:\n",
        "        pd.DataFrame(issue_rows).sort_values(\"issue_score\", ascending=False).to_csv(issues_csv, index=False)\n",
        "    else:\n",
        "        pd.DataFrame(columns=[\n",
        "            \"repo\", \"framework\", \"number\", \"title\", \"url\", \"state\",\n",
        "            \"created_at\", \"updated_at\", \"comments\", \"labels\", \"issue_score\"\n",
        "        ]).to_csv(issues_csv, index=False)\n",
        "\n",
        "    by_fw = pd.Series([r[\"framework\"] for r in records]).value_counts().to_dict() if records else {}\n",
        "    by_oracle = {}\n",
        "    for r in records:\n",
        "        for o in r[\"oracle_type\"]:\n",
        "            by_oracle[o] = by_oracle.get(o, 0) + 1\n",
        "\n",
        "    stats = {\n",
        "        \"created_at\": datetime.now(timezone.utc).isoformat(),\n",
        "        \"repos\": REPOS,\n",
        "        \"start_date\": START_DATE,\n",
        "        \"end_date\": END_DATE,\n",
        "        \"date_fields\": DATE_FIELDS,\n",
        "        \"terms\": TERMS,\n",
        "        \"candidate_issues\": len(full_issues),\n",
        "        \"records_total\": len(records),\n",
        "        \"train\": len(train),\n",
        "        \"val\": len(val),\n",
        "        \"test\": len(test),\n",
        "        \"by_framework\": by_fw,\n",
        "        \"by_oracle_type\": by_oracle,\n",
        "        \"avg_quality_score\": float(sum(r[\"quality_score\"] for r in records) / len(records)) if records else 0.0,\n",
        "        \"notes\": [\n",
        "            \"Public GitHub issues/comments only.\",\n",
        "            \"Records are SFT-style: instruction/input/output.\",\n",
        "            \"Use for internal research/training; verify licenses and redistribution policy before publishing.\",\n",
        "            \"Recommended next: execute snippets in sandbox and add valid_runtime/crash_signature fields.\"\n",
        "        ],\n",
        "    }\n",
        "    manifest_path.write_text(json.dumps(stats, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n",
        "\n",
        "    zip_path = Path(\"/content/dl_issue_fuzz_dataset_v2.zip\")\n",
        "    with zipfile.ZipFile(zip_path, \"w\", zipfile.ZIP_DEFLATED) as z:\n",
        "        for p in OUT_DIR.glob(\"*\"):\n",
        "            z.write(p, arcname=p.name)\n",
        "\n",
        "    print(\"\\n================ DONE ================\")\n",
        "    print(json.dumps(stats, ensure_ascii=False, indent=2))\n",
        "    print(f\"\\nDataset: {dataset_path}\")\n",
        "    print(f\"Zip:     {zip_path}\")\n",
        "\n",
        "    print(\"\\nTop 8 records:\")\n",
        "    for r in records[:8]:\n",
        "        print(\"-\" * 90)\n",
        "        print(f'{r[\"repo\"]}#{r[\"issue_number\"]} | score={r[\"quality_score\"]} | {r[\"issue_title\"][:130]}')\n",
        "        print(f'APIs: {\", \".join(r[\"apis\"][:15])}')\n",
        "        print(f'Oracle: {\", \".join(r[\"oracle_type\"])}')\n",
        "        print(f'URL: {r[\"url\"]}')\n",
        "        print(r[\"output\"][:900].replace(\"\\n\", \"\\n  \"))\n",
        "\n",
        "    try:\n",
        "        from google.colab import files\n",
        "        print(\"\\nĐang gọi download zip...\")\n",
        "        files.download(str(zip_path))\n",
        "    except Exception as e:\n",
        "        print(f\"Tải thủ công ở: {zip_path} | {e}\")"
      ],
