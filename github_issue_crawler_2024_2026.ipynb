        "res.close()\n",
        "'''\n",
        "\n",
        "def run_chunk(chunk, runner_path, env):\n",
        "    \"\"\"Chạy một lô trong tiến trình con; watchdog đo từ dòng tiến độ cuối cùng.\"\"\"\n",
        "    results, remaining, attempts = {}, list(chunk), 0\n",
        "    while remaining and attempts <= len(chunk) + 3:\n",
        "        attempts += 1\n",
        "        n_before = len(results)\n",
        "        sandbox = tempfile.mkdtemp(prefix=\"calm_smoke_\")\n",
        "        sp, rp = Path(sandbox, \"in.jsonl\"), Path(sandbox, \"out.jsonl\")\n",
        "        sp.write_text(\"\".join(json.dumps({\"id\": s[\"id\"], \"code\": s[\"output\"]}) + \"\\n\"\n",
        "                              for s in remaining), encoding=\"utf-8\")\n",
        "        rp.touch()\n",
        "        proc = subprocess.Popen([sys.executable, runner_path, str(sp), str(rp)],\n",
        "                                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,\n",
        "                                cwd=sandbox, env=env)\n",
        "        inflight, killed, last, n_seen = None, False, time.time(), 0\n",
        "        while True:\n",
        "            time.sleep(0.25)\n",
        "            txt = rp.read_text(encoding=\"utf-8\", errors=\"replace\")\n",
        "            lines = txt.splitlines()\n",
        "            if txt and not txt.endswith(\"\\n\"):\n",
        "                lines = lines[:-1]                            # bỏ dòng đang ghi dở\n",
        "            if len(lines) > n_seen:\n",
        "                for l in lines[n_seen:]:\n",
        "                    ev = json.loads(l)\n",
        "                    if ev[\"ev\"] == \"b\":\n",
        "                        inflight = ev[\"id\"]\n",
        "                    else:\n",
        "                        results[ev[\"id\"]] = ev[\"st\"]; inflight = None\n",
        "                n_seen, last = len(lines), time.time()\n",
        "            if proc.poll() is not None:\n",
        "                if inflight is not None:                      # chết giữa chừng một mẫu\n",
        "                    results[inflight] = \"timeout\" if killed else \"native_crash\"\n",
        "                break\n",
        "            if time.time() - last > CFG2[\"per_sample_timeout\"]:\n",
        "                killed = True; proc.kill()\n",
        "        shutil.rmtree(sandbox, ignore_errors=True)\n",
        "        remaining = [s for s in remaining if s[\"id\"] not in results]\n",
        "        if len(results) == n_before and not killed:\n",
        "            break  # runner tự chết mà không ghi được gì → hỏng hệ thống, đừng thử lại\n",
        "    for s in remaining:                                       # hết lượt thử\n",
        "        results[s[\"id\"]] = \"runner_giveup\"\n",
        "    return results\n",
        "\n",
        "def smoke_validate(all_samples):\n",
        "    have = {fw for fw, mod in ((\"pytorch\", \"torch\"), (\"tensorflow\", \"tensorflow\"))\n",
