        "import ast, hashlib, importlib.util, json, os, shutil, subprocess, sys, tempfile, time\n",
        "from collections import Counter\n",
        "from datetime import datetime, timezone\n",
        "from pathlib import Path\n",
        "\n",
        "try:\n",
        "    sys.stdout.reconfigure(encoding=\"utf-8\")\n",
        "except Exception:\n",
        "    pass\n",
        "\n",
        "CFG2 = {\n",
        "    \"in_dir_name\": \"gemma4_sft_out\",\n",
        "    \"out_dir_name\": \"gemma4_sft_final\",\n",
        "    \"search_dirs\": [\".\", r\"C:\\Users\\fagon\\Loxi\\th6\\11\", \"/content\", \"/content/drive/MyDrive\"],\n",
        "    \"smoke_run\": True,\n",
        "    \"per_sample_timeout\": 12,   # giây; mỗi mẫu được tối đa chừng này kể từ BEGIN\n",
        "    \"chunk_size\": 20,           # mẫu/tiến trình con (import torch/tf chỉ ấm 1 lần/lô)\n",
        "    \"workers\": 3,               # số lô chạy song song\n",
        "    \"synth_per_template\": 20,   # 9 template × 20 = 180 mẫu vàng (~8% train)\n",
        "    \"seed_salt\": \"calm_sft_v2_20260611\",\n",
        "}\n",
        "DROP_ETYPES = {\"ModuleNotFoundError\", \"ImportError\", \"FileNotFoundError\", \"NameError\",\n",
        "               \"UnboundLocalError\", \"SyntaxError\", \"IndentationError\", \"EOFError\",\n",
        "               \"AttributeError\", \"IsADirectoryError\", \"PermissionError\"}\n",
        "\n",
        "h64 = lambda s: int.from_bytes(hashlib.sha1(s.encode(\"utf-8\", \"ignore\")).digest()[:8], \"big\")\n",
        "\n",
        "def find_in_dir():\n",
        "    for d in CFG2[\"search_dirs\"]:\n",
        "        p = Path(d) / CFG2[\"in_dir_name\"]\n",
        "        if (p / \"train.jsonl\").is_file():\n",
        "            return p.resolve()  # tuyệt đối — tiến trình con chạy với cwd=sandbox\n",
        "    raise SystemExit(\"Không thấy gemma4_sft_out/ — chạy cell 1 trước đã.\")\n",
        "\n",
        "IN_DIR = find_in_dir()\n",
        "OUT_DIR = IN_DIR.parent / CFG2[\"out_dir_name\"]\n",
        "OUT_DIR.mkdir(exist_ok=True)\n",
        "load = lambda n: [json.loads(l) for l in open(IN_DIR / n, encoding=\"utf-8\") if l.strip()]\n",
        "splits = {k: load(f\"{k}.jsonl\") for k in (\"train\", \"val\", \"test\")}\n",
        "print(f\"Cell 1 → train {len(splits['train'])} / val {len(splits['val'])} / test {len(splits['test'])} (từ {IN_DIR})\")\n",
        "\n",
        "# ═════ 1) SMOKE-RUN ngoài tiến trình, theo lô, có watchdog ═══════════════════\n",
        "RUNNER = r'''\n",
        "import json, io, os, sys, contextlib\n",
        "samples_path, results_path = sys.argv[1], sys.argv[2]\n",
        "res = open(results_path, \"a\", encoding=\"utf-8\", buffering=1)\n",
        "def emit(obj):\n",
        "    res.write(json.dumps(obj) + \"\\n\"); res.flush()\n",
        "    try: os.fsync(res.fileno())\n",
        "    except OSError: pass\n",
        "import builtins\n",
        "builtins.input = lambda *a, **k: (_ for _ in ()).throw(EOFError(\"stdin disabled\"))\n",
        "for line in open(samples_path, encoding=\"utf-8\"):\n",
        "    s = json.loads(line)\n",
        "    emit({\"ev\": \"b\", \"id\": s[\"id\"]})\n",
        "    status = \"ok\"\n",
        "    try:\n",
        "        ns = {\"__name__\": \"__main__\"}\n",
        "        with contextlib.redirect_stdout(io.StringIO()), contextlib.redirect_stderr(io.StringIO()):\n",
        "            exec(compile(s[\"code\"], \"<seed>\", \"exec\"), ns)\n",
        "    except SystemExit as e:\n",
        "        status = \"ok\" if not e.code else \"raise:SystemExit\"\n",
        "    except BaseException as e:\n",
        "        status = \"raise:\" + type(e).__name__\n",
        "    emit({\"ev\": \"e\", \"id\": s[\"id\"], \"st\": status})\n",
        "res.close()\n",
        "'''\n",
        "\n",
        "def run_chunk(chunk, runner_path, env):\n",
        "    \"\"\"Chạy một lô trong tiến trình con; watchdog đo từ dòng tiến độ cuối cùng.\"\"\"\n",
        "    results, remaining, attempts = {}, list(chunk), 0\n",
        "    while remaining and attempts <= len(chunk) + 3:\n",
        "        attempts += 1\n",
        "        n_before = len(results)\n",
        "        sandbox = tempfile.mkdtemp(prefix=\"calm_smoke_\")\n",
        "        sp, rp = Path(sandbox, \"in.jsonl\"), Path(sandbox, \"out.jsonl\")\n",
        "        sp.write_text(\"\".join(json.dumps({\"id\": s[\"id\"], \"code\": s[\"output\"]}) + \"\\n\"\n",
        "                              for s in remaining), encoding=\"utf-8\")\n",
        "        rp.touch()\n",
        "        proc = subprocess.Popen([sys.executable, runner_path, str(sp), str(rp)],\n",
        "                                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,\n",
        "                                cwd=sandbox, env=env)\n",
        "        inflight, killed, last, n_seen = None, False, time.time(), 0\n",
        "        while True:\n",
        "            time.sleep(0.25)\n",
        "            txt = rp.read_text(encoding=\"utf-8\", errors=\"replace\")\n",
        "            lines = txt.splitlines()\n",
        "            if txt and not txt.endswith(\"\\n\"):\n",
        "                lines = lines[:-1]                            # bỏ dòng đang ghi dở\n",
        "            if len(lines) > n_seen:\n",
        "                for l in lines[n_seen:]:\n",
        "                    ev = json.loads(l)\n",
        "                    if ev[\"ev\"] == \"b\":\n",
        "                        inflight = ev[\"id\"]\n",
        "                    else:\n",
        "                        results[ev[\"id\"]] = ev[\"st\"]; inflight = None\n",
        "                n_seen, last = len(lines), time.time()\n",
        "            if proc.poll() is not None:\n",
        "                if inflight is not None:                      # chết giữa chừng một mẫu\n",
        "                    results[inflight] = \"timeout\" if killed else \"native_crash\"\n",
        "                break\n",
        "            if time.time() - last > CFG2[\"per_sample_timeout\"]:\n",
        "                killed = True; proc.kill()\n",
        "        shutil.rmtree(sandbox, ignore_errors=True)\n",
        "        remaining = [s for s in remaining if s[\"id\"] not in results]\n",
        "        if len(results) == n_before and not killed:\n",
        "            break  # runner tự chết mà không ghi được gì → hỏng hệ thống, đừng thử lại\n",
        "    for s in remaining:                                       # hết lượt thử\n",
        "        results[s[\"id\"]] = \"runner_giveup\"\n",
        "    return results\n",
        "\n",
        "def smoke_validate(all_samples):\n",
        "    have = {fw for fw, mod in ((\"pytorch\", \"torch\"), (\"tensorflow\", \"tensorflow\"))\n",
        "            if importlib.util.find_spec(mod)}\n",
        "    todo = [s for s in all_samples if s[\"framework\"] in have]\n",
        "    skipped = [s for s in all_samples if s[\"framework\"] not in have]\n",
        "    status = {s[\"id\"]: \"unvalidated\" for s in skipped}\n",
        "    runner_path = str(OUT_DIR / \"_smoke_runner.py\")\n",
        "    Path(runner_path).write_text(RUNNER, encoding=\"utf-8\")\n",
        "    env = dict(os.environ, MPLBACKEND=\"Agg\", TF_CPP_MIN_LOG_LEVEL=\"3\",\n",
        "               TORCHDYNAMO_DISABLE=\"1\", TORCH_COMPILE_DISABLE=\"1\",\n",
        "               HF_HUB_OFFLINE=\"1\", TRANSFORMERS_OFFLINE=\"1\", PYTHONIOENCODING=\"utf-8\",\n",
        "               CUDA_VISIBLE_DEVICES=os.environ.get(\"CUDA_VISIBLE_DEVICES\", \"0\"))\n",
        "    if not have:  # máy không có torch/TF → chứng minh bộ máy bằng self-test rồi thôi\n",
        "        print(\"⚠ torch/tensorflow chưa cài ở máy này → bỏ qua smoke-run (Colab sẽ chạy đủ).\")\n",
        "        demo = [{\"id\": \"t_ok\", \"framework\": \"x\", \"output\": \"print(1+1)\"},\n",
        "                {\"id\": \"t_raise\", \"framework\": \"x\", \"output\": \"raise ValueError('boom')\"},\n",
        "                {\"id\": \"t_hang\", \"framework\": \"x\", \"output\": \"import time\\nwhile True: time.sleep(1)\"}]\n",
        "        old = CFG2[\"per_sample_timeout\"]; CFG2[\"per_sample_timeout\"] = 4\n",
        "        got = run_chunk(demo, runner_path, env); CFG2[\"per_sample_timeout\"] = old\n",
        "        assert got[\"t_ok\"] == \"ok\" and got[\"t_raise\"] == \"raise:ValueError\" \\\n",
        "               and got[\"t_hang\"] == \"timeout\", got\n",
        "        print(\"  self-test bộ máy watchdog: ok / raise / timeout phân loại đúng ✓\")\n",
        "        return status\n",
        "    print(f\"Smoke-run {len(todo)} mẫu ({', '.join(sorted(have))}), \"\n",
        "          f\"lô {CFG2['chunk_size']}, {CFG2['workers']} luồng, timeout {CFG2['per_sample_timeout']}s/mẫu…\")\n",
        "    chunks = [todo[i:i + CFG2[\"chunk_size\"]] for i in range(0, len(todo), CFG2[\"chunk_size\"])]\n",
        "    from concurrent.futures import ThreadPoolExecutor\n",
        "    t0, done_n = time.time(), 0\n",
        "    with ThreadPoolExecutor(CFG2[\"workers\"]) as ex:\n",
        "        for got in ex.map(lambda c: run_chunk(c, runner_path, env), chunks):\n",
        "            status.update(got); done_n += len(got)\n",
        "            if done_n % 200 < CFG2[\"chunk_size\"]:\n",
        "                print(f\"  …{done_n}/{len(todo)} ({time.time()-t0:.0f}s)\")\n",
        "    return status\n",
        "\n",
        "def verdict(st):\n",
        "    if st in (\"ok\", \"native_crash\", \"unvalidated\", \"runner_giveup\"):\n",
        "        return \"keep\"\n",
        "    if st == \"timeout\":\n",
        "        return \"drop\"\n",
        "    if st.startswith(\"raise:\"):\n",
        "        return \"drop\" if st.split(\":\", 1)[1] in DROP_ETYPES else \"keep\"\n",
        "    return \"keep\"\n",
        "\n",
        "all_real = [s for k in splits for s in splits[k]]\n",
        "run_status = smoke_validate(all_real) if CFG2[\"smoke_run\"] else {s[\"id\"]: \"unvalidated\" for s in all_real}\n",
        "st_count = Counter(run_status.values())\n",
