        "            }\n",
        "        )\n",
        "\n",
        "        raw_len = len(raw)\n",
        "        if raw_len == 0:\n",
        "            break\n",
        "\n",
        "        issues_only = [x for x in raw if \"pull_request\" not in x]\n",
        "        repo_items.extend(issues_only)\n",
        "\n",
        "        print(\n",
        "            f\"[{now()}] {repo} page={page} raw={raw_len} \"\n",
