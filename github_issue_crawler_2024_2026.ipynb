        "        fw=\"PyTorch\" if fw == \"pytorch\" else \"TensorFlow\")\n",
        "    apis = [a for a in r.get(\"apis\", []) if isinstance(a, str)][:12]\n",
        "    labels = [l for l in map(str, r.get(\"labels\", []))\n",
        "              if re.search(r\"module:|comp:|topic:|correctness|numerical|cuda|mps|rocm|amp|\"\n",
        "                           r\"linalg|type:bug|high priority\", l, re.I)][:4]\n",
        "    inp = \"\\n\".join(filter(None, [\n",
        "        f\"Framework: {fw}\",\n",
        "        f\"Focus: {FOCUS_LINE[axis]}\",\n",
        "        f\"Issue: {str(r.get('issue_title', '')).strip()[:200]}\",\n",
        "        f\"Labels: {', '.join(labels)}\" if labels else \"\",\n",
        "        f\"APIs: {', '.join(apis)}\" if apis else \"\",\n",
