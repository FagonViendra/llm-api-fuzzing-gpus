        "    era = \"2024_2026\" if str(r.get(\"created_at\", \"\"))[:4] >= \"2024\" else \"2021_2023\"\n",
        "\n",
        "    # — dựng lại prompt có cấu trúc + đa dạng hoá tất định theo id —\n",
        "    rid = r.get(\"id\", r.get(\"code_sha1\", \"\"))\n",
