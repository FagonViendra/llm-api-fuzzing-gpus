        "]\n",
        "\n",
        "\n",
        "# =========================\n",
        "# Helpers\n",
        "# =========================\n",
        "\n",
        "def now():\n",
        "    return datetime.now().strftime(\"%H:%M:%S\")\n",
        "\n",
        "\n",
        "def sha1_text(text):\n",
        "    return hashlib.sha1((text or \"\").encode(\"utf-8\", errors=\"ignore\")).hexdigest()\n",
        "\n",
        "\n",
        "def read_jsonl(path):\n",
        "    rows = []\n",
        "    p = Path(path)\n",
        "    if not p.exists():\n",
        "        return rows\n",
        "    with p.open(\"r\", encoding=\"utf-8\", errors=\"ignore\") as f:\n",
        "        for line in f:\n",
        "            line = line.strip()\n",
        "            if line:\n",
        "                rows.append(json.loads(line))\n",
        "    return rows\n",
        "\n",
        "\n",
        "def write_jsonl(path, rows):\n",
        "    path = Path(path)\n",
        "    path.parent.mkdir(parents=True, exist_ok=True)\n",
        "    with path.open(\"w\", encoding=\"utf-8\") as f:\n",
        "        for row in rows:\n",
        "            f.write(json.dumps(row, ensure_ascii=False) + \"\\n\")\n",
        "\n",
        "\n",
        "def append_jsonl(path, row):\n",
        "    path = Path(path)\n",
        "    path.parent.mkdir(parents=True, exist_ok=True)\n",
        "    with path.open(\"a\", encoding=\"utf-8\") as f:\n",
        "        f.write(json.dumps(row, ensure_ascii=False) + \"\\n\")\n",
        "\n",
        "\n",
        "def labels(issue):\n",
        "    vals = issue.get(\"labels\") or []\n",
        "    out = []\n",
        "    for x in vals:\n",
        "        if isinstance(x, dict):\n",
        "            out.append(x.get(\"name\", \"\"))\n",
        "        elif isinstance(x, str):\n",
        "            out.append(x)\n",
        "    return [x for x in out if x]\n",
        "\n",
        "\n",
        "def issue_url(issue):\n",
        "    return issue.get(\"html_url\") or issue.get(\"url\") or \"\"\n",
        "\n",
        "\n",
        "def normalize_issue(repo, issue):\n",
        "    return {\n",
        "        \"repo\": repo,\n",
        "        \"number\": issue.get(\"number\"),\n",
        "        \"title\": issue.get(\"title\") or \"\",\n",
        "        \"url\": issue_url(issue),\n",
        "        \"state\": issue.get(\"state\"),\n",
        "        \"created_at\": issue.get(\"created_at\"),\n",
        "        \"updated_at\": issue.get(\"updated_at\"),\n",
        "        \"comments\": int(issue.get(\"comments\") or 0),\n",
        "        \"labels\": labels(issue),\n",
        "        \"body\": issue.get(\"body\") or \"\",\n",
        "    }\n",
        "\n",
        "\n",
        "def code_blocks(markdown):\n",
        "    markdown = markdown or \"\"\n",
        "    blocks = []\n",
        "    for m in re.finditer(r\"```[ \\t]*([A-Za-z0-9_+\\-\\.]*)?[ \\t]*\\n(.*?)```\", markdown, re.S):\n",
        "        lang = (m.group(1) or \"\").strip().lower()\n",
        "        raw = m.group(2) or \"\"\n",
        "        blocks.append((lang, raw))\n",
        "    return blocks\n",
        "\n",
        "\n",
        "def apis_in_text(text, fw):\n",
        "    found = set()\n",
        "    for pat in API_REGEX[fw]:\n",
        "        for m in re.finditer(pat, text or \"\"):\n",
        "            x = m.group(0)\n",
        "            if len(x) < 180:\n",
        "                found.add(x.replace(\"tensorflow.\", \"tf.\"))\n",
        "    return sorted(found)\n",
        "\n",
        "\n",
        "def clean_code(raw):\n",
        "    code = (raw or \"\").replace(\"\\r\\n\", \"\\n\").replace(\"\\r\", \"\\n\")\n",
        "    lines = []\n",
        "    for line in code.splitlines():\n",
        "        line = re.sub(r\"^\\s*(>>>|\\.\\.\\.)\\s?\", \"\", line)\n",
        "        lines.append(line.rstrip())\n",
        "    code = \"\\n\".join(lines).strip()\n",
        "    return code[:MAX_CODE_CHARS]\n",
        "\n",
        "\n",
        "def ast_parse_ok(code):\n",
        "    try:\n",
        "        ast.parse(code)\n",
        "        return True\n",
        "    except Exception:\n",
        "        return False\n",
        "\n",
        "\n",
        "def looks_like_log_or_env(code):\n",
        "    text = code or \"\"\n",
        "    if any(p in text for p in LOG_OR_ENV_PATTERNS):\n",
        "        return True\n",
        "    stripped = text.strip()\n",
        "    if re.match(r\"^(RuntimeError|ValueError|TypeError|AssertionError|InternalError):\", stripped):\n",
        "        return True\n",
        "    return False\n",
        "\n",
        "\n",
        "def issue_score(issue, fw):\n",
        "    title = issue.get(\"title\") or \"\"\n",
        "    body = issue.get(\"body\") or \"\"\n",
        "    labs = \" \".join(labels(issue)).lower()\n",
        "    text = (title + \"\\n\" + body + \"\\n\" + labs).lower()\n",
        "    score = 0\n",
        "    score += min(9, sum(1 for t in BUG_TERMS if t in text))\n",
        "    if any(x in labs for x in [\"bug\", \"type:bug\", \"type: bug\", \"regression\", \"module:\", \"comp:\", \"triaged\"]):\n",
        "        score += 6\n",
        "    if code_blocks(body):\n",
        "        score += 6\n",
        "    if fw == \"pytorch\" and (\"torch.\" in body or \"import torch\" in body or \"from torch\" in body):\n",
        "        score += 5\n",
        "    if fw == \"tensorflow\" and (\"tf.\" in body or \"tensorflow\" in body or \"keras\" in body):\n",
        "        score += 5\n",
        "    score += min(4, int(issue.get(\"comments\") or 0) // 5)\n",
        "    return score\n",
        "\n",
        "\n",
        "def record_from_block(repo, issue, source, idx, lang, raw):\n",
        "    fw = FRAMEWORK_HINT[repo]\n",
        "    code = clean_code(raw)\n",
        "    if len(code) < MIN_CODE_CHARS:\n",
        "        return None\n",
        "\n",
        "    api_list = apis_in_text(code, fw)\n",
        "    if not api_list:\n",
        "        return None\n",
        "\n",
        "    if fw == \"pytorch\" and not re.search(r\"\\b(torch\\.|import torch|from torch|torchvision\\.|functorch\\.)\", code):\n",
        "        return None\n",
        "    if fw == \"tensorflow\" and not re.search(\n",
        "        r\"\\b(tf\\.|tensorflow\\.|keras\\.|import tensorflow|from tensorflow|import keras)\",\n",
        "        code,\n",
        "    ):\n",
        "        return None\n",
        "\n",
        "    parsed = ast_parse_ok(code)\n",
        "    if STRICT_PYTHON_AST and not parsed:\n",
        "        return None\n",
        "    if looks_like_log_or_env(code):\n",
        "        return None\n",
        "\n",
        "    ctx = ((issue.get(\"title\") or \"\") + \"\\n\" + (issue.get(\"body\") or \"\")).lower()\n",
        "    score = 6 + min(10, len(api_list))\n",
        "    score += min(9, sum(1 for t in BUG_TERMS if t in (ctx + \"\\n\" + code.lower())))\n",
        "    score += 4 if parsed else -1\n",
        "    score += 4 if code_blocks(issue.get(\"body\") or \"\") else 0\n",
        "    score += min(3, int(issue.get(\"comments\") or 0) // 10)\n",
        "\n",
        "    if score < 10:\n",
        "        return None\n",
        "\n",
        "    h = sha1_text(code)\n",
        "    return {\n",
        "        \"id\": f\"{repo}#{issue.get('number')}:{source}:{idx}:{h[:12]}\",\n",
        "        \"framework\": fw,\n",
        "        \"repo\": repo,\n",
        "        \"issue_number\": issue.get(\"number\"),\n",
        "        \"issue_title\": issue.get(\"title\"),\n",
        "        \"url\": issue_url(issue),\n",
        "        \"created_at\": issue.get(\"created_at\"),\n",
        "        \"updated_at\": issue.get(\"updated_at\"),\n",
        "        \"labels\": labels(issue),\n",
        "        \"apis\": api_list,\n",
        "        \"quality_score\": score,\n",
        "        \"source\": source,\n",
        "        \"markdown_lang\": lang,\n",
        "        \"code_sha1\": h,\n",
        "        \"ast_parse_ok\": parsed,\n",
        "        \"instruction\": \"Generate or mutate a minimal Python fuzzing/reproducer seed for PyTorch/TensorFlow bug discovery.\",\n",
        "        \"input\": (\n",
        "            f\"Framework: {fw}\\n\"\n",
        "            f\"Issue: {issue.get('title')}\\n\"\n",
        "            f\"APIs: {', '.join(api_list[:20])}\\n\"\n",
        "            f\"URL: {issue_url(issue)}\"\n",
        "        ),\n",
        "        \"output\": code,\n",
        "    }\n",
        "\n",
        "\n",
        "def month_ranges(start=\"2021-01-01\", end=\"2023-12-31\"):\n",
        "    s = datetime.strptime(start, \"%Y-%m-%d\").date()\n",
        "    e = datetime.strptime(end, \"%Y-%m-%d\").date()\n",
        "    out = []\n",
        "    cur = date(s.year, s.month, 1)\n",
        "    while cur <= e:\n",
        "        nxt = date(cur.year + 1, 1, 1) if cur.month == 12 else date(cur.year, cur.month + 1, 1)\n",
        "        last = min(e, nxt - timedelta(days=1))\n",
        "        out.append((cur.isoformat(), last.isoformat()))\n",
        "        cur = nxt\n",
        "    return out\n",
        "\n",
        "\n",
        "def split_date_range(start_s, end_s):\n",
        "    s = datetime.strptime(start_s, \"%Y-%m-%d\").date()\n",
        "    e = datetime.strptime(end_s, \"%Y-%m-%d\").date()\n",
        "    if s >= e:\n",
        "        return None\n",
        "    mid = s + (e - s) // 2\n",
        "    return (s.isoformat(), mid.isoformat()), ((mid + timedelta(days=1)).isoformat(), e.isoformat())\n",
        "\n",
        "\n",
        "def find_or_upload_rescue_zip():\n",
        "    global RESCUE_ZIP\n",
        "    if RESCUE_ZIP.exists():\n",
        "        return RESCUE_ZIP\n",
        "\n",
        "    candidates = sorted(Path(\"/content\").glob(\"*rescue*2021*2023*.zip\"))\n",
        "    if candidates:\n",
        "        RESCUE_ZIP = candidates[0]\n",
        "        return RESCUE_ZIP\n",
        "\n",
        "    print(\"rescue_2021_2023_partial.zip not found in /content. Upload it now.\")\n",
        "    try:\n",
        "        from google.colab import files\n",
        "\n",
        "        files.upload()\n",
        "    except Exception as exc:\n",
        "        raise FileNotFoundError(\"Could not open Colab upload widget. Upload the rescue zip to /content first.\") from exc\n",
        "\n",
        "    candidates = sorted(Path(\"/content\").glob(\"*rescue*2021*2023*.zip\"))\n",
        "    if not candidates:\n",
        "        raise FileNotFoundError(\"No rescue_2021_2023_partial.zip found after upload.\")\n",
        "    RESCUE_ZIP = candidates[0]\n",
        "    return RESCUE_ZIP\n",
        "\n",
        "\n",
        "def load_rescue_candidates(zip_path):\n",
        "    rows = []\n",
        "    with zipfile.ZipFile(zip_path) as z:\n",
        "        name = None\n",
        "        for n in z.namelist():\n",
        "            if n.endswith(\".jsonl\") and \"partial_candidates\" in n:\n",
        "                name = n\n",
        "                break\n",
        "        if not name:\n",
        "            raise FileNotFoundError(\"partial_candidates_2021_2023.jsonl not found inside rescue zip.\")\n",
        "        for line in z.read(name).decode(\"utf-8\", errors=\"replace\").splitlines():\n",
        "            if not line.strip():\n",
        "                continue\n",
        "            row = json.loads(line)\n",
        "            repo = row.get(\"repo\")\n",
        "            if repo in FRAMEWORK_HINT:\n",
        "                rows.append(normalize_issue(repo, row))\n",
        "    return rows\n",
        "\n",
        "\n",
        "def load_existing_fast_records():\n",
        "    if not FAST_ZIP.exists():\n",
        "        candidates = sorted(Path(\"/content\").glob(\"*dl_issue_fuzz_dataset_fast*.zip\"))\n",
        "        if candidates:\n",
        "            fast_zip = candidates[0]\n",
        "        else:\n",
        "            return []\n",
        "    else:\n",
        "        fast_zip = FAST_ZIP\n",
        "\n",
        "    try:\n",
        "        with zipfile.ZipFile(fast_zip) as z:\n",
        "            if \"all.jsonl\" not in z.namelist():\n",
        "                return []\n",
        "            rows = []\n",
        "            for line in z.read(\"all.jsonl\").decode(\"utf-8\", errors=\"replace\").splitlines():\n",
        "                if line.strip():\n",
        "                    rows.append(json.loads(line))\n",
        "            return rows\n",
        "    except Exception as exc:\n",
        "        print(f\"[WARN] Could not read {fast_zip}: {exc}\")\n",
        "        return []\n",
        "\n",
        "\n",
        "def save_candidate_checkpoint(candidates, path):\n",
        "    rows = list(candidates.values())\n",
        "    rows.sort(key=lambda x: (x.get(\"repo\") or \"\", int(x.get(\"number\") or 0)))\n",
        "    write_jsonl(path, rows)\n",
        "\n",
        "\n",
        "# =========================\n",
        "# GitHub API client\n",
        "# =========================\n",
        "\n",
        "TOKEN = os.environ.get(\"GITHUB_TOKEN\", \"\").strip()\n",
        "try:\n",
        "    from google.colab import userdata\n",
        "\n",
        "    TOKEN = TOKEN or (userdata.get(\"GITHUB_TOKEN\") or \"\").strip()\n",
        "except Exception:\n",
        "    pass\n",
        "\n",
        "if not TOKEN:\n",
        "    print(\"GITHUB_TOKEN not found. Public unauthenticated crawling is very slow.\")\n",
        "    TOKEN = getpass.getpass(\"Paste a GitHub token, or press Enter to continue unauthenticated: \").strip()\n",
        "\n",
        "HEADERS = {\n",
        "    \"Accept\": \"application/vnd.github+json\",\n",
        "    \"X-GitHub-Api-Version\": \"2022-11-28\",\n",
        "    \"User-Agent\": \"gemma-fuzz-dataset-rescue-crawler\",\n",
        "}\n",
        "if TOKEN:\n",
        "    HEADERS[\"Authorization\"] = f\"Bearer {TOKEN}\"\n",
        "\n",
        "S = requests.Session()\n",
        "API = \"https://api.github.com\"\n",
        "\n",
        "PACE_LOCK = threading.Lock()\n",
        "LAST_CALL = {\"search\": 0.0, \"core\": 0.0}\n",
        "SEARCH_INTERVAL = SEARCH_INTERVAL_AUTH if TOKEN else SEARCH_INTERVAL_NO_TOKEN\n",
        "CORE_INTERVAL = CORE_INTERVAL_AUTH if TOKEN else CORE_INTERVAL_NO_TOKEN\n",
        "\n",
        "\n",
        "def pace(bucket):\n",
        "    interval = SEARCH_INTERVAL if bucket == \"search\" else CORE_INTERVAL\n",
        "    with PACE_LOCK:\n",
        "        elapsed = time.time() - LAST_CALL[bucket]\n",
        "        if elapsed < interval:\n",
        "            time.sleep(interval - elapsed)\n",
        "        LAST_CALL[bucket] = time.time()\n",
        "\n",
        "\n",
        "def wait_from_headers(headers, fallback=60):\n",
        "    retry_after = headers.get(\"retry-after\")\n",
        "    if retry_after:\n",
        "        try:\n",
        "            return int(retry_after) + 5\n",
        "        except ValueError:\n",
        "            pass\n",
        "    reset = headers.get(\"x-ratelimit-reset\")\n",
        "    remaining = headers.get(\"x-ratelimit-remaining\")\n",
        "    if remaining == \"0\" and reset:\n",
        "        try:\n",
        "            return max(20, int(reset) - int(time.time()) + 5)\n",
        "        except ValueError:\n",
        "            return fallback\n",
        "    return fallback\n",
        "\n",
        "\n",
        "def gh_get(path, params=None, bucket=\"core\", retries=8):\n",
        "    url = path if str(path).startswith(\"http\") else API + path\n",
        "    params = params or {}\n",
        "    for attempt in range(retries):\n",
        "        try:\n",
        "            pace(bucket)\n",
        "            resp = S.get(url, headers=HEADERS, params=params, timeout=45)\n",
        "        except requests.RequestException as exc:\n",
        "            wait = min(90, 8 + 6 * attempt + random.randint(0, 6))\n",
        "            print(f\"[{now()}] network error: {exc}; sleep {wait}s\")\n",
        "            time.sleep(wait)\n",
        "            continue\n",
        "\n",
        "        if resp.status_code == 200:\n",
        "            return resp.json(), resp.headers\n",
        "\n",
        "        body = resp.text[:240].replace(\"\\n\", \" \")\n",
        "        print(\n",
        "            f\"[{now()}] HTTP {resp.status_code} bucket={bucket} \"\n",
        "            f\"remain={resp.headers.get('x-ratelimit-remaining')} \"\n",
        "            f\"resource={resp.headers.get('x-ratelimit-resource')} body={body}\"\n",
        "        )\n",
        "\n",
        "        if resp.status_code in (403, 429):\n",
        "            wait = wait_from_headers(resp.headers, fallback=60 + 15 * attempt + random.randint(0, 15))\n",
        "            print(f\"[{now()}] rate/secondary limit; sleep {wait}s\")\n",
        "            time.sleep(wait)\n",
        "            continue\n",
        "\n",
        "        if resp.status_code in (500, 502, 503, 504):\n",
        "            wait = 10 + 8 * attempt + random.randint(0, 8)\n",
        "            time.sleep(wait)\n",
        "            continue\n",
        "\n",
        "        if resp.status_code == 422:\n",
        "            raise RuntimeError(f\"GitHub validation/search error 422: {body}\")\n",
        "\n",
        "        raise RuntimeError(f\"GitHub error {resp.status_code}: {body}\")\n",
        "\n",
        "    raise RuntimeError(f\"GitHub request failed after retries: {url}\")\n",
        "\n",
        "\n",
        "def search_issues(repo, term, start_s, end_s, depth=0):\n",
        "    q = f\"repo:{repo} is:issue created:{start_s}..{end_s} {term}\"\n",
        "    data, _ = gh_get(\n",
        "        \"/search/issues\",\n",
        "        {\n",
        "            \"q\": q,\n",
        "            \"sort\": \"updated\",\n",
        "            \"order\": \"desc\",\n",
        "            \"per_page\": 100,\n",
        "            \"page\": 1,\n",
        "        },\n",
        "        bucket=\"search\",\n",
        "    )\n",
        "\n",
        "    total = int(data.get(\"total_count\", 0) or 0)\n",
        "    if total > 900 and depth < 9:\n",
        "        split = split_date_range(start_s, end_s)\n",
        "        if split:\n",
        "            left, right = split\n",
        "            return search_issues(repo, term, left[0], left[1], depth + 1) + search_issues(\n",
        "                repo, term, right[0], right[1], depth + 1\n",
        "            )\n",
        "\n",
        "    items = data.get(\"items\", []) or []\n",
        "    max_pages = min(10, math.ceil(min(total, 1000) / 100))\n",
        "    for page in range(2, max_pages + 1):\n",
        "        d, _ = gh_get(\n",
        "            \"/search/issues\",\n",
        "            {\n",
        "                \"q\": q,\n",
        "                \"sort\": \"updated\",\n",
        "                \"order\": \"desc\",\n",
        "                \"per_page\": 100,\n",
        "                \"page\": page,\n",
        "            },\n",
        "            bucket=\"search\",\n",
        "        )\n",
        "        items.extend(d.get(\"items\", []) or [])\n",
        "\n",
        "    return [x for x in items if \"pull_request\" not in x]\n",
        "\n",
        "\n",
        "def fetch_comments(repo, issue_number):\n",
        "    comments = []\n",
        "    for page in range(1, MAX_COMMENT_PAGES + 1):\n",
        "        data, _ = gh_get(\n",
        "            f\"/repos/{repo}/issues/{issue_number}/comments\",\n",
        "            {\"per_page\": 100, \"page\": page},\n",
        "            bucket=\"core\",\n",
        "        )\n",
        "        if not data:\n",
        "            break\n",
        "        comments.extend(data)\n",
        "        if len(data) < 100:\n",
        "            break\n",
        "    return comments\n",
        "\n",
        "\n",
        "# =========================\n",
        "# Main pipeline\n",
        "# =========================\n",
        "\n",
        "print(f\"[{now()}] Start rescue continuation\")\n",
        "print(f\"[{now()}] Token mode: {'authenticated' if TOKEN else 'unauthenticated'}\")\n",
        "\n",
        "rate, _ = gh_get(\"/rate_limit\", bucket=\"core\")\n",
        "print(\"[rate_limit search]\", json.dumps(rate.get(\"resources\", {}).get(\"search\", {}), indent=2))\n",
        "print(\"[rate_limit core]\", json.dumps(rate.get(\"resources\", {}).get(\"core\", {}), indent=2))\n",
        "\n",
        "rescue_zip = find_or_upload_rescue_zip()\n",
        "rescue_rows = load_rescue_candidates(rescue_zip)\n",
        "print(f\"[{now()}] Loaded rescue candidates: {len(rescue_rows)} from {rescue_zip}\")\n",
        "\n",
        "candidates_path = CHECKPOINT_DIR / \"candidate_issues_2021_2023_completed.jsonl\"\n",
        "if candidates_path.exists():\n",
        "    loaded = read_jsonl(candidates_path)\n",
        "    print(f\"[{now()}] Loaded candidate checkpoint: {len(loaded)}\")\n",
        "else:\n",
        "    loaded = rescue_rows\n",
        "\n",
        "candidates = {}\n",
        "for row in loaded:\n",
        "    repo = row.get(\"repo\")\n",
        "    num = row.get(\"number\")\n",
        "    if repo in FRAMEWORK_HINT and num is not None:\n",
        "        candidates[(repo, int(num))] = normalize_issue(repo, row)\n",
        "\n",
        "print(\"[candidate counts before]\", dict(Counter(repo for repo, _ in candidates.keys())))\n",
        "\n",
        "repos_to_search = []\n",
        "if CRAWL_PYTORCH_MISSING:\n",
        "    repos_to_search.append(\"pytorch/pytorch\")\n",
        "if CRAWL_TENSORFLOW_MISSING:\n",
        "    repos_to_search.append(\"tensorflow/tensorflow\")\n",
        "\n",
        "for repo in repos_to_search:\n",
        "    fw = FRAMEWORK_HINT[repo]\n",
        "    ranges = month_ranges(\"2021-01-01\", \"2023-12-31\")\n",
        "    terms = TERMS_BY_REPO[repo]\n",
        "    print(f\"\\n[{now()}] Search missing candidates repo={repo}, months={len(ranges)}, terms={len(terms)}\")\n",
        "\n",
        "    for start_s, end_s in tqdm(ranges, desc=f\"candidate search {repo}\"):\n",
        "        month_new = 0\n",
        "        for term in terms:\n",
        "            try:\n",
        "                items = search_issues(repo, term, start_s, end_s)\n",
        "                for item in items:\n",
        "                    row = normalize_issue(repo, item)\n",
        "                    key = (repo, int(row[\"number\"]))\n",
        "                    old = candidates.get(key)\n",
        "                    if old is None:\n",
        "                        candidates[key] = row\n",
        "                        month_new += 1\n",
        "                    elif issue_score(row, fw) > issue_score(old, fw):\n",
        "                        candidates[key] = row\n",
        "            except Exception as exc:\n",
        "                print(f\"[WARN] search failed repo={repo} range={start_s}..{end_s} term={term}: {exc}\")\n",
        "\n",
        "        save_candidate_checkpoint(candidates, candidates_path)\n",
        "        print(f\"[{now()}] {repo} {start_s[:7]} new={month_new} total={sum(1 for r, _ in candidates if r == repo)}\")\n",
        "\n",
        "print(\"[candidate counts after]\", dict(Counter(repo for repo, _ in candidates.keys())))\n",
        "\n",
        "candidate_rows = list(candidates.values())\n",
        "candidate_rows.sort(key=lambda x: issue_score(x, FRAMEWORK_HINT[x[\"repo\"]]), reverse=True)\n",
        "save_candidate_checkpoint(candidates, candidates_path)\n",
        "\n",
        "pd.DataFrame(\n",
        "    [\n",
        "        {\n",
        "            \"repo\": r[\"repo\"],\n",
        "            \"number\": r[\"number\"],\n",
        "            \"title\": r.get(\"title\"),\n",
        "            \"url\": r.get(\"url\"),\n",
        "            \"state\": r.get(\"state\"),\n",
        "            \"created_at\": r.get(\"created_at\"),\n",
        "            \"updated_at\": r.get(\"updated_at\"),\n",
        "            \"comments\": r.get(\"comments\"),\n",
        "            \"labels\": \"|\".join(labels(r)),\n",
        "            \"score\": issue_score(r, FRAMEWORK_HINT[r[\"repo\"]]),\n",
        "        }\n",
        "        for r in candidate_rows\n",
        "    ]\n",
        ").to_csv(OUT_DIR / \"candidate_issues_2021_2023_completed.csv\", index=False)\n",
        "\n",
        "\n",
        "existing_rows = load_existing_fast_records()\n",
        "existing_code_keys = set()\n",
        "for r in existing_rows:\n",
        "    h = r.get(\"code_sha1\") or sha1_text(r.get(\"output\", \"\"))\n",
        "    if h:\n",
        "        existing_code_keys.add((r.get(\"framework\"), h))\n",
        "print(f\"[{now()}] Existing fast records loaded for dedupe/combine: {len(existing_rows)}\")\n",
        "\n",
        "records_partial_path = CHECKPOINT_DIR / \"new_2021_2023.partial.jsonl\"\n",
        "processed_comments_path = CHECKPOINT_DIR / \"processed_comment_issues.jsonl\"\n",
        "\n",
        "records = read_jsonl(records_partial_path)\n",
        "seen_code = set(existing_code_keys)\n",
        "for r in records:\n",
        "    h = r.get(\"code_sha1\") or sha1_text(r.get(\"output\", \"\"))\n",
        "    if h:\n",
        "        seen_code.add((r.get(\"framework\"), h))\n",
        "\n",
        "processed_comments = set()\n",
        "for row in read_jsonl(processed_comments_path):\n",
        "    if row.get(\"repo\") and row.get(\"number\") is not None:\n",
        "        processed_comments.add((row[\"repo\"], int(row[\"number\"])))\n",
        "\n",
        "print(f\"[{now()}] Loaded partial new records={len(records)} processed_comment_issues={len(processed_comments)}\")\n",
        "\n",
        "\n",
        "def add_record_if_new(rec):\n",
        "    if not rec:\n",
        "        return False\n",
        "    key = (rec.get(\"framework\"), rec.get(\"code_sha1\"))\n",
        "    if key in seen_code:\n",
        "        return False\n",
        "    seen_code.add(key)\n",
        "    records.append(rec)\n",
        "    append_jsonl(records_partial_path, rec)\n",
        "    return True\n",
        "\n",
        "\n",
        "print(f\"\\n[{now()}] Fast body-only extraction from all candidates\")\n",
        "body_added = 0\n",
        "for issue in tqdm(candidate_rows, desc=\"body extract\"):\n",
        "    repo = issue[\"repo\"]\n",
        "    for idx, (lang, raw) in enumerate(code_blocks(issue.get(\"body\") or \"\")):\n",
        "        rec = record_from_block(repo, issue, \"issue_body\", idx, lang, raw)\n",
        "        if add_record_if_new(rec):\n",
        "            body_added += 1\n",
        "print(f\"[{now()}] Body records added this run: {body_added}\")\n",
        "\n",
        "\n",
        "selected = []\n",
        "for repo in REPOS:\n",
        "    xs = [r for r in candidate_rows if r[\"repo\"] == repo]\n",
        "    xs.sort(key=lambda x: issue_score(x, FRAMEWORK_HINT[repo]), reverse=True)\n",
        "    take = xs[:FETCH_COMMENTS_TOP_PER_REPO]\n",
        "    selected.extend(take)\n",
        "    print(f\"[{now()}] selected for comments {repo}: {len(take)} / candidates={len(xs)}\")\n",
        "\n",
        "selected = [r for r in selected if (r[\"repo\"], int(r[\"number\"])) not in processed_comments]\n",
        "print(f\"[{now()}] Remaining comment issues to fetch: {len(selected)}\")\n",
        "\n",
        "\n",
        "def process_issue_comments(issue):\n",
        "    repo = issue[\"repo\"]\n",
        "    number = int(issue[\"number\"])\n",
        "    comments = fetch_comments(repo, number)\n",
        "    new_records = []\n",
        "    for c_idx, comment in enumerate(comments):\n",
        "        body = comment.get(\"body\") or \"\"\n",
        "        for b_idx, (lang, raw) in enumerate(code_blocks(body)):\n",
        "            rec = record_from_block(repo, issue, \"comment\", c_idx * 1000 + b_idx, lang, raw)\n",
        "            if rec:\n",
        "                new_records.append(rec)\n",
        "    return repo, number, new_records\n",
        "\n",
        "\n",
        "print(f\"\\n[{now()}] Fetch comments and extract\")\n",
        "comment_added = 0\n",
        "if selected:\n",
        "    with ThreadPoolExecutor(max_workers=MAX_WORKERS) as ex:\n",
        "        futures = [ex.submit(process_issue_comments, issue) for issue in selected]\n",
        "        for fut in tqdm(as_completed(futures), total=len(futures), desc=\"comments extract\"):\n",
        "            try:\n",
        "                repo, number, new_records = fut.result()\n",
        "                added = 0\n",
        "                for rec in new_records:\n",
        "                    if add_record_if_new(rec):\n",
        "                        added += 1\n",
