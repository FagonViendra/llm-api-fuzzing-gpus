        "               f\"Issue: [axiom probe] {title}\\nAPIs: {', '.join(apis)}\")\n",
        "        synthetic.append({\n",
        "            \"id\": rid, \"framework\": \"pytorch\", \"era\": \"2024_2026\", \"axis\": axis,\n",
        "            \"repo\": \"calm/axiom_synthetic\", \"issue_number\": None, \"url\": \"\",\n",
        "            \"quality_score\": None, \"calm_score\": 9.9, \"n_code_lines\": code.count(\"\\n\"),\n",
        "            \"instruction\": instr, \"input\": inp, \"output\": code,\n",
