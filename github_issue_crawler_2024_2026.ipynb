        "print(f\"Cell 1 → train {len(splits['train'])} / val {len(splits['val'])} / test {len(splits['test'])} (từ {IN_DIR})\")\n",
        "\n",
        "# ═════ 1) SMOKE-RUN ngoài tiến trình, theo lô, có watchdog ═══════════════════\n",
        "RUNNER = r'''\n",
        "import json, io, os, sys, contextlib\n",
        "samples_path, results_path = sys.argv[1], sys.argv[2]\n",
        "res = open(results_path, \"a\", encoding=\"utf-8\", buffering=1)\n",
        "def emit(obj):\n",
        "    res.write(json.dumps(obj) + \"\\n\"); res.flush()\n",
        "    try: os.fsync(res.fileno())\n",
        "    except OSError: pass\n",
        "import builtins\n",
        "builtins.input = lambda *a, **k: (_ for _ in ()).throw(EOFError(\"stdin disabled\"))\n",
        "for line in open(samples_path, encoding=\"utf-8\"):\n",
        "    s = json.loads(line)\n",
        "    emit({\"ev\": \"b\", \"id\": s[\"id\"]})\n",
        "    status = \"ok\"\n",
        "    try:\n",
        "        ns = {\"__name__\": \"__main__\"}\n",
        "        with contextlib.redirect_stdout(io.StringIO()), contextlib.redirect_stderr(io.StringIO()):\n",
        "            exec(compile(s[\"code\"], \"<seed>\", \"exec\"), ns)\n",
        "    except SystemExit as e:\n",
