        "    \"precision_dtype\": \"Exercise low/mixed precision paths (fp16/bf16/tf32/fp64) and rounding behavior.\",\n",
        "    \"compile_drift\": \"Contrast eager execution with compiled/graph execution of the same computation.\",\n",
        "    \"metamorphic_axiom\": \"Probe mathematical invariants (sign symmetry, NaN/Inf handling, determinism).\",\n",
        "    \"layout_phase\": \"Vary memory layout, strides and shapes; bugs may be size- or layout-dependent.\",\n",
        "    \"gradient_adjoint\": \"Check forward/backward consistency: gradients must match the math.\",\n",
        "    \"boundary_contract\": \"Stress boundary cases: empty/0-dim tensors, extreme sizes, odd dimensions.\",\n",
        "    \"op_core\": \"Keep the operator chain short and assert on concrete numeric outputs.\",\n",
        "}\n",
        "\n",
        "synthetic = []\n",
