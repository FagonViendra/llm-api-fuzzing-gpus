        "    return {\n",
        "        \"id\": rid, \"framework\": fw, \"era\": era, \"axis\": axis,\n",
        "        \"repo\": r.get(\"repo\", \"\"), \"issue_number\": r.get(\"issue_number\"),\n",
        "        \"url\": r.get(\"url\", \"\"), \"quality_score\": r.get(\"quality_score\"),\n",
        "        \"calm_score\": round(score, 3), \"axis_hits\": axes,\n",
