        "\n",
        "def h64(s):  # hash tất định 64-bit (không dùng hash() vì PYTHONHASHSEED)\n",
        "    return int.from_bytes(hashlib.sha1(s.encode(\"utf-8\", \"ignore\")).digest()[:8], \"big\")\n",
        "\n",
        "def find_zips():\n",
        "    seen, out = set(), []\n",
        "    for d in CFG[\"search_dirs\"]:\n",
        "        p = Path(d)\n",
        "        if p.is_dir():\n",
        "            for z in sorted(p.glob(CFG[\"zip_glob\"])):\n",
        "                if z.name not in seen and z.stat().st_size > 1e6:\n",
        "                    seen.add(z.name); out.append(z)\n",
        "    return out\n",
        "\n",
        "def iter_records(zf):\n",
        "    names = [n for n in zf.namelist() if re.fullmatch(r\"all_\\d{4}_\\d{4}\\.jsonl\", n)] or \\\n",
        "            [n for n in zf.namelist() if n in (\"train.jsonl\", \"val.jsonl\", \"test.jsonl\")]\n",
        "    for n in names:\n",
        "        with zf.open(n) as f:\n",
        "            for line in io.TextIOWrapper(f, encoding=\"utf-8\", errors=\"replace\"):\n",
        "                if line.strip():\n",
        "                    yield json.loads(line)\n",
        "\n",
        "def clean_code(code):\n",
        "    \"\"\"Gọt rác notebook/REPL; chỉ nhận bản gọt nếu vẫn parse được.\"\"\"\n",
        "    out = []\n",
        "    for l in code.splitlines():\n",
        "        s = l.strip()\n",
        "        if s.startswith((\"!pip\", \"%pip\", \"!apt\", \"!wget\", \"%cd\", \"%env\", \"%%\", \"pip install\")):\n",
        "            continue\n",
        "        if s.startswith(\">>> \"):\n",
        "            l = l.replace(\">>> \", \"\", 1)\n",
        "        elif s.startswith(\"... \"):\n",
        "            l = l.replace(\"... \", \"\", 1)\n",
        "        out.append(l)\n",
        "    cleaned = \"\\n\".join(out).strip() + \"\\n\"\n",
        "    try:\n",
        "        ast.parse(cleaned)\n",
        "        return cleaned\n",
        "    except SyntaxError:\n",
        "        return code.strip() + \"\\n\"\n",
        "\n",
        "def static_max_numel(tree):\n",
        "    worst = 0\n",
        "    for node in ast.walk(tree):\n",
        "        if isinstance(node, ast.Call):\n",
        "            name = node.func.attr if isinstance(node.func, ast.Attribute) else getattr(node.func, \"id\", \"\")\n",
        "            if name in ALLOC:\n",
        "                numel, ok = 1, False\n",
        "                for a in node.args:\n",
        "                    if isinstance(a, ast.Constant) and isinstance(a.value, int):\n",
        "                        numel *= max(abs(a.value), 1); ok = True\n",
        "                    elif isinstance(a, (ast.Tuple, ast.List)):\n",
        "                        for e in a.elts:\n",
        "                            if isinstance(e, ast.Constant) and isinstance(e.value, int):\n",
        "                                numel *= max(abs(e.value), 1); ok = True\n",
        "                if ok:\n",
        "                    worst = max(worst, numel)\n",
        "    return worst\n",
        "\n",
        "def simhash(code):\n",
        "    \"\"\"SimHash 64-bit trên 4-gram token đã chuẩn hoá (bỏ comment, thay tên/số).\"\"\"\n",
        "    try:\n",
        "        tree = ast.parse(code)\n",
        "        toks = []\n",
        "        for node in ast.walk(tree):\n",
        "            toks.append(type(node).__name__)\n",
        "            if isinstance(node, ast.Attribute):\n",
        "                toks.append(node.attr)            # giữ tên API, bỏ tên biến\n",
        "            elif isinstance(node, ast.Constant):\n",
        "                toks.append(type(node.value).__name__)\n",
        "    except SyntaxError:\n",
        "        toks = re.findall(r\"[A-Za-z_]+\", code)\n",
        "    v = [0] * 64\n",
        "    for i in range(max(len(toks) - 3, 1)):\n",
        "        hh = h64(\" \".join(toks[i:i + 4]))\n",
        "        for b in range(64):\n",
        "            v[b] += 1 if (hh >> b) & 1 else -1\n",
        "    return sum(1 << b for b in range(64) if v[b] > 0)\n",
        "\n",
        "def near_dup(sig, buckets):\n",
        "    \"\"\"LSH 4 băng × 16 bit: chỉ so Hamming trong cùng băng → gần O(n).\"\"\"\n",
        "    for band in range(4):\n",
        "        key = (band, (sig >> (band * 16)) & 0xFFFF)\n",
        "        for other in buckets.get(key, ()):\n",
        "            if bin(sig ^ other).count(\"1\") <= CFG[\"simhash_hamming\"]:\n",
        "                return True\n",
        "    for band in range(4):\n",
        "        buckets.setdefault((band, (sig >> (band * 16)) & 0xFFFF), []).append(sig)\n",
        "    return False\n",
        "\n",
        "def grade(r):\n",
        "    \"\"\"Trả (sample đã làm giàu, None) hoặc (None, lý do loại).\"\"\"\n",
        "    code = (r.get(\"output\") or \"\").strip()\n",
        "    if not code or not r.get(\"ast_parse_ok\", False):\n",
        "        return None, \"no_code\"\n",
        "    meta = \" \".join([str(r.get(\"issue_title\", \"\")), \" \".join(map(str, r.get(\"labels\", []))),\n",
