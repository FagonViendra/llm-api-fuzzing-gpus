      "source": [
        "from pathlib import Path\n",
        "import json, os, time, zipfile\n",
        "\n",
        "ROOT = Path(\"/content\")\n",
        "\n",
        "def line_count(p):\n",
        "    try:\n",
        "        with open(p, \"r\", encoding=\"utf-8\", errors=\"ignore\") as f:\n",
        "            return sum(1 for _ in f)\n",
        "    except Exception:\n",
        "        return None\n",
        "\n",
        "def size_mb(p):\n",
        "    return p.stat().st_size / 1024 / 1024\n",
        "\n",
        "def mtime(p):\n",
        "    return time.strftime(\"%Y-%m-%d %H:%M:%S\", time.localtime(p.stat().st_mtime))\n",
        "\n",
        "print(\"=== /content overview ===\")\n",
        "for p in sorted(ROOT.iterdir(), key=lambda x: x.stat().st_mtime, reverse=True):\n",
        "    if p.is_dir() and p.name.startswith((\"dl_issue\", \"rescue\", \"gemma\")):\n",
        "        print(f\"\\n📁 {p} | modified={mtime(p)}\")\n",
        "        for child in sorted(p.iterdir(), key=lambda x: x.name):\n",
        "            if child.is_file():\n",
        "                extra = \"\"\n",
        "                if child.suffix == \".jsonl\":\n",
        "                    extra = f\" | lines={line_count(child)}\"\n",
        "                print(f\"  - {child.name} | {size_mb(child):.2f} MB | modified={mtime(child)}{extra}\")\n",
        "                if child.name.startswith(\"manifest\") and child.suffix == \".json\":\n",
        "                    try:\n",
        "                        data = json.loads(child.read_text(encoding=\"utf-8\"))\n",
        "                        print(\"    manifest:\", json.dumps(data, ensure_ascii=False, indent=2)[:1500])\n",
        "                    except Exception as e:\n",
        "                        print(\"    manifest read error:\", e)\n",
        "\n",
        "print(\"\\n=== ZIP files ===\")\n",
        "for z in sorted(ROOT.glob(\"*.zip\"), key=lambda x: x.stat().st_mtime, reverse=True):\n",
        "    print(f\"\\n🗜️ {z} | {size_mb(z):.2f} MB | modified={mtime(z)}\")\n",
        "    try:\n",
        "        with zipfile.ZipFile(z) as zz:\n",
        "            names = zz.namelist()\n",
        "            print(\"  files:\", names[:12], \"...\" if len(names) > 12 else \"\")\n",
        "    except Exception as e:\n",
        "        print(\"  zip error:\", e)\n",
        "\n",
        "print(\"\\n=== Direct likely dataset files ===\")\n",
        "for pattern in [\n",
        "    \"/content/**/all.jsonl\",\n",
        "    \"/content/**/records_from_rescue.jsonl\",\n",
        "    \"/content/**/combined*.jsonl\",\n",
        "    \"/content/**/train.jsonl\",\n",
        "    \"/content/**/gemma_fuzz*.jsonl\",\n",
        "]:\n",
        "    for p in ROOT.glob(pattern.replace(\"/content/**/\", \"**/\")):\n",
        "        if p.is_file():\n",
        "            print(f\"{p} | {size_mb(p):.2f} MB | lines={line_count(p)} | modified={mtime(p)}\")"
      ],
