        "    if any(rx.search(meta) for rx in HARD_C):\n",
        "        return None, \"env_packaging\"\n",
        "    code = clean_code(code)\n",
        "    if len(code) < CFG[\"min_code_chars\"]:\n",
        "        return None, \"too_short\"\n",
        "    if len(code) > CFG[\"max_code_chars\"]:\n",
        "        return None, \"too_long\"\n",
        "    fw = r.get(\"framework\", \"\")\n",
        "    has_import = re.search(r\"^\\s*(import torch|from torch)\", code, re.M) if fw == \"pytorch\" \\\n",
