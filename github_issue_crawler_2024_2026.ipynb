        "    status = {s[\"id\"]: \"unvalidated\" for s in skipped}\n",
        "    runner_path = str(OUT_DIR / \"_smoke_runner.py\")\n",
        "    Path(runner_path).write_text(RUNNER, encoding=\"utf-8\")\n",
        "    env = dict(os.environ, MPLBACKEND=\"Agg\", TF_CPP_MIN_LOG_LEVEL=\"3\",\n",
        "               TORCHDYNAMO_DISABLE=\"1\", TORCH_COMPILE_DISABLE=\"1\",\n",
        "               HF_HUB_OFFLINE=\"1\", TRANSFORMERS_OFFLINE=\"1\", PYTHONIOENCODING=\"utf-8\",\n",
        "               CUDA_VISIBLE_DEVICES=os.environ.get(\"CUDA_VISIBLE_DEVICES\", \"0\"))\n",
        "    if not have:  # máy không có torch/TF → chứng minh bộ máy bằng self-test rồi thôi\n",
        "        print(\"⚠ torch/tensorflow chưa cài ở máy này → bỏ qua smoke-run (Colab sẽ chạy đủ).\")\n",
        "        demo = [{\"id\": \"t_ok\", \"framework\": \"x\", \"output\": \"print(1+1)\"},\n",
        "                {\"id\": \"t_raise\", \"framework\": \"x\", \"output\": \"raise ValueError('boom')\"},\n",
        "                {\"id\": \"t_hang\", \"framework\": \"x\", \"output\": \"import time\\nwhile True: time.sleep(1)\"}]\n",
        "        old = CFG2[\"per_sample_timeout\"]; CFG2[\"per_sample_timeout\"] = 4\n",
        "        got = run_chunk(demo, runner_path, env); CFG2[\"per_sample_timeout\"] = old\n",
        "        assert got[\"t_ok\"] == \"ok\" and got[\"t_raise\"] == \"raise:ValueError\" \\\n",
        "               and got[\"t_hang\"] == \"timeout\", got\n",
        "        print(\"  self-test bộ máy watchdog: ok / raise / timeout phân loại đúng ✓\")\n",
        "        return status\n",
        "    print(f\"Smoke-run {len(todo)} mẫu ({', '.join(sorted(have))}), \"\n",
        "          f\"lô {CFG2['chunk_size']}, {CFG2['workers']} luồng, timeout {CFG2['per_sample_timeout']}s/mẫu…\")\n",
        "    chunks = [todo[i:i + CFG2[\"chunk_size\"]] for i in range(0, len(todo), CFG2[\"chunk_size\"])]\n",
        "    from concurrent.futures import ThreadPoolExecutor\n",
        "    t0, done_n = time.time(), 0\n",
        "    with ThreadPoolExecutor(CFG2[\"workers\"]) as ex:\n",
        "        for got in ex.map(lambda c: run_chunk(c, runner_path, env), chunks):\n",
        "            status.update(got); done_n += len(got)\n",
        "            if done_n % 200 < CFG2[\"chunk_size\"]:\n",
        "                print(f\"  …{done_n}/{len(todo)} ({time.time()-t0:.0f}s)\")\n",
        "    return status\n",
        "\n",
        "def verdict(st):\n",
        "    if st in (\"ok\", \"native_crash\", \"unvalidated\", \"runner_giveup\"):\n",
        "        return \"keep\"\n",
        "    if st == \"timeout\":\n",
