        "\n",
        "# ═════ 3) Gói cuối: ghi split, prompt giữ lại, config FT, manifest, report ═══\n",
        "order = lambda rows: sorted(rows, key=lambda s: h64(s[\"id\"] + \"final\" + CFG2[\"seed_salt\"]))\n",
