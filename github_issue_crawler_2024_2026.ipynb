    {
      "cell_type": "code",
      "source": [
        "# @title\n",
        "# =========================\n",
        "# Colab 1-cell: Crawl PyTorch/TensorFlow issues -> FuzzGPT-style SFT dataset\n",
        "# Output: /content/dl_issue_fuzz_dataset/*.jsonl + zip\n",
        "# =========================\n",
        "\n",
        "!pip -q install requests tqdm pandas\n",
        "\n",
        "import os, re, json, time, math, random, hashlib, zipfile, getpass, ast\n",
        "from pathlib import Path\n",
        "from datetime import datetime, timezone, timedelta, date\n",
        "from concurrent.futures import ThreadPoolExecutor, as_completed\n",
        "\n",
        "import requests\n",
        "import pandas as pd\n",
        "from tqdm.auto import tqdm\n",
        "\n",
        "# ========= CONFIG: chỉnh rất ít thôi =========\n",
        "MODE = \"deadline_high_yield\"   # \"deadline_high_yield\" | \"deep\"\n",
        "REPOS = [\"pytorch/pytorch\", \"tensorflow/tensorflow\"]\n",
        "\n",
        "if MODE == \"deadline_high_yield\":\n",
        "    START_DATE = \"2021-01-01\"   # đủ mới, đủ nhiều, chạy còn kịp deadline\n",
        "    MAX_ISSUES_PER_REPO = 4500\n",
        "    FETCH_COMMENTS_FOR_TOP_PER_REPO = 1500\n",
        "    MAX_COMMENT_PAGES_PER_ISSUE = 2\n",
        "else:\n",
        "    START_DATE = \"2017-01-01\"   # sâu hơn, lâu hơn nhiều\n",
        "    MAX_ISSUES_PER_REPO = 12000\n",
        "    FETCH_COMMENTS_FOR_TOP_PER_REPO = 3500\n",
        "    MAX_COMMENT_PAGES_PER_ISSUE = 3\n",
        "\n",
        "END_DATE = datetime.now(timezone.utc).date().isoformat()\n",
        "OUT_DIR = Path(\"/content/dl_issue_fuzz_dataset\")\n",
        "OUT_DIR.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "MIN_RECORD_SCORE = 6\n",
        "MAX_SNIPPET_CHARS = 8000\n",
        "RANDOM_SEED = 1337\n",
        "MAX_WORKERS = 4\n",
        "\n",
        "# Query shard ngắn để không vỡ giới hạn query của GitHub Search.\n",
        "# Dùng nhiều shard thay vì 1 query khổng lồ.\n",
        "QUERY_SHARDS = [\n",
        "    '(bug OR regression OR broken)',\n",
        "    '(crash OR segfault OR \"segmentation fault\")',\n",
        "    '(\"minimal repro\" OR \"minimal reproduction\" OR reproduction OR reproduce)',\n",
        "    '(\"wrong result\" OR incorrect OR mismatch OR inconsistency)',\n",
        "    '(\"RuntimeError\" OR \"AssertionError\" OR \"ValueError\" OR \"InternalError\")',\n",
        "    '(\"CUDA error\" OR cuda OR cudnn OR gpu OR xla)',\n",
        "    '(autograd OR gradient OR backward OR jacobian)',\n",
        "    '(dtype OR shape OR nan OR inf)',\n",
        "    '(\"torch.compile\" OR dynamo OR inductor OR functorch)',\n",
        "    '(\"tf.function\" OR keras OR eager OR graph)',\n",
        "]\n",
        "\n",
        "BUG_TERMS = [\n",
        "    \"bug\", \"regression\", \"crash\", \"segfault\", \"segmentation fault\",\n",
        "    \"runtimeerror\", \"assertionerror\", \"valueerror\", \"internalerror\",\n",
        "    \"wrong result\", \"incorrect\", \"mismatch\", \"inconsistency\",\n",
        "    \"nan\", \"inf\", \"cuda\", \"cudnn\", \"gpu\", \"xla\",\n",
        "    \"autograd\", \"gradient\", \"backward\", \"memory leak\",\n",
        "    \"deadlock\", \"hang\", \"minimal repro\", \"reproduce\", \"reproduction\",\n",
        "]\n",
        "\n",
        "ORACLE_TERMS = {\n",
        "    \"crash\": [\"crash\", \"segfault\", \"segmentation fault\", \"floating point exception\", \"abort\", \"core dumped\"],\n",
        "    \"exception\": [\"runtimeerror\", \"assertionerror\", \"valueerror\", \"internalerror\", \"typeerror\"],\n",
        "    \"silent_wrong_result\": [\"wrong result\", \"incorrect\", \"mismatch\", \"inconsistency\", \"different result\"],\n",
        "    \"autograd\": [\"autograd\", \"gradient\", \"backward\", \"jacobian\", \"gradcheck\"],\n",
        "    \"resource\": [\"memory leak\", \"oom\", \"out of memory\", \"deadlock\", \"hang\"],\n",
        "    \"numerical\": [\"nan\", \"inf\", \"overflow\", \"underflow\", \"precision\"],\n",
        "}\n",
        "\n",
        "API_REGEX = {\n",
        "    \"pytorch\": [\n",
        "        r\"\\btorch(?:\\.[A-Za-z_]\\w*){1,6}\\b\",\n",
        "        r\"\\btorchvision(?:\\.[A-Za-z_]\\w*){1,6}\\b\",\n",
        "        r\"\\bfunctorch(?:\\.[A-Za-z_]\\w*){0,6}\\b\",\n",
        "    ],\n",
        "    \"tensorflow\": [\n",
        "        r\"\\btf(?:\\.[A-Za-z_]\\w*){1,6}\\b\",\n",
        "        r\"\\btensorflow(?:\\.[A-Za-z_]\\w*){1,6}\\b\",\n",
        "        r\"\\bkeras(?:\\.[A-Za-z_]\\w*){1,6}\\b\",\n",
        "    ],\n",
        "}\n",
        "\n",
        "FRAMEWORK_HINT = {\n",
        "    \"pytorch/pytorch\": \"pytorch\",\n",
        "    \"tensorflow/tensorflow\": \"tensorflow\",\n",
        "}\n",
        "\n",
        "# ========= TOKEN =========\n",
        "TOKEN = os.environ.get(\"GITHUB_TOKEN\", \"\").strip()\n",
        "try:\n",
        "    from google.colab import userdata\n",
        "    TOKEN = TOKEN or (userdata.get(\"GITHUB_TOKEN\") or \"\").strip()\n",
        "except Exception:\n",
        "    pass\n",
        "\n",
        "if not TOKEN:\n",
        "    print(\"⚠️ Chưa thấy GITHUB_TOKEN trong Colab Secrets/env.\")\n",
        "    print(\"Không token vẫn chạy nhưng rất dễ dính rate limit. Dán token public/read-only hoặc Enter để chạy chay.\")\n",
        "    try:\n",
        "        TOKEN = getpass.getpass(\"GITHUB_TOKEN: \").strip()\n",
        "    except Exception:\n",
        "        TOKEN = \"\"\n",
        "\n",
        "HEADERS = {\n",
        "    \"Accept\": \"application/vnd.github+json\",\n",
        "    \"X-GitHub-Api-Version\": \"2022-11-28\",\n",
        "    \"User-Agent\": \"dl-issue-fuzz-dataset-crawler\",\n",
        "}\n",
        "if TOKEN:\n",
        "    HEADERS[\"Authorization\"] = f\"Bearer {TOKEN}\"\n",
        "\n",
        "SESSION = requests.Session()\n",
        "API = \"https://api.github.com\"\n",
        "\n",
        "def now():\n",
        "    return datetime.now().strftime(\"%H:%M:%S\")\n",
        "\n",
        "def parse_date(s):\n",
        "    return datetime.strptime(s, \"%Y-%m-%d\").date()\n",
        "\n",
        "def daterange_split(start_s, end_s):\n",
        "    s, e = parse_date(start_s), parse_date(end_s)\n",
        "    mid = s + (e - s) // 2\n",
        "    if mid >= e:\n",
        "        return None\n",
        "    return (s.isoformat(), mid.isoformat()), ((mid + timedelta(days=1)).isoformat(), e.isoformat())\n",
        "\n",
        "def safe_text(x):\n",
        "    return x if isinstance(x, str) else \"\"\n",
        "\n",
        "def sha1(x):\n",
        "    return hashlib.sha1(x.encode(\"utf-8\", errors=\"ignore\")).hexdigest()\n",
        "\n",
        "def github_get(endpoint_or_url, params=None, retries=8):\n",
        "    url = endpoint_or_url if endpoint_or_url.startswith(\"http\") else API + endpoint_or_url\n",
        "    params = dict(params or {})\n",
        "    used_fallback = False\n",
        "\n",
        "    for attempt in range(retries):\n",
        "        try:\n",
        "            r = SESSION.get(url, headers=HEADERS, params=params, timeout=40)\n",
        "        except requests.RequestException as e:\n",
        "            wait = min(90, 2 ** attempt + random.random())\n",
        "            print(f\"[{now()}] network lỗi: {e}; ngủ {wait:.1f}s\")\n",
        "            time.sleep(wait)\n",
        "            continue\n",
        "\n",
        "        if r.status_code == 401:\n",
        "            raise RuntimeError(\"GitHub token sai/hết hạn. Kiểm tra GITHUB_TOKEN.\")\n",
        "\n",
        "        # Fallback nếu endpoint advanced_search chưa được tài khoản/API chấp nhận.\n",
        "        if r.status_code == 422 and params.get(\"advanced_search\") and not used_fallback:\n",
        "            params.pop(\"advanced_search\", None)\n",
        "            used_fallback = True\n",
        "            continue\n",
        "\n",
        "        if r.status_code in (403, 429):\n",
        "            msg = r.text.lower()\n",
        "            rem = int(r.headers.get(\"X-RateLimit-Remaining\", \"0\") or 0)\n",
        "            reset = int(r.headers.get(\"X-RateLimit-Reset\", \"0\") or 0)\n",
        "\n",
        "            if \"secondary rate\" in msg or \"abuse\" in msg:\n",
        "                wait = 75 + random.randint(0, 45)\n",
        "            elif rem == 0 and reset:\n",
        "                wait = max(10, reset - int(time.time()) + 5)\n",
        "            else:\n",
        "                wait = 60 + random.randint(0, 30)\n",
        "\n",
        "            print(f\"[{now()}] GitHub rate/secondary limit; ngủ {wait}s\")\n",
        "            time.sleep(wait)\n",
        "            continue\n",
        "\n",
        "        if r.status_code in (500, 502, 503, 504):\n",
        "            wait = min(120, 2 ** attempt + random.random() * 3)\n",
        "            print(f\"[{now()}] GitHub {r.status_code}; ngủ {wait:.1f}s\")\n",
        "            time.sleep(wait)\n",
        "            continue\n",
        "\n",
        "        if r.status_code >= 400:\n",
        "            raise RuntimeError(f\"GitHub API lỗi {r.status_code}: {r.text[:500]}\")\n",
        "\n",
        "        return r.json(), r.headers\n",
        "\n",
        "    raise RuntimeError(f\"Hết retry cho {url}\")\n",
        "\n",
        "def search_issues_window(repo, expr, start_s, end_s, depth=0):\n",
        "    q = f'repo:{repo} is:issue state:all created:{start_s}..{end_s} {expr}'\n",
        "    params = {\n",
        "        \"q\": q,\n",
        "        \"sort\": \"updated\",\n",
        "        \"order\": \"desc\",\n",
        "        \"per_page\": 100,\n",
        "        \"page\": 1,\n",
        "        \"advanced_search\": \"true\",\n",
        "    }\n",
        "    data, _ = github_get(\"/search/issues\", params=params)\n",
        "    total = int(data.get(\"total_count\", 0) or 0)\n",
        "\n",
        "    # Search API trả tối đa 1000 kết quả/query; nếu quá dày thì chia đôi ngày.\n",
        "    if total > 900 and depth < 12:\n",
        "        sp = daterange_split(start_s, end_s)\n",
        "        if sp:\n",
        "            left, right = sp\n",
        "            return (\n",
        "                search_issues_window(repo, expr, left[0], left[1], depth + 1)\n",
        "                + search_issues_window(repo, expr, right[0], right[1], depth + 1)\n",
        "            )\n",
        "\n",
        "    items = data.get(\"items\", [])\n",
        "    max_pages = min(10, math.ceil(min(total, 1000) / 100))\n",
        "    for page in range(2, max_pages + 1):\n",
        "        params[\"page\"] = page\n",
        "        d, _ = github_get(\"/search/issues\", params=params)\n",
        "        items.extend(d.get(\"items\", []))\n",
        "    return items\n",
        "\n",
        "def label_names(issue):\n",
        "    return [x.get(\"name\", \"\") for x in issue.get(\"labels\", []) if isinstance(x, dict)]\n",
        "\n",
        "def framework_of(repo):\n",
        "    return FRAMEWORK_HINT.get(repo, \"unknown\")\n",
        "\n",
        "def extract_code_blocks(md):\n",
        "    md = safe_text(md)\n",
        "    blocks = []\n",
        "\n",
        "    # fenced Markdown code blocks\n",
        "    pat = re.compile(r\"```[ \\t]*([A-Za-z0-9_+\\-\\.]*)?[ \\t]*\\n(.*?)```\", re.S)\n",
        "    for m in pat.finditer(md):\n",
        "        lang = (m.group(1) or \"\").strip().lower()\n",
        "        code = m.group(2) or \"\"\n",
        "        blocks.append((lang, code))\n",
        "\n",
        "    # fallback: HTML <pre><code>...</code></pre> rất hiếm nhưng có\n",
        "    pat2 = re.compile(r\"<pre><code>(.*?)</code></pre>\", re.S | re.I)\n",
        "    for m in pat2.finditer(md):\n",
        "        blocks.append((\"\", m.group(1) or \"\"))\n",
        "\n",
        "    return blocks\n",
        "\n",
        "def clean_code(code):\n",
        "    code = safe_text(code)\n",
        "    code = code.replace(\"\\r\\n\", \"\\n\").replace(\"\\r\", \"\\n\")\n",
        "    out = []\n",
        "    for line in code.split(\"\\n\"):\n",
        "        line = re.sub(r\"^\\s*(>>>|\\.\\.\\.)\\s?\", \"\", line)\n",
        "        line = line.rstrip()\n",
        "        out.append(line)\n",
        "    code = \"\\n\".join(out).strip()\n",
        "\n",
        "    # cắt nếu người dùng paste cả log cực dài\n",
        "    if len(code) > MAX_SNIPPET_CHARS:\n",
        "        code = code[:MAX_SNIPPET_CHARS] + \"\\n# ... [TRUNCATED]\"\n",
        "    return code\n",
        "\n",
        "def extract_apis(text, fw):\n",
        "    found = set()\n",
        "    for pat in API_REGEX.get(fw, []):\n",
        "        for m in re.finditer(pat, text):\n",
        "            x = m.group(0)\n",
        "            if len(x) <= 120:\n",
        "                found.add(x.replace(\"tensorflow.\", \"tf.\"))\n",
        "    return sorted(found)\n",
        "\n",
        "def infer_oracle_type(text):\n",
        "    t = safe_text(text).lower()\n",
        "    hits = []\n",
        "    for k, terms in ORACLE_TERMS.items():\n",
        "        if any(term in t for term in terms):\n",
        "            hits.append(k)\n",
        "    return hits or [\"unknown\"]\n",
        "\n",
        "def ast_ok(code):\n",
        "    try:\n",
        "        ast.parse(code)\n",
        "        return True\n",
        "    except Exception:\n",
        "        return False\n",
        "\n",
        "def issue_score(issue):\n",
        "    title = safe_text(issue.get(\"title\"))\n",
        "    body = safe_text(issue.get(\"body\"))\n",
        "    labels = \" \".join(label_names(issue)).lower()\n",
        "    txt = (title + \"\\n\" + body + \"\\n\" + labels).lower()\n",
        "\n",
        "    score = 0\n",
        "    if any(x in labels for x in [\"bug\", \"triaged\", \"regression\", \"module:\", \"comp:\", \"type:bug\", \"type: bug\"]):\n",
        "        score += 4\n",
        "    score += min(5, sum(1 for k in BUG_TERMS if k in txt))\n",
        "    if extract_code_blocks(body):\n",
        "        score += 4\n",
        "    if issue.get(\"comments\", 0):\n",
        "        score += min(3, int(math.log2(issue.get(\"comments\", 0) + 1)))\n",
        "    if any(x in txt for x in [\"expected behavior\", \"actual behavior\", \"environment\", \"version\", \"collect_env\"]):\n",
        "        score += 3\n",
        "    return score\n",
        "\n",
        "def snippet_score(code, ctx, labels, fw):\n",
        "    t = (code + \"\\n\" + ctx + \"\\n\" + \" \".join(labels)).lower()\n",
        "    apis = extract_apis(code, fw)\n",
        "    score = 0\n",
        "\n",
        "    if apis:\n",
        "        score += 5\n",
        "    if fw == \"pytorch\" and re.search(r\"\\b(import torch|from torch|torch\\.)\", code):\n",
        "        score += 5\n",
        "    if fw == \"tensorflow\" and re.search(r\"\\b(import tensorflow|import keras|from tensorflow|tf\\.|keras\\.)\", code):\n",
        "        score += 5\n",
        "\n",
        "    if any(k in t for k in BUG_TERMS):\n",
        "        score += min(5, sum(1 for k in BUG_TERMS if k in t))\n",
        "\n",
        "    labels_l = \" \".join(labels).lower()\n",
        "    if any(x in labels_l for x in [\"bug\", \"regression\", \"triaged\", \"module:\", \"comp:\", \"type: bug\", \"type:bug\"]):\n",
        "        score += 3\n",
        "\n",
        "    if 40 <= len(code) <= MAX_SNIPPET_CHARS:\n",
        "        score += 2\n",
        "    if ast_ok(code):\n",
        "        score += 3\n",
        "    elif \"traceback\" in code.lower() and not apis:\n",
        "        score -= 4\n",
        "\n",
        "    # giảm log thuần\n",
        "    if code.lower().count(\"traceback\") and not re.search(r\"\\b(import |torch\\.|tf\\.|tensorflow\\.|keras\\.)\", code):\n",
        "        score -= 5\n",
        "\n",
        "    return score\n",
        "\n",
        "def make_record(repo, issue, source_kind, source_index, source_body, lang, raw_code):\n",
        "    fw = framework_of(repo)\n",
        "    labels = label_names(issue)\n",
        "    title = safe_text(issue.get(\"title\"))\n",
        "    body = safe_text(issue.get(\"body\"))\n",
        "    ctx = f\"{title}\\n{body[:4000]}\\n{source_body[:3000]}\"\n",
        "    code = clean_code(raw_code)\n",
        "    apis = extract_apis(code, fw)\n",
        "    score = snippet_score(code, ctx, labels, fw)\n",
        "\n",
        "    if score < MIN_RECORD_SCORE:\n",
        "        return None\n",
        "    if fw == \"pytorch\" and not re.search(r\"\\b(torch\\.|import torch|from torch|torchvision\\.|functorch\\.)\", code):\n",
        "        return None\n",
        "    if fw == \"tensorflow\" and not re.search(r\"\\b(tf\\.|tensorflow\\.|keras\\.|import tensorflow|import keras|from tensorflow)\", code):\n",
        "        return None\n",
        "\n",
        "    issue_number = issue.get(\"number\")\n",
        "    url = issue.get(\"html_url\") or f\"https://github.com/{repo}/issues/{issue_number}\"\n",
        "    oracle_type = infer_oracle_type(ctx + \"\\n\" + code)\n",
        "\n",
        "    instruction = (\n",
        "        \"Generate or mutate a minimal Python reproducer / fuzz seed for a deep-learning \"\n",
        "        \"library bug. Prefer runnable code, edge-case tensors, dtype/shape/device variants, \"\n",
        "        \"and an oracle such as crash, exception, numerical mismatch, autograd mismatch, or hang.\"\n",
        "    )\n",
        "    inp = (\n",
        "        f\"Framework: {fw}\\n\"\n",
        "        f\"Repository: {repo}\\n\"\n",
        "        f\"Issue: #{issue_number} - {title}\\n\"\n",
        "        f\"Labels: {', '.join(labels)}\\n\"\n",
        "        f\"Detected APIs: {', '.join(apis[:20])}\\n\"\n",
        "        f\"Oracle type: {', '.join(oracle_type)}\\n\"\n",
        "        f\"URL: {url}\\n\"\n",
        "    )\n",
        "\n",
        "    return {\n",
        "        \"id\": f\"{repo}#{issue_number}:{source_kind}:{source_index}:{sha1(code)[:12]}\",\n",
        "        \"framework\": fw,\n",
        "        \"repo\": repo,\n",
        "        \"issue_number\": issue_number,\n",
        "        \"issue_title\": title,\n",
        "        \"url\": url,\n",
        "        \"state\": issue.get(\"state\"),\n",
        "        \"created_at\": issue.get(\"created_at\"),\n",
        "        \"updated_at\": issue.get(\"updated_at\"),\n",
        "        \"closed_at\": issue.get(\"closed_at\"),\n",
        "        \"labels\": labels,\n",
        "        \"source_kind\": source_kind,\n",
        "        \"source_index\": source_index,\n",
        "        \"markdown_lang\": lang,\n",
        "        \"apis\": apis,\n",
        "        \"oracle_type\": oracle_type,\n",
        "        \"quality_score\": score,\n",
        "        \"code_sha1\": sha1(code),\n",
        "        \"instruction\": instruction,\n",
        "        \"input\": inp,\n",
        "        \"output\": code,\n",
        "        \"raw_context_excerpt\": ctx[:2500],\n",
        "    }\n",
        "\n",
        "def fetch_issue_full_and_comments(repo, number):\n",
        "    full, _ = github_get(f\"/repos/{repo}/issues/{number}\")\n",
        "    comments = []\n",
        "    for page in range(1, MAX_COMMENT_PAGES_PER_ISSUE + 1):\n",
        "        d, _ = github_get(\n",
        "            f\"/repos/{repo}/issues/{number}/comments\",\n",
        "            params={\"per_page\": 100, \"page\": page}\n",
        "        )\n",
        "        if not d:\n",
        "            break\n",
        "        comments.extend(d)\n",
        "        if len(d) < 100:\n",
        "            break\n",
        "    return full, comments\n",
        "\n",
        "def write_jsonl(path, rows):\n",
        "    with open(path, \"w\", encoding=\"utf-8\") as f:\n",
        "        for r in rows:\n",
        "            f.write(json.dumps(r, ensure_ascii=False) + \"\\n\")\n",
        "\n",
        "# ========= STAGE 1: search candidate issues =========\n",
        "all_issue_map = {}\n",
        "\n",
        "print(f\"[{now()}] START crawl candidates | repos={REPOS} | {START_DATE}..{END_DATE} | mode={MODE}\")\n",
        "for repo in REPOS:\n",
        "    repo_items = {}\n",
        "    print(f\"\\n[{now()}] Repo: {repo}\")\n",
        "\n",
        "    for expr in tqdm(QUERY_SHARDS, desc=f\"search shards {repo}\"):\n",
        "        try:\n",
        "            items = search_issues_window(repo, expr, START_DATE, END_DATE)\n",
        "        except Exception as e:\n",
        "            print(f\"[WARN] shard lỗi repo={repo}, expr={expr}: {e}\")\n",
        "            continue\n",
        "\n",
        "        for it in items:\n",
        "            if it.get(\"pull_request\"):\n",
        "                continue\n",
        "            num = it.get(\"number\")\n",
        "            if not num:\n",
        "                continue\n",
        "            repo_items[num] = it\n",
        "\n",
        "        if len(repo_items) >= MAX_ISSUES_PER_REPO:\n",
        "            break\n",
        "\n",
        "    scored = sorted(repo_items.values(), key=issue_score, reverse=True)\n",
        "    scored = scored[:MAX_ISSUES_PER_REPO]\n",
        "    for it in scored:\n",
        "        all_issue_map[(repo, it[\"number\"])] = it\n",
        "\n",
        "    print(f\"[{now()}] {repo}: unique candidates={len(repo_items)}, kept={len(scored)}\")\n",
        "\n",
        "# ========= STAGE 2: fetch full issue + comments for top candidates =========\n",
        "selected = []\n",
        "for repo in REPOS:\n",
        "    xs = [it for (r, n), it in all_issue_map.items() if r == repo]\n",
        "    xs = sorted(xs, key=issue_score, reverse=True)[:FETCH_COMMENTS_FOR_TOP_PER_REPO]\n",
        "    selected.extend([(repo, it[\"number\"], it) for it in xs])\n",
        "\n",
        "print(f\"\\n[{now()}] Fetch full issue/comments for {len(selected)} issues...\")\n",
        "full_issues = {}\n",
        "comments_map = {}\n",
        "\n",
        "def fetch_one(task):\n",
        "    repo, num, seed_item = task\n",
        "    try:\n",
        "        full, comments = fetch_issue_full_and_comments(repo, num)\n",
        "        return (repo, num, full, comments, None)\n",
        "    except Exception as e:\n",
        "        return (repo, num, seed_item, [], str(e))\n",
        "\n",
        "workers = MAX_WORKERS if TOKEN else 1\n",
        "with ThreadPoolExecutor(max_workers=workers) as ex:\n",
        "    futs = [ex.submit(fetch_one, t) for t in selected]\n",
        "    for fut in tqdm(as_completed(futs), total=len(futs), desc=\"full+comments\"):\n",
        "        repo, num, full, comments, err = fut.result()\n",
        "        if err:\n",
        "            print(f\"[WARN] fetch lỗi {repo}#{num}: {err}\")\n",
        "        full_issues[(repo, num)] = full\n",
        "        comments_map[(repo, num)] = comments\n",
        "\n",
        "# ========= STAGE 3: extract code blocks -> records =========\n",
        "records = []\n",
        "seen_code = set()\n",
        "issue_rows = []\n",
        "\n",
        "print(f\"\\n[{now()}] Extract code blocks...\")\n",
        "for (repo, num), issue in tqdm(full_issues.items(), desc=\"extract\"):\n",
        "    fw = framework_of(repo)\n",
        "    labels = label_names(issue)\n",
        "    iscore = issue_score(issue)\n",
        "\n",
        "    issue_rows.append({\n",
        "        \"repo\": repo,\n",
        "        \"framework\": fw,\n",
        "        \"number\": num,\n",
        "        \"title\": issue.get(\"title\"),\n",
        "        \"url\": issue.get(\"html_url\"),\n",
        "        \"state\": issue.get(\"state\"),\n",
        "        \"created_at\": issue.get(\"created_at\"),\n",
        "        \"updated_at\": issue.get(\"updated_at\"),\n",
        "        \"comments\": issue.get(\"comments\"),\n",
        "        \"labels\": \"|\".join(labels),\n",
        "        \"issue_score\": iscore,\n",
        "    })\n",
        "\n",
        "    bodies = [(\"issue_body\", 0, safe_text(issue.get(\"body\")))]\n",
        "    for i, c in enumerate(comments_map.get((repo, num), [])):\n",
        "        bodies.append((\"comment\", i, safe_text(c.get(\"body\"))))\n",
        "\n",
        "    for source_kind, source_index, md in bodies:\n",
        "        for lang, code in extract_code_blocks(md):\n",
        "            rec = make_record(repo, issue, source_kind, source_index, md, lang, code)\n",
        "            if not rec:\n",
        "                continue\n",
        "            # dedupe theo code + framework, vì nhiều issue/comment quote lại cùng repro\n",
        "            key = (rec[\"framework\"], rec[\"code_sha1\"])\n",
        "            if key in seen_code:\n",
        "                continue\n",
        "            seen_code.add(key)\n",
        "            records.append(rec)\n",
        "\n",
        "records = sorted(records, key=lambda r: r[\"quality_score\"], reverse=True)\n",
        "\n",
        "# ========= STAGE 4: train/val/test split =========\n",
        "random.seed(RANDOM_SEED)\n",
        "shuffled = records[:]\n",
        "random.shuffle(shuffled)\n",
        "\n",
        "n = len(shuffled)\n",
        "n_val = max(1, int(n * 0.05)) if n else 0\n",
        "n_test = max(1, int(n * 0.05)) if n else 0\n",
        "val = shuffled[:n_val]\n",
        "test = shuffled[n_val:n_val+n_test]\n",
        "train = shuffled[n_val+n_test:]\n",
        "\n",
        "# ========= STAGE 5: write files =========\n",
        "dataset_path = OUT_DIR / \"fuzzgpt_style_pytorch_tensorflow_issues.jsonl\"\n",
        "train_path = OUT_DIR / \"train.jsonl\"\n",
        "val_path = OUT_DIR / \"val.jsonl\"\n",
        "test_path = OUT_DIR / \"test.jsonl\"\n",
        "issues_csv = OUT_DIR / \"candidate_issues.csv\"\n",
        "manifest_path = OUT_DIR / \"manifest.json\"\n",
        "\n",
        "write_jsonl(dataset_path, records)\n",
        "write_jsonl(train_path, train)\n",
        "write_jsonl(val_path, val)\n",
        "write_jsonl(test_path, test)\n",
        "\n",
        "pd.DataFrame(issue_rows).sort_values(\"issue_score\", ascending=False).to_csv(issues_csv, index=False)\n",
        "\n",
        "stats = {\n",
        "    \"created_at\": datetime.now(timezone.utc).isoformat(),\n",
        "    \"mode\": MODE,\n",
        "    \"repos\": REPOS,\n",
        "    \"start_date\": START_DATE,\n",
        "    \"end_date\": END_DATE,\n",
        "    \"candidate_issues\": len(full_issues),\n",
        "    \"records_total\": len(records),\n",
        "    \"train\": len(train),\n",
        "    \"val\": len(val),\n",
        "    \"test\": len(test),\n",
        "    \"by_framework\": pd.Series([r[\"framework\"] for r in records]).value_counts().to_dict() if records else {},\n",
        "    \"avg_quality_score\": float(sum(r[\"quality_score\"] for r in records) / len(records)) if records else 0.0,\n",
        "    \"min_record_score\": MIN_RECORD_SCORE,\n",
        "    \"notes\": [\n",
        "        \"Records are mined from public GitHub issues/comments.\",\n",
        "        \"Each record is SFT-style: instruction/input/output.\",\n",
        "        \"Output is the original cleaned code block; verify licenses/policies before redistribution.\",\n",
        "        \"Recommended next step: run snippets in sandbox and add execution_result/crash_signature/validity fields.\",\n",
        "    ],\n",
        "}\n",
        "manifest_path.write_text(json.dumps(stats, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n",
        "\n",
        "zip_path = Path(\"/content/dl_issue_fuzz_dataset.zip\")\n",
        "with zipfile.ZipFile(zip_path, \"w\", zipfile.ZIP_DEFLATED) as z:\n",
        "    for p in OUT_DIR.glob(\"*\"):\n",
        "        z.write(p, arcname=p.name)\n",
        "\n",
        "# ========= preview =========\n",
        "print(\"\\n================ DONE ================\")\n",
        "print(json.dumps(stats, ensure_ascii=False, indent=2))\n",
        "print(f\"\\nDataset: {dataset_path}\")\n",
        "print(f\"Zip:     {zip_path}\")\n",
        "\n",
        "print(\"\\nTop 5 records:\")\n",
        "for r in records[:5]:\n",
        "    print(\"-\" * 80)\n",
        "    print(f'{r[\"repo\"]}#{r[\"issue_number\"]} | score={r[\"quality_score\"]} | {r[\"issue_title\"][:120]}')\n",
        "    print(f'APIs: {\", \".join(r[\"apis\"][:12])}')\n",
        "    print(f'URL: {r[\"url\"]}')\n",
        "    print(r[\"output\"][:700].replace(\"\\n\", \"\\n  \"))\n",
        "\n",
        "try:\n",
        "    from google.colab import files\n",
        "    print(\"\\nĐang gọi download zip...\")\n",
        "    files.download(str(zip_path))\n",
        "except Exception as e:\n",
        "    print(f\"Tải thủ công ở: {zip_path} | {e}\")"
      ],
