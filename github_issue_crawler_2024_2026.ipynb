        "print(\"== LỆNH TẢI ==\")\n",
        "print(\" \".join(cmd))\n",
        "print()\n",
        "\n",
        "p = subprocess.run(cmd, text=True, capture_output=True)\n",
        "print(\"== STDOUT ==\")\n",
        "print(p.stdout)\n",
        "print(\"== STDERR ==\")\n",
        "print(p.stderr)\n",
        "\n",
        "if p.returncode != 0:\n",
        "    raise RuntimeError(f\"pip download lỗi với mã {p.returncode}. Kéo phần STDERR gửi lại tôi nếu vẫn fail.\")\n",
        "\n",
        "install_script = ROOT / \"install_offline_tensorflow_cpu.sh\"\n",
        "install_script.write_text(f\"\"\"#!/usr/bin/env bash\n",
        "set -euo pipefail\n",
        "cd \"$(dirname \"$0\")\"\n",
        "\n",
        "python3 -m pip install --upgrade pip setuptools wheel\n",
        "\n",
        "python3 -m pip install \\\\\n",
        "  --no-index \\\\\n",
        "  --find-links ./wheelhouse \\\\\n",
        "  --only-binary=:all: \\\\\n",
        "  {TF_PKG}=={TF_VERSION}\n",
        "\n",
        "python3 - <<'PY'\n",
        "import sys\n",
        "print(\"Python:\", sys.version)\n",
        "import tensorflow as tf\n",
        "print(\"TensorFlow:\", tf.__version__)\n",
        "print(\"Physical devices:\", tf.config.list_physical_devices())\n",
        "print(\"Quick tensor:\", tf.reduce_sum(tf.random.normal([16, 16])).numpy())\n",
        "PY\n",
        "\"\"\", encoding=\"utf-8\")\n",
        "os.chmod(install_script, 0o755)\n",
        "\n",
        "manifest = {\n",
        "    \"package\": TF_PKG,\n",
        "    \"version\": TF_VERSION,\n",
        "    \"target\": {\n",
        "        \"python\": \"cp313-cp313\",\n",
        "        \"os\": \"linux\",\n",
        "        \"machine\": \"x86_64\",\n",
        "        \"platforms\": [\n",
        "            \"manylinux_2_27_x86_64\",\n",
        "            \"manylinux_2_17_x86_64\",\n",
        "            \"manylinux2014_x86_64\",\n",
        "        ],\n",
        "    },\n",
        "    \"install\": \"bash install_offline_tensorflow_cpu.sh\",\n",
        "    \"note\": \"CPU-only TensorFlow wheelhouse for offline install into ChatGPT sandbox if upload size is accepted.\",\n",
        "}\n",
        "(ROOT / \"manifest.json\").write_text(json.dumps(manifest, indent=2, ensure_ascii=False), encoding=\"utf-8\")\n",
        "\n",
        "print()\n",
        "print(\"== DANH SÁCH WHEEL ==\")\n",
        "total = 0\n",
        "for p in sorted(WHEELHOUSE.glob(\"*.whl\")):\n",
        "    size = p.stat().st_size\n",
        "    total += size\n",
        "    print(f\"{p.name}  {size/1024/1024:.1f} MB\")\n",
        "print(f\"Tổng dung lượng wheel: {total/1024/1024:.1f} MB\")\n",
        "\n",
        "archive_base = \"/content/tensorflow_cpu_2_21_0_cp313_linux_x86_64_wheelhouse\"\n",
        "archive_path = shutil.make_archive(\n",
        "    archive_base,\n",
        "    \"gztar\",\n",
        "    root_dir=str(ROOT.parent),\n",
        "    base_dir=ROOT.name,\n",
        ")\n",
        "\n",
        "print()\n",
        "print(\"== XONG ==\")\n",
        "print(\"Tệp:\", archive_path)\n",
        "print(\"Dung lượng nén:\", round(os.path.getsize(archive_path)/1024/1024, 1), \"MB\")\n",
        "\n",
        "files.download(archive_path)"
      ],
